<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="description" content="Painel administrativo do EJC COP para gerenciar inscricoes, aprovacoes e operacoes do encontro.">
  <title>Painel de Inscrição - EJC COP</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Manrope:wght@400;500;600;700;800&family=Sora:wght@500;600;700&display=swap" rel="stylesheet">
  <link rel="preload" href="/vendor/fontawesome/css/all.min.css" as="style" onload="this.onload=null;this.rel='stylesheet'">
  <noscript><link rel="stylesheet" href="/vendor/fontawesome/css/all.min.css"></noscript>
  <link rel="stylesheet" href="/css/admin-saas.css">
</head>
<body class="admin-panel admin-home-page">
  <div class="admin-background"></div>
  <div class="admin-home-container">
    <div class="user-info-badge">
      <i class="fas fa-user-shield"></i>
      Logado como: <strong><%= adminUsername %></strong>
    </div>

    <div class="admin-header">
      <h1><i class="fas fa-clipboard-list"></i> Painel Administrativo</h1>
      <p>Escolha o tipo de cadastro que deseja realizar</p>
    </div>

    <div class="cards-grid">
      <!-- ENCONTRISTAS -->
      <a href="/inscricao?tipo=encontrista" class="card-option">
        <div class="card-icon">
          <i class="fas fa-user"></i>
        </div>
        <h2 class="card-title">Encontristas</h2>
        <p class="card-description">
          Pessoas que desejam participar dos encontros do EJC
        </p>
      </a>

      <!-- ENCONTREIROS -->
      <a href="/encontro?tipo=encontreiro" class="card-option">
        <div class="card-icon">
          <i class="fas fa-user-friends"></i>
        </div>
        <h2 class="card-title">Encontreiros</h2>
        <p class="card-description">
          Pessoas ou casais experientes que coordenaram encontros
        </p>
      </a>

      <!-- GERENCIAR CADASTROS -->
      <a href="/admin/gerenciar-cadastros" class="card-option">
        <div class="card-icon">
          <i class="fas fa-users-cog"></i>
        </div>
        <h2 class="card-title">Gerenciar Cadastros</h2>
        <p class="card-description">
          Visualizar, editar e aprovar todos os cadastros do sistema
        </p>
        <span class="card-button">
          <svg class="icon icon-space" viewBox="0 0 24 24" aria-hidden="true"><path d="M13.17 5.17a1 1 0 0 1 1.41 0l6 6a1 1 0 0 1 0 1.41l-6 6a1 1 0 1 1-1.41-1.41L17.59 13H4a1 1 0 1 1 0-2h13.59l-4.42-4.41a1 1 0 0 1 0-1.42Z"/></svg>Acessar Painel
        </span>
      </a>
    </div>

    <div style="text-align: center; margin-top: 32px;">
      <a href="/admin/logout" class="logout-btn" style="text-decoration: none;">
        <i class="fas fa-sign-out-alt"></i> Sair
      </a>
    </div>
  </div>
  

</body>
</html>