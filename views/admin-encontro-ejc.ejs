    async function appPrompt({ title = 'Editar', label = 'Novo valor', value = '', placeholder = '', help = '', confirmText = 'Salvar' }) {
      const { element, instance } = ensureAppInputPopup();
      const titleEl = element.querySelector('#app-input-title');
      const labelEl = element.querySelector('#app-input-label');
      const inputEl = element.querySelector('#app-input-field');
      const helpEl = element.querySelector('#app-input-help');
      const cancelBtn = element.querySelector('#app-input-cancel');
      const confirmBtn = element.querySelector('#app-input-confirm');

      titleEl.textContent = title;
      labelEl.textContent = label;
      inputEl.value = String(value || '');
      inputEl.placeholder = String(placeholder || '');
      helpEl.textContent = String(help || '');
      helpEl.style.display = help ? '' : 'none';
      confirmBtn.textContent = confirmText;

      return new Promise((resolve) => {
        let resolved = false;

        const cleanup = () => {
          cancelBtn.removeEventListener('click', onCancel);
          confirmBtn.removeEventListener('click', onConfirm);
          inputEl.removeEventListener('keydown', onInputKeydown);
          element.removeEventListener('shown.bs.modal', onShown);
          element.removeEventListener('hidden.bs.modal', onHidden);
        };

        const settle = (val) => {
          if (resolved) return;
          resolved = true;
          cleanup();
          resolve(val);
        };

        const onCancel = () => {
          settle(null);
          instance.hide();
        };

        const onConfirm = () => {
          settle(String(inputEl.value || ''));
          instance.hide();
        };

        const onInputKeydown = (event) => {
          if (event.key === 'Enter') {
            event.preventDefault();
            onConfirm();
          }
        };

        const onShown = () => {
          inputEl.focus();
          inputEl.select();
        };

        const onHidden = () => settle(null);

        cancelBtn.addEventListener('click', onCancel);
        confirmBtn.addEventListener('click', onConfirm);
        inputEl.addEventListener('keydown', onInputKeydown);
        element.addEventListener('shown.bs.modal', onShown, { once: true });
        element.addEventListener('hidden.bs.modal', onHidden, { once: true });

        instance.show();
      });
    }

    function abrirExportacao(entidadeTipo, entidadeId, formato, botao) {
      if (!ensurePermission(entidadeTipo === 'circulo' ? 'encontros.gerenciar' : 'equipes.gerenciar')) return;
      if (!entidadeTipo || !entidadeId || !formato) return;

      let restoreTimer = null;
      if (botao) {
        botao.disabled = true;
        botao.dataset.originalHtml = botao.innerHTML;
        botao.innerHTML = '<span class="spinner-border spinner-border-sm me-1" role="status" aria-hidden="true"></span>Gerando...';
      }

      const url = `/admin/encontros/${encodeURIComponent(ejcId)}/export/${encodeURIComponent(entidadeTipo)}/${encodeURIComponent(entidadeId)}/${encodeURIComponent(formato)}`;
      window.open(url, '_blank');

      // The browser handles the download asynchronously, so we restore button state after a short delay.
      restoreTimer = setTimeout(() => {
        if (botao) {
          botao.disabled = false;
          botao.innerHTML = botao.dataset.originalHtml || botao.innerHTML;
          delete botao.dataset.originalHtml;
        }
      }, 1600);

      return restoreTimer;
    }

    function gerarQuadrante(botao) {
      if (!ensurePermission('encontros.gerenciar')) return;
      let restoreTimer = null;
      if (botao) {
        botao.disabled = true;
        botao.dataset.originalHtml = botao.innerHTML;
        botao.innerHTML = '<span class="spinner-border spinner-border-sm me-1" role="status" aria-hidden="true"></span>Gerando...';
      }

      const url = `/admin/encontros/${encodeURIComponent(ejcId)}/quadrante/editor`;
      window.location.href = url;

      restoreTimer = setTimeout(() => {
        if (botao) {
          botao.disabled = false;
          botao.innerHTML = botao.dataset.originalHtml || botao.innerHTML;
          delete botao.dataset.originalHtml;
        }
      }, 1800);

      return restoreTimer;
    }

    function ativarPainel(panelId, btn) {
      const targetPanel = document.getElementById(panelId);
      if (!targetPanel || targetPanel.style.display === 'none') return;

      document.querySelectorAll('.panel').forEach((panel) => panel.classList.remove('active', 'panel-entering'));
      targetPanel.classList.add('active');
      targetPanel.classList.add('panel-entering');
      window.setTimeout(() => {
        targetPanel.classList.remove('panel-entering');
      }, 320);

      document.querySelectorAll('.menu-btn').forEach((b) => b.classList.remove('active'));
      const menuButton = btn || document.querySelector(`.menu-btn[data-panel="${panelId}"]`);
      if (menuButton) menuButton.classList.add('active');
      atualizarAtalhosPainelAtivo(panelId);

      salvarPainelAtivo();
    }

    function atualizarAtalhosPainelAtivo(panelId) {
      document.querySelectorAll('.encontro-module-card[data-panel-target]').forEach((item) => {
        item.classList.toggle('active', item.dataset.panelTarget === panelId);
      });
    }

    function getPainelAtivoId() {
      const ativo = document.querySelector('.panel.active');
      return ativo && ativo.id ? ativo.id : 'panel-circulos';
    }

    function getPainelStorageKey() {
      return `admin_encontro_ejc_painel_${String(ejcId || 'default')}`;
    }

    function salvarPainelAtivo() {
      const painelId = getPainelAtivoId();
      localStorage.setItem(getPainelStorageKey(), painelId);

      const url = new URL(window.location.href);
      url.searchParams.set('painel', painelId);
      window.history.replaceState({}, '', url.toString());
    }

    function restaurarPainelAtivo() {
      const url = new URL(window.location.href);
      const painelNaUrl = String(url.searchParams.get('painel') || '').trim();
      const painelNoStorage = String(localStorage.getItem(getPainelStorageKey()) || '').trim();
      const painelFallback = getPrimeiroPainelDisponivelId();
      const painelDesejado = painelNaUrl || painelNoStorage || painelFallback;
      const painelEl = document.getElementById(painelDesejado);

      if (painelEl && painelEl.style.display !== 'none') {
        ativarPainel(painelDesejado);
        return;
      }

      ativarPainel(painelFallback);
    }

    function recarregarMantendoPainelAtual() {
      salvarPainelAtivo();
      window.location.href = window.location.href;
    }

    function getChecklistElements(selectId) {
      return {
        select: document.getElementById(selectId),
        list: document.getElementById(`lista_${selectId}`),
      };
    }

    function closeAllChecklists(exceptSelectId = '') {
      ['encontrista_id', 'encontreiro_id'].forEach((selectId) => {
        if (selectId === exceptSelectId) return;
        const { list } = getChecklistElements(selectId);
        if (list) list.classList.add('d-none');
      });
    }

    function toggleMultiChecklist(selectId) {
      const { list } = getChecklistElements(selectId);
      if (!list) return;

      const willOpen = list.classList.contains('d-none');
      closeAllChecklists(selectId);
      if (willOpen) {
        list.classList.remove('d-none');
      } else {
        list.classList.add('d-none');
      }
    }

    function filtrarSelectMulti(selectId, termo) {
      const filtro = String(termo || '').trim().toLowerCase();
      const { list } = getChecklistElements(selectId);
      if (!list) return;

      if (filtro) {
        list.classList.remove('d-none');
      }

      Array.from(list.querySelectorAll('.multi-check-item')).forEach((item) => {
        const texto = String(item.getAttribute('data-text') || '');
        item.style.display = (!filtro || texto.includes(filtro)) ? '' : 'none';
      });
    }

    function limparFiltroSelectMulti(inputId, selectId) {
      const input = document.getElementById(inputId);
      if (input) {
        input.value = '';
      }

      filtrarSelectMulti(selectId, '');

      if (input) {
        input.focus();
      }
    }

    function initChecklistFromSelect(selectId) {
      const { select, list } = getChecklistElements(selectId);
      if (!select || !list) return;

      const options = Array.from(select.options || []).filter((option) => option.value);
      list.innerHTML = options.map((option) => {
        const optionValue = escapeHtml(String(option.value || ''));
        const optionTextRaw = String(option.textContent || '').trim();
        const optionText = escapeHtml(optionTextRaw);
        const checked = option.selected ? 'checked' : '';
        return `
          <label class="multi-check-item" data-value="${optionValue}" data-text="${escapeHtml(optionTextRaw.toLowerCase())}">
            <input type="checkbox" value="${optionValue}" ${checked} onchange="toggleChecklistValue('${selectId}', this.value, this.checked)">
            <span>${optionText}</span>
          </label>
        `;
      }).join('');

      atualizarContadorSelecao(selectId);
    }

    function toggleChecklistValue(selectId, value, checked) {
      const { select } = getChecklistElements(selectId);
      if (!select) return;

      const option = Array.from(select.options || []).find((item) => String(item.value) === String(value));
      if (!option) return;

      option.selected = Boolean(checked);
      select.dispatchEvent(new Event('change'));
      atualizarContadorSelecao(selectId);
    }

    function atualizarResumoSelecao(selectId) {
      const select = document.getElementById(selectId);
      const resumo = document.getElementById(`resumo_${selectId}`);
      if (!select || !resumo) return;

      const selecionados = Array.from(select.selectedOptions || []);
      if (!selecionados.length) {
        resumo.textContent = 'Clique para selecionar nomes';
      } else if (selecionados.length === 1) {
        resumo.textContent = selecionados[0].textContent || '1 nome selecionado';
      } else {
        resumo.textContent = `${selecionados.length} nomes selecionados`;
      }
    }

    function atualizarContadorSelecao(selectId) {
      const select = document.getElementById(selectId);
      const contador = document.getElementById(`contador_${selectId}`);
      if (!select || !contador) return;

      const totalSelecionados = Array.from(select.selectedOptions || [])
        .map((option) => String(option.value || '').trim())
        .filter(Boolean)
        .length;

      contador.textContent = totalSelecionados === 1
        ? '1 selecionado'
        : `${totalSelecionados} selecionados`;

      atualizarResumoSelecao(selectId);
    }

    function observarContadorSelecao(selectId) {
      const select = document.getElementById(selectId);
      if (!select) return;

      const atualizar = () => atualizarContadorSelecao(selectId);
      select.addEventListener('change', atualizar);
      select.addEventListener('keyup', atualizar);
      select.addEventListener('mouseup', atualizar);
      atualizar();
    }

    document.addEventListener('click', (event) => {
      const target = event.target;
      if (!(target instanceof Element)) return;
      if (target.closest('.multi-select-panel')) return;
      closeAllChecklists();
    });

    async function removerVinculo(vinculoId) {
      if (!vinculoId) return;
      const vinculo = vinculos.find((item) => String(item._id) === String(vinculoId));
      const permissaoNecessaria = vinculo?.entidadeTipo === 'equipe' ? 'equipes.gerenciar' : 'encontros.gerenciar';
      if (!ensurePermission(permissaoNecessaria)) return;
      if (!await appConfirm('Deseja remover este vinculo?', 'Confirmar remocao')) return;

      const res = await fetch(`/admin/remover-vinculo/${encodeURIComponent(vinculoId)}`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' }
      });
      const data = await res.json();
      if (!data.success) return await appAlert(data.error || 'Erro ao remover vinculo.', 'danger', 'Erro');
      recarregarMantendoPainelAtual();
    }

    async function criarCirculo() {
      if (!ensurePermission('encontros.gerenciar')) return;
      const nome = document.getElementById('circulo_nome').value.trim();
      if (!nome) return await appAlert('Informe o nome do circulo.', 'warning', 'Campo obrigatorio');
      const res = await fetch('/admin/criar-circulo', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ nome, ejcId })
      });
      const data = await res.json();
      if (!data.success) return await appAlert(data.error || 'Erro ao criar circulo.', 'danger', 'Erro');
      recarregarMantendoPainelAtual();
    }

    async function criarEquipe() {
      if (!ensurePermission('equipes.gerenciar')) return;
      const nome = document.getElementById('equipe_nome').value.trim();
      if (!nome) return await appAlert('Informe o nome da equipe.', 'warning', 'Campo obrigatorio');
      const res = await fetch('/admin/cadastrar-equipe', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ nome, ejcId })
      });
      const data = await res.json();
      if (!data.success) return await appAlert(data.error || 'Erro ao criar equipe.', 'danger', 'Erro');
      recarregarMantendoPainelAtual();
    }

    async function editarCirculo(circuloId, nomeAtual) {
      if (!ensurePermission('encontros.gerenciar')) return;
      if (!circuloId) return;
      const novoNome = String(await appPrompt({
        title: 'Editar circulo',
        label: 'Nome do circulo',
        value: nomeAtual || '',
        placeholder: 'Digite o novo nome',
        help: 'O nome sera atualizado neste EJC.',
        confirmText: 'Salvar',
      }) || '').trim();
      if (!novoNome || novoNome === String(nomeAtual || '').trim()) return;

      const res = await fetch(`/admin/editar-circulo/${encodeURIComponent(circuloId)}`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ ejcId, nome: novoNome }),
      });
      const data = await res.json();
      if (!data.success) return await appAlert(data.error || 'Erro ao editar circulo.', 'danger', 'Erro');
      recarregarMantendoPainelAtual();
    }

    async function excluirCirculo(circuloId, nomeCirculo) {
      if (!ensurePermission('encontros.gerenciar')) return;
      if (!circuloId) return;
      if (!await appConfirm(`Deseja excluir o circulo \"${nomeCirculo || ''}\"? Todos os vinculos dele serao removidos.`, 'Confirmar exclusao')) return;

      const res = await fetch(`/admin/excluir-circulo/${encodeURIComponent(circuloId)}`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ ejcId }),
      });
      const data = await res.json();
      if (!data.success) return await appAlert(data.error || 'Erro ao excluir circulo.', 'danger', 'Erro');
      recarregarMantendoPainelAtual();
    }

    async function editarEquipe(equipeId, nomeAtual) {
      if (!ensurePermission('equipes.gerenciar')) return;
      if (!equipeId) return;
      const novoNome = String(await appPrompt({
        title: 'Editar equipe',
        label: 'Nome da equipe',
        value: nomeAtual || '',
        placeholder: 'Digite o novo nome',
        help: 'O nome e referencias de equipe serao atualizados.',
        confirmText: 'Salvar',
      }) || '').trim();
      if (!novoNome || novoNome === String(nomeAtual || '').trim()) return;

      const res = await fetch(`/admin/editar-equipe/${encodeURIComponent(equipeId)}`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ ejcId, nome: novoNome }),
      });
      const data = await res.json();
      if (!data.success) return await appAlert(data.error || 'Erro ao editar equipe.', 'danger', 'Erro');
      recarregarMantendoPainelAtual();
    }

    async function excluirEquipe(equipeId, nomeEquipe) {
      if (!ensurePermission('equipes.gerenciar')) return;
      if (!equipeId) return;
      if (!await appConfirm(`Deseja excluir a equipe \"${nomeEquipe || ''}\"? Todos os vinculos dela serao removidos.`, 'Confirmar exclusao')) return;

      const res = await fetch(`/admin/excluir-equipe/${encodeURIComponent(equipeId)}`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ ejcId }),
      });
      const data = await res.json();
      if (!data.success) return await appAlert(data.error || 'Erro ao excluir equipe.', 'danger', 'Erro');
      recarregarMantendoPainelAtual();
    }

    async function vincularEncontristaCirculo() {
      if (!ensurePermission('encontros.gerenciar')) return;
      try {
        const entidadeId = document.getElementById('circulo_id').value;
        const pessoaIds = Array.from(document.getElementById('encontrista_id').selectedOptions || [])
          .map((option) => String(option.value || '').trim())
          .filter(Boolean);
        const papel = document.getElementById('papel_circulo').value || 'membro';
        const descricaoPapel = (document.getElementById('descricao_papel_moita').value || '').trim();

        if (!entidadeId || pessoaIds.length === 0) return await appAlert('Selecione circulo e ao menos um encontrista.', 'warning', 'Dados incompletos');
        if (papel === 'moita' && !descricaoPapel) {
          return await appAlert('Informe qual papel a pessoa esta fazendo na moita.', 'warning', 'Campo obrigatorio');
        }

        console.log('[VINCULAR CIRCULO]', { ejcId, entidadeId, pessoaIds, papel, descricaoPapel });

        const res = await fetch('/admin/vincular-encontro', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            ejcId,
            entidadeTipo: 'circulo',
            entidadeId,
            pessoaTipo: 'encontrista',
            pessoaIds,
            papel,
            descricaoPapel,
          })
        });

        const data = await res.json();
        console.log('[VINCULAR CIRCULO] resposta:', res.status, data);
        if (!res.ok || !data.success) {
          return await appAlert(data.error || 'Erro ao vincular encontrista.', 'danger', 'Erro');
        }

        if ((Number(data.vinculados) || 0) === 0) {
          return await appAlert(`Nenhum novo vinculo foi criado. Esses nomes podem ja estar vinculados nesse circulo. (ja vinculados: ${data.jaVinculados || 0}, nao encontrados: ${data.naoEncontrados || 0})`, 'warning', 'Sem alteracoes');
        }

        recarregarMantendoPainelAtual();
      } catch (err) {
        await appAlert(`Falha ao vincular encontrista: ${err.message}`, 'danger', 'Erro');
      }
    }

    async function vincularEncontreiroEquipeEJC() {
      if (!ensurePermission('equipes.gerenciar')) return;
      try {
        const entidadeId = document.getElementById('equipe_id').value;
        const pessoaIds = Array.from(document.getElementById('encontreiro_id').selectedOptions || [])
          .map((option) => String(option.value || '').trim())
          .filter(Boolean);
        const papel = document.getElementById('papel_equipe').value;

        if (!entidadeId || pessoaIds.length === 0 || !papel) {
          return await appAlert('Selecione equipe, ao menos uma pessoa e vinculo.', 'warning', 'Dados incompletos');
        }

        console.log('[VINCULAR EQUIPE]', { ejcId, entidadeId, pessoaIds, papel });

        const res = await fetch('/admin/vincular-encontro', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ ejcId, entidadeTipo: 'equipe', entidadeId, pessoaTipo: 'encontreiro', pessoaIds, papel })
        });

        const data = await res.json();
        console.log('[VINCULAR EQUIPE] resposta:', res.status, data);
        if (!res.ok || !data.success) {
          return await appAlert(data.error || 'Erro ao vincular na equipe.', 'danger', 'Erro');
        }

        if ((Number(data.vinculados) || 0) === 0) {
          return await appAlert(`Nenhum novo vinculo foi criado. Esses nomes podem ja estar vinculados nessa equipe. (ja vinculados: ${data.jaVinculados || 0}, nao encontrados: ${data.naoEncontrados || 0})`, 'warning', 'Sem alteracoes');
        }

        recarregarMantendoPainelAtual();
      } catch (err) {
        await appAlert(`Falha ao vincular na equipe: ${err.message}`, 'danger', 'Erro');
      }
    }

    function alternarCampoMoita() {
      const papel = document.getElementById('papel_circulo').value;
      const wrap = document.getElementById('wrap_papel_moita');
      if (!wrap) return;

      if (papel === 'moita') {
        wrap.style.display = '';
      } else {
        wrap.style.display = 'none';
        const input = document.getElementById('descricao_papel_moita');
        if (input) input.value = '';
      }
    }

    initChecklistFromSelect('encontrista_id');
    initChecklistFromSelect('encontreiro_id');
    observarContadorSelecao('encontrista_id');
    observarContadorSelecao('encontreiro_id');
    alternarCampoMoita();
    aplicarPermissoesNaPagina();
    restaurarPainelAtivo();
    renderAll();
  </script>
</body>
</html>

