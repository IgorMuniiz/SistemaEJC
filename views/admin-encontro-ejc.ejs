<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="description" content="Gestao de circulos e equipes do EJC com vinculo de encontristas, encontreiros e exportacao de quadrante.">
  <title>Encontro - <%= ejc.nome %></title>
  <link rel="preload" href="/vendor/bootstrap/css/bootstrap.min.css" as="style" onload="this.onload=null;this.rel='stylesheet'">
  <noscript><link rel="stylesheet" href="/vendor/bootstrap/css/bootstrap.min.css"></noscript>
  <link rel="preload" href="/vendor/fontawesome/css/all.min.css" as="style" onload="this.onload=null;this.rel='stylesheet'">
  <noscript><link rel="stylesheet" href="/vendor/fontawesome/css/all.min.css"></noscript>
  <link rel="stylesheet" href="/css/admin-saas.css">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Manrope:wght@400;500;600;700;800&family=Sora:wght@500;600;700&display=swap" rel="stylesheet">
</head>
<body class="admin-panel admin-encontro-page admin-encontro-revamp">
  <% const totalVinculosCirculo = (vinculos || []).filter(function(v){ return v.entidadeTipo === 'circulo'; }).length; %>
  <% const totalVinculosEquipe = (vinculos || []).filter(function(v){ return v.entidadeTipo === 'equipe'; }).length; %>
  <% const totalPessoasVinculadas = totalVinculosCirculo + totalVinculosEquipe; %>
  <% const adminPermissoesLista = Array.isArray(adminPermissoes) ? adminPermissoes : []; %>
  <div class="page-shell">
    <aside class="sidebar">
      <div class="title"><i class="fas fa-layer-group me-2"></i>Painel do EJC</div>
      <div class="subtitle"><%= ejc.nome %></div>

      <button type="button" class="menu-btn active" data-panel="panel-circulos" data-required-permission="encontros.gerenciar" onclick="ativarPainel('panel-circulos', this)">
        <i class="fas fa-circle-notch me-2"></i>Círculos
      </button>
      <button type="button" class="menu-btn" data-panel="panel-equipes" data-required-permission="equipes.gerenciar" onclick="ativarPainel('panel-equipes', this)">
        <i class="fas fa-people-group me-2"></i>Equipes
      </button>

      <button type="button" class="menu-btn" data-required-permission="encontros.gerenciar" onclick="gerarQuadrante(this)">
        <i class="fas fa-file-pdf me-2"></i>Gerar Quadrante
      </button>

      <a class="btn btn-light w-100 mt-3" href="/admin/gerenciar-cadastros">
        <i class="fas fa-arrow-left me-1"></i>Voltar ao Admin
      </a>
    </aside>

    <main class="content-area">
      <div class="topbar workspace-hero">
        <div class="workspace-hero-main">
          <h1 class="workspace-title-encontro">
            <span class="workspace-title-icon" aria-hidden="true"><i class="fas fa-layer-group"></i></span>
            <span class="workspace-title-copy">
              <span class="workspace-title-kicker">Painel</span>
              <span class="workspace-title-main">Gestão do EJC</span>
            </span>
          </h1>
          <div class="workspace-hero-strip" aria-label="Destaques do encontro">
            <span class="hero-strip-pill"><i class="fas fa-circle-notch"></i><%= totalVinculosCirculo %> vínculos em círculos</span>
            <span class="hero-strip-pill"><i class="fas fa-people-group"></i><%= totalVinculosEquipe %> vínculos em equipes</span>
            <span class="hero-strip-pill"><i class="fas fa-file-export"></i><%= totalPessoasVinculadas %> pessoas distribuídas</span>
          </div>
        </div>
        <div class="workspace-stats" aria-label="Resumo da operacao">
          <article class="workspace-stat-card">
            <span class="stat-label">Circulos</span>
            <strong class="stat-value"><%= (circulos || []).length %></strong>
          </article>
          <article class="workspace-stat-card">
            <span class="stat-label">Equipes</span>
            <strong class="stat-value"><%= (equipes || []).length %></strong>
          </article>
          <article class="workspace-stat-card">
            <span class="stat-label">Vinculos Circulos</span>
            <strong class="stat-value"><%= totalVinculosCirculo %></strong>
          </article>
          <article class="workspace-stat-card">
            <span class="stat-label">Vinculos Equipes</span>
            <strong class="stat-value"><%= totalVinculosEquipe %></strong>
          </article>
        </div>
      </div>

      <section class="encontro-module-grid" aria-label="Atalhos do painel EJC">
        <button type="button" class="encontro-module-card active" data-panel-target="panel-circulos" data-required-permission="encontros.gerenciar" onclick="ativarPainel('panel-circulos')">
          <span class="encontro-module-icon"><i class="fas fa-circle-notch"></i></span>
          <span class="encontro-module-copy">
            <span class="encontro-module-title">Círculos</span>
          </span>
          <span class="encontro-module-count"><%= (circulos || []).length %></span>
        </button>
        <button type="button" class="encontro-module-card" data-panel-target="panel-equipes" data-required-permission="equipes.gerenciar" onclick="ativarPainel('panel-equipes')">
          <span class="encontro-module-icon"><i class="fas fa-people-group"></i></span>
          <span class="encontro-module-copy">
            <span class="encontro-module-title">Equipes</span>
          </span>
          <span class="encontro-module-count"><%= (equipes || []).length %></span>
        </button>
        <button type="button" class="encontro-module-card encontro-module-card-action" data-required-permission="encontros.gerenciar" onclick="gerarQuadrante(this)">
          <span class="encontro-module-icon"><i class="fas fa-file-pdf"></i></span>
          <span class="encontro-module-copy">
            <span class="encontro-module-title">Quadrante</span>
          </span>
          <span class="encontro-module-count"><%= totalPessoasVinculadas %></span>
        </button>
        <a class="encontro-module-card encontro-module-card-link" href="/admin/gerenciar-cadastros">
          <span class="encontro-module-icon"><i class="fas fa-arrow-left"></i></span>
          <span class="encontro-module-copy">
            <span class="encontro-module-title">Voltar ao Admin</span>
          </span>
          <span class="encontro-module-count"><i class="fas fa-up-right-from-square"></i></span>
        </a>
      </section>

      <section id="panel-circulos" class="panel active" data-required-permission="encontros.gerenciar">
        <div class="panel-premium-head panel-premium-head-circulos">
          <div>
            <h2><i class="fas fa-circle-notch me-2"></i>Curadoria dos círculos</h2>
          </div>
          <div class="panel-premium-chips">
            <span class="panel-premium-chip"><i class="fas fa-layer-group"></i><%= (circulos || []).length %> círculos</span>
            <span class="panel-premium-chip"><i class="fas fa-link"></i><%= totalVinculosCirculo %> vínculos</span>
          </div>
        </div>
        <div class="row g-3 mb-3 panel-intake-grid">
          <div class="col-xl-3 col-lg-4 panel-create-col">
            <div class="surface create-surface-compact">
              <div class="surface-head"><span><i class="fas fa-plus-circle me-2"></i>Novo Circulo</span></div>
              <div class="surface-body">
                <label class="field-label" for="circulo_nome">Nome do Circulo</label>
                <div class="create-form-wrap">
                  <div class="input-group">
                    <input id="circulo_nome" class="form-control" placeholder="Ex: Circulo Sao Paulo">
                    <button class="btn btn-primary" onclick="criarCirculo()">Criar</button>
                  </div>
                </div>
              </div>
            </div>
          </div>
          <div class="col-xl-9 col-lg-8 panel-link-col">
            <div class="surface link-surface-wide">
              <div class="surface-head"><span><i class="fas fa-user-plus me-2"></i>Vincular Encontrista ao Circulo</span></div>
              <div class="surface-body">
                <div class="link-bar-shell">
                  <div class="row g-3 align-items-start link-form-grid link-form-grid-modern">
                    <div class="col-md-3 col-select-main">
                      <label class="field-label" for="circulo_id">Circulo</label>
                      <select id="circulo_id" class="form-select">
                        <option value="">Selecione circulo</option>
                        <% circulos.forEach(function(c) { %>
                          <option value="<%= c._id %>"><%= c.nome %></option>
                        <% }) %>
                      </select>
                    </div>
                    <div class="col-md-5 col-select-people">
                      <label class="field-label" for="encontrista_id">Encontristas</label>
                      <div class="multi-select-panel">
                        <div class="multi-filter-row">
                          <div class="search-input-shell">
                            <i class="fas fa-search search-icon" aria-hidden="true"></i>
                            <input
                              id="filtro_encontrista"
                              class="form-control multi-filter-input"
                              type="text"
                              placeholder="Buscar encontrista..."
                              oninput="filtrarSelectMulti('encontrista_id', this.value)">
                          </div>
                          <button
                            type="button"
                            class="btn btn-clear-mini"
                            onclick="limparFiltroSelectMulti('filtro_encontrista', 'encontrista_id')">
                            Limpar
                          </button>
                        </div>
                        <button type="button" class="multi-check-toggle" onclick="toggleMultiChecklist('encontrista_id')">
                          <span id="resumo_encontrista_id">Clique para selecionar nomes</span>
                          <i class="fas fa-chevron-down" aria-hidden="true"></i>
                        </button>
                        <div id="lista_encontrista_id" class="multi-checklist d-none"></div>
                        <select id="encontrista_id" class="form-select d-none" multiple size="1">
                          <% encontristas.forEach(function(p) { %>
                            <option value="<%= p._id %>"><%= p.nomeCompleto %></option>
                          <% }) %>
                        </select>
                        <small class="multi-select-help"><span class="multi-select-count" id="contador_encontrista_id">0 selecionados</span> · Marque um por um antes de vincular.</small>
                      </div>
                    </div>
                    <div class="col-md-2">
                      <label class="field-label" for="papel_circulo">Tipo de Vinculo</label>
                      <select id="papel_circulo" class="form-select" onchange="alternarCampoMoita()">
                        <option value="membro">Membro</option>
                        <option value="moita">Moita</option>
                      </select>
                    </div>
                    <div class="col-md-2 d-flex align-items-end col-link-action">
                      <button class="btn btn-primary link-action-btn w-100" onclick="vincularEncontristaCirculo()">Vincular</button>
                    </div>
                    <div class="col-12" id="wrap_papel_moita" style="display:none;">
                      <input id="descricao_papel_moita" class="form-control" placeholder="Qual papel esta fazendo na moita? Ex: Animacao, Acolhida, Intercessao">
                    </div>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>

        <div class="surface panel-list-surface">
          <div class="surface-head">
            <span><i class="fas fa-circle-notch me-2"></i>Circulos Criados</span>
            <span class="muted" id="count-circulos"></span>
          </div>
          <div class="surface-body" id="lista-circulos"></div>
        </div>
      </section>

      <section id="panel-equipes" class="panel" data-required-permission="equipes.gerenciar">
        <div class="panel-premium-head panel-premium-head-equipes">
          <div>
            <p class="panel-premium-kicker">Operação do encontro</p>
            <h2><i class="fas fa-people-group me-2"></i>Arquitetura das equipes</h2>
            <p class="panel-premium-copy">Monte equipes, distribua jovens e tios e acompanhe coordenação e execução com uma estética mais executiva.</p>
          </div>
          <div class="panel-premium-chips">
            <span class="panel-premium-chip"><i class="fas fa-people-group"></i><%= (equipes || []).length %> equipes</span>
            <span class="panel-premium-chip"><i class="fas fa-link"></i><%= totalVinculosEquipe %> vínculos</span>
          </div>
        </div>
        <div class="row g-3 mb-3 panel-intake-grid">
          <div class="col-xl-3 col-lg-4 panel-create-col">
            <div class="surface create-surface-compact">
              <div class="surface-head"><span><i class="fas fa-plus-circle me-2"></i>Nova Equipe</span></div>
              <div class="surface-body">
                <label class="field-label" for="equipe_nome">Nome da Equipe</label>
                <div class="create-form-wrap">
                  <div class="input-group">
                    <input id="equipe_nome" class="form-control" placeholder="Ex: Liturgia">
                    <button class="btn btn-primary" onclick="criarEquipe()">Criar</button>
                  </div>
                </div>
              </div>
            </div>
          </div>
          <div class="col-xl-9 col-lg-8 panel-link-col">
            <div class="surface link-surface-wide">
              <div class="surface-head"><span><i class="fas fa-user-plus me-2"></i>Vincular Encontreiro/Tios na Equipe</span></div>
              <div class="surface-body">
                <div class="link-bar-shell">
                  <div class="row g-3 align-items-start link-form-grid link-form-grid-modern">
                    <div class="col-md-3 col-select-main">
                      <label class="field-label" for="equipe_id">Equipe</label>
                      <select id="equipe_id" class="form-select">
                        <option value="">Selecione equipe</option>
                        <% equipes.forEach(function(eq) { %>
                          <option value="<%= eq._id %>"><%= eq.nome %></option>
                        <% }) %>
                      </select>
                    </div>
                    <div class="col-md-5 col-select-people">
                      <label class="field-label" for="encontreiro_id">Encontreiros e Tios</label>
                      <div class="multi-select-panel">
                        <div class="multi-filter-row">
                          <div class="search-input-shell">
                            <i class="fas fa-search search-icon" aria-hidden="true"></i>
                            <input
                              id="filtro_encontreiro"
                              class="form-control multi-filter-input"
                              type="text"
                              placeholder="Buscar encontreiro/tios..."
                              oninput="filtrarSelectMulti('encontreiro_id', this.value)">
                          </div>
                          <button
                            type="button"
                            class="btn btn-clear-mini"
                            onclick="limparFiltroSelectMulti('filtro_encontreiro', 'encontreiro_id')">
                            Limpar
                          </button>
                        </div>
                        <button type="button" class="multi-check-toggle" onclick="toggleMultiChecklist('encontreiro_id')">
                          <span id="resumo_encontreiro_id">Clique para selecionar nomes</span>
                          <i class="fas fa-chevron-down" aria-hidden="true"></i>
                        </button>
                        <div id="lista_encontreiro_id" class="multi-checklist d-none"></div>
                        <select id="encontreiro_id" class="form-select d-none" multiple size="1">
                          <% encontreiros.forEach(function(p) { %>
                            <option value="<%= p._id %>"><%= p.nomeCompleto %> (<%= p.tipo === 'tios' ? 'Tios' : 'Jovens' %>)</option>
                          <% }) %>
                        </select>
                        <small class="multi-select-help"><span class="multi-select-count" id="contador_encontreiro_id">0 selecionados</span> · Marque um por um antes de vincular.</small>
                      </div>
                    </div>
                    <div class="col-md-2">
                      <label class="field-label" for="papel_equipe">Tipo de Vinculo</label>
                      <select id="papel_equipe" class="form-select">
                        <option value="membro">Membro</option>
                        <option value="coordenador">Coordenador</option>
                      </select>
                    </div>
                    <div class="col-md-2 d-flex align-items-end col-link-action">
                      <button class="btn btn-primary link-action-btn w-100" onclick="vincularEncontreiroEquipeEJC()">Vincular</button>
                    </div>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>

        <div class="surface panel-list-surface">
          <div class="surface-head">
            <span><i class="fas fa-people-group me-2"></i>Equipes Criadas</span>
            <span class="muted" id="count-equipes"></span>
          </div>
          <div class="surface-body" id="lista-equipes"></div>
        </div>
      </section>

    </main>
  </div>

  <script id="dados-circulos" type="application/json"><%- JSON.stringify(circulos || []) %></script>
  <script id="dados-equipes" type="application/json"><%- JSON.stringify(equipes || []) %></script>
  <script id="dados-encontristas" type="application/json"><%- JSON.stringify(encontristas || []) %></script>
  <script id="dados-encontreiros" type="application/json"><%- JSON.stringify(encontreiros || []) %></script>
  <script id="dados-vinculos" type="application/json"><%- JSON.stringify(vinculos || []) %></script>

  <script src="/vendor/bootstrap/js/bootstrap.bundle.min.js"></script>
  <script src="/js/page-transitions.js"></script>
  <script>
    const ejcId = '<%= ejc._id %>';
    const circulos = JSON.parse(document.getElementById('dados-circulos').textContent || '[]');
    const equipes = JSON.parse(document.getElementById('dados-equipes').textContent || '[]');
    const encontristas = JSON.parse(document.getElementById('dados-encontristas').textContent || '[]');
    const encontreiros = JSON.parse(document.getElementById('dados-encontreiros').textContent || '[]');
    const vinculos = JSON.parse(document.getElementById('dados-vinculos').textContent || '[]');

    const mapEncontristas = Object.fromEntries(encontristas.map((p) => [String(p._id), p]));
    const mapEncontreiros = Object.fromEntries(encontreiros.map((p) => [String(p._id), p]));
    const currentAdminPermissions = <%- JSON.stringify(adminPermissoesLista || []) %>;

    function hasPermission(permissionKey) {
      if (!permissionKey) return true;
      return currentAdminPermissions.includes(permissionKey);
    }

    function ensurePermission(permissionKey, message) {
      if (hasPermission(permissionKey)) return true;
      appAlert(message || 'Voce nao possui permissao para esta acao.', 'warning', 'Acesso negado');
      return false;
    }

    function getPrimeiroPainelDisponivelId() {
      const painels = ['panel-circulos', 'panel-equipes'];
      return painels.find((id) => {
        const panel = document.getElementById(id);
        return panel && panel.style.display !== 'none';
      }) || 'panel-circulos';
    }

    function aplicarPermissoesNaPagina() {
      document.querySelectorAll('[data-required-permission]').forEach((node) => {
        const permissionKey = node.getAttribute('data-required-permission');
        if (hasPermission(permissionKey)) return;
        node.style.display = 'none';
      });
    }

    function escapeHtml(value) {
      return String(value || '')
        .replace(/&/g, '&amp;')
        .replace(/</g, '&lt;')
        .replace(/>/g, '&gt;')
        .replace(/"/g, '&quot;')
        .replace(/'/g, '&#39;');
    }

    function personByVinculo(vinculo) {
      return vinculo.pessoaTipo === 'encontrista'
        ? mapEncontristas[String(vinculo.pessoaId)]
        : mapEncontreiros[String(vinculo.pessoaId)];
    }

    function personTipoLabel(vinculo, pessoa) {
      if (vinculo.pessoaTipo === 'encontrista') return 'Encontrista';
      if (pessoa && pessoa.tipo === 'tios') return 'Tios';
      return 'Encontreiro';
    }

    function personRowCirculo(vinculo, pessoa) {
      const foto = pessoa && pessoa.foto
        ? `<img src="/img/uploads/${encodeURIComponent(pessoa.foto)}?w=96&h=96&fit=cover&format=webp" class="person-photo" alt="Foto">`
        : '<span class="text-muted"><i class="fas fa-user-circle fa-2x"></i></span>';

      const isMoita = vinculo.papel === 'moita';
      const tipo = isMoita ? 'Moita' : personTipoLabel(vinculo, pessoa);
      const tipoClass = isMoita ? 'moita' : vinculo.pessoaTipo;
      const papel = isMoita ? (vinculo.descricaoPapel || '-') : 'Membro';
      const podeRemover = hasPermission('encontros.gerenciar');
      const acaoRemover = podeRemover
        ? `<button class="btn btn-sm btn-danger-soft" onclick="removerVinculo('${escapeHtml(String(vinculo._id || ''))}')"><i class="fas fa-trash me-1"></i>Remover</button>`
        : '<span class="text-muted small">Sem permissao</span>';
      return `
        <tr>
          <td>${foto}</td>
          <td>${escapeHtml(pessoa?.nomeCompleto || '-')}</td>
          <td><span class="pill ${tipoClass}">${escapeHtml(tipo)}</span></td>
          <td>${escapeHtml(papel)}</td>
          <td>${escapeHtml(pessoa?.telefone || '-')}</td>
          <td>${escapeHtml(pessoa?.email || '-')}</td>
          <td>${escapeHtml(pessoa?.ejc || '-')}</td>
          <td>${acaoRemover}</td>
        </tr>
      `;
    }

    function personRowEquipe(vinculo, pessoa) {
      const foto = pessoa && pessoa.foto
        ? `<img src="/img/uploads/${encodeURIComponent(pessoa.foto)}?w=96&h=96&fit=cover&format=webp" class="person-photo" alt="Foto">`
        : '<span class="text-muted"><i class="fas fa-user-circle fa-2x"></i></span>';

      const tipo = personTipoLabel(vinculo, pessoa);
      const papel = (vinculo.papel === 'coordenador' || vinculo.papel === 'coordenou')
        ? 'Coordenador'
        : 'Membro';
      const podeRemover = hasPermission('equipes.gerenciar');
      const acaoRemover = podeRemover
        ? `<button class="btn btn-sm btn-danger-soft" onclick="removerVinculo('${escapeHtml(String(vinculo._id || ''))}')"><i class="fas fa-trash me-1"></i>Remover</button>`
        : '<span class="text-muted small">Sem permissao</span>';
      return `
        <tr>
          <td>${foto}</td>
          <td>${escapeHtml(pessoa?.nomeCompleto || '-')}</td>
          <td><span class="pill ${vinculo.pessoaTipo}">${escapeHtml(tipo)}</span></td>
          <td>${escapeHtml(papel)}</td>
          <td>${escapeHtml(pessoa?.telefone || '-')}</td>
          <td>${escapeHtml(pessoa?.email || '-')}</td>
          <td>${escapeHtml(pessoa?.ejc || '-')}</td>
          <td>${acaoRemover}</td>
        </tr>
      `;
    }

    function getCirculoTheme(nome) {
      const normalizado = String(nome || '')
        .normalize('NFD')
        .replace(/[\u0300-\u036f]/g, '')
        .toLowerCase()
        .replace(/[^a-z\s-]/g, ' ')
        .replace(/\s+/g, ' ')
        .trim();

      const palette = [
        { theme: 'theme-amarelo', termos: ['amarelo', 'dourado', 'ouro', 'ambar', 'gold'] },
        { theme: 'theme-azul', termos: ['azul', 'anil', 'ciano', 'cyan', 'turquesa', 'celeste'] },
        { theme: 'theme-laranja', termos: ['laranja', 'laranjado', 'ocre', 'coral', 'marrom', 'terracota', 'bronze'] },
        { theme: 'theme-verde', termos: ['verde', 'esmeralda', 'lima', 'limao', 'olive', 'oliva'] },
        { theme: 'theme-vermelho', termos: ['vermelho', 'rubro', 'vinho', 'bordo', 'scarlet', 'red'] },
        { theme: 'theme-rosa', termos: ['rosa', 'pink', 'rose', 'cor de rosa', 'rosado'] },
        { theme: 'theme-roxo', termos: ['roxo', 'lilas', 'violeta', 'purple', 'magenta'] },
      ];

      for (const item of palette) {
        if (item.termos.some((termo) => normalizado.includes(termo))) {
          return item.theme;
        }
      }

      if (['preto', 'grafite', 'black'].some((termo) => normalizado.includes(termo))) {
        return 'theme-preto';
      }

      if (['branco', 'prata', 'silver', 'white'].some((termo) => normalizado.includes(termo))) {
        return 'theme-branco';
      }

      if (['cinza', 'gray', 'grey'].some((termo) => normalizado.includes(termo))) {
        return 'theme-default';
      }

      return 'theme-default';
    }

