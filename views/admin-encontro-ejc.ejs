    function renderAll() {
      renderListaCirculos();
      renderListaEquipes();
    }

    function ensureAppPopup() {
      let modalElement = document.getElementById('app-popup-modal');
      if (modalElement) {
        return {
          element: modalElement,
          instance: bootstrap.Modal.getOrCreateInstance(modalElement),
        };
      }

      modalElement = document.createElement('div');
      modalElement.className = 'modal fade';
      modalElement.id = 'app-popup-modal';
      modalElement.tabIndex = -1;
      modalElement.setAttribute('aria-hidden', 'true');
      modalElement.innerHTML = `
        <div class="modal-dialog modal-dialog-centered">
          <div class="modal-content border-0 shadow-lg">
            <div class="modal-header">
              <h5 class="modal-title" id="app-popup-title">Aviso</h5>
              <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Fechar"></button>
            </div>
            <div class="modal-body">
              <p id="app-popup-message" class="mb-0" style="white-space: pre-line;"></p>
            </div>
            <div class="modal-footer">
              <button type="button" class="btn btn-outline-secondary" id="app-popup-cancel">Cancelar</button>
              <button type="button" class="btn btn-primary" id="app-popup-confirm">OK</button>
            </div>
          </div>
        </div>
      `;
      document.body.appendChild(modalElement);

      return {
        element: modalElement,
        instance: bootstrap.Modal.getOrCreateInstance(modalElement),
      };
    }

    function showAppPopup({ title, message, confirmText = 'OK', cancelText = null, tone = 'primary' }) {
      const { element, instance } = ensureAppPopup();
      const titleEl = element.querySelector('#app-popup-title');
      const messageEl = element.querySelector('#app-popup-message');
      const confirmBtn = element.querySelector('#app-popup-confirm');
      const cancelBtn = element.querySelector('#app-popup-cancel');

      titleEl.textContent = title || 'Aviso';
      messageEl.textContent = message || '';
      confirmBtn.textContent = confirmText;
      confirmBtn.className = `btn btn-${tone}`;

      if (cancelText) {
        cancelBtn.style.display = '';
        cancelBtn.textContent = cancelText;
      } else {
        cancelBtn.style.display = 'none';
      }

      return new Promise((resolve) => {
        let resolved = false;

        const cleanup = () => {
          confirmBtn.removeEventListener('click', onConfirm);
          cancelBtn.removeEventListener('click', onCancel);
          element.removeEventListener('hidden.bs.modal', onHidden);
        };

        const settle = (value) => {
          if (resolved) return;
          resolved = true;
          cleanup();
          resolve(value);
        };

        const onConfirm = () => {
          settle(true);
          instance.hide();
        };

        const onCancel = () => {
          settle(false);
          instance.hide();
        };

        const onHidden = () => settle(false);

        confirmBtn.addEventListener('click', onConfirm);
        cancelBtn.addEventListener('click', onCancel);
        element.addEventListener('hidden.bs.modal', onHidden, { once: true });

        instance.show();
      });
    }

    async function appAlert(message, tone = 'primary', title = 'Aviso') {
      await showAppPopup({ title, message, confirmText: 'Entendi', tone });
    }

    async function appConfirm(message, title = 'Confirmacao') {
      return await showAppPopup({
        title,
        message,
        confirmText: 'Confirmar',
        cancelText: 'Cancelar',
        tone: 'warning',
      });
    }

    function abrirExportacao(entidadeTipo, entidadeId, formato, botao) {
      if (!entidadeTipo || !entidadeId || !formato) return;

      let restoreTimer = null;
      if (botao) {
        botao.disabled = true;
        botao.dataset.originalHtml = botao.innerHTML;
        botao.innerHTML = '<span class="spinner-border spinner-border-sm me-1" role="status" aria-hidden="true"></span>Gerando...';
      }

      const url = `/admin/encontros/${encodeURIComponent(ejcId)}/export/${encodeURIComponent(entidadeTipo)}/${encodeURIComponent(entidadeId)}/${encodeURIComponent(formato)}`;
      window.open(url, '_blank');

      // The browser handles the download asynchronously, so we restore button state after a short delay.
      restoreTimer = setTimeout(() => {
        if (botao) {
          botao.disabled = false;
          botao.innerHTML = botao.dataset.originalHtml || botao.innerHTML;
          delete botao.dataset.originalHtml;
        }
      }, 1600);

      return restoreTimer;
    }

    function gerarQuadrante(botao) {
      let restoreTimer = null;
      if (botao) {
        botao.disabled = true;
        botao.dataset.originalHtml = botao.innerHTML;
        botao.innerHTML = '<span class="spinner-border spinner-border-sm me-1" role="status" aria-hidden="true"></span>Gerando...';
      }

      const url = `/admin/encontros/${encodeURIComponent(ejcId)}/export/quadrante/pdf`;
      window.open(url, '_blank');

      restoreTimer = setTimeout(() => {
        if (botao) {
          botao.disabled = false;
          botao.innerHTML = botao.dataset.originalHtml || botao.innerHTML;
          delete botao.dataset.originalHtml;
        }
      }, 1800);

      return restoreTimer;
    }

    function ativarPainel(panelId, btn) {
      const targetPanel = document.getElementById(panelId);
      if (!targetPanel) return;

      document.querySelectorAll('.panel').forEach((panel) => panel.classList.remove('active'));
      targetPanel.classList.add('active');

      document.querySelectorAll('.menu-btn').forEach((b) => b.classList.remove('active'));
      const menuButton = btn || document.querySelector(`.menu-btn[data-panel="${panelId}"]`);
      if (menuButton) menuButton.classList.add('active');

      salvarPainelAtivo();
    }

    function getPainelAtivoId() {
      const ativo = document.querySelector('.panel.active');
      return ativo && ativo.id ? ativo.id : 'panel-circulos';
    }

    function getPainelStorageKey() {
      return `admin_encontro_ejc_painel_${String(ejcId || 'default')}`;
    }

    function salvarPainelAtivo() {
      const painelId = getPainelAtivoId();
      localStorage.setItem(getPainelStorageKey(), painelId);

      const url = new URL(window.location.href);
      url.searchParams.set('painel', painelId);
      window.history.replaceState({}, '', url.toString());
    }

    function restaurarPainelAtivo() {
      const url = new URL(window.location.href);
      const painelNaUrl = String(url.searchParams.get('painel') || '').trim();
      const painelNoStorage = String(localStorage.getItem(getPainelStorageKey()) || '').trim();
      const painelDesejado = painelNaUrl || painelNoStorage || 'panel-circulos';

      if (document.getElementById(painelDesejado)) {
        ativarPainel(painelDesejado);
        return;
      }

      ativarPainel('panel-circulos');
    }

    function recarregarMantendoPainelAtual() {
      salvarPainelAtivo();
      window.location.href = window.location.href;
    }

    function filtrarSelectMulti(selectId, termo) {
      const select = document.getElementById(selectId);
      if (!select) return;

      const filtro = String(termo || '').trim().toLowerCase();
      const options = Array.from(select.options || []);

      // Expandir o select quando digitar
      if (filtro) {
        expandirSelectMulti(select);
      }

      options.forEach((option) => {
        if (!option.value) {
          option.hidden = false;
          return;
        }

        const texto = String(option.textContent || '').toLowerCase();
        option.hidden = filtro ? !texto.includes(filtro) : false;
      });
    }

    function limparFiltroSelectMulti(inputId, selectId) {
      const input = document.getElementById(inputId);
      if (input) {
        input.value = '';
      }

      filtrarSelectMulti(selectId, '');

      if (input) {
        input.focus();
      }
    }

    function expandirSelectMulti(select) {
      if (!select) return;
      const expandedSize = Math.max(5, Number(select.dataset.expandedSize || 7));
      select.classList.remove('multi-select-collapsed');
      select.size = expandedSize;
    }

    function recolherSelectMulti(select) {
      if (!select) return;
      setTimeout(() => {
        if (document.activeElement === select) return;
        select.classList.add('multi-select-collapsed');
        select.size = 1;
      }, 120);
    }

    async function removerVinculo(vinculoId) {
      if (!vinculoId) return;
      if (!await appConfirm('Deseja remover este vinculo?', 'Confirmar remocao')) return;

      const res = await fetch(`/admin/remover-vinculo/${encodeURIComponent(vinculoId)}`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' }
      });
      const data = await res.json();
      if (!data.success) return await appAlert(data.error || 'Erro ao remover vinculo.', 'danger', 'Erro');
      recarregarMantendoPainelAtual();
    }

    async function criarCirculo() {
      const nome = document.getElementById('circulo_nome').value.trim();
      if (!nome) return await appAlert('Informe o nome do circulo.', 'warning', 'Campo obrigatorio');
      const res = await fetch('/admin/criar-circulo', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ nome, ejcId })
      });
      const data = await res.json();
      if (!data.success) return await appAlert(data.error || 'Erro ao criar circulo.', 'danger', 'Erro');
      recarregarMantendoPainelAtual();
    }

    async function criarEquipe() {
      const nome = document.getElementById('equipe_nome').value.trim();
      if (!nome) return await appAlert('Informe o nome da equipe.', 'warning', 'Campo obrigatorio');
      const res = await fetch('/admin/cadastrar-equipe', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ nome, ejcId })
      });
      const data = await res.json();
      if (!data.success) return await appAlert(data.error || 'Erro ao criar equipe.', 'danger', 'Erro');
      recarregarMantendoPainelAtual();
    }

    async function vincularEncontristaCirculo() {
      const entidadeId = document.getElementById('circulo_id').value;
      const pessoaIds = Array.from(document.getElementById('encontrista_id').selectedOptions || [])
        .map((option) => String(option.value || '').trim())
        .filter(Boolean);
      const papel = document.getElementById('papel_circulo').value || 'membro';
      const descricaoPapel = (document.getElementById('descricao_papel_moita').value || '').trim();

      if (!entidadeId || pessoaIds.length === 0) return await appAlert('Selecione circulo e ao menos um encontrista.', 'warning', 'Dados incompletos');
      if (papel === 'moita' && !descricaoPapel) {
        return await appAlert('Informe qual papel a pessoa esta fazendo na moita.', 'warning', 'Campo obrigatorio');
      }

      const res = await fetch('/admin/vincular-encontro', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          ejcId,
          entidadeTipo: 'circulo',
          entidadeId,
          pessoaTipo: 'encontrista',
          pessoaIds,
          papel,
          descricaoPapel,
        })
      });
      const data = await res.json();
      if (!data.success) return await appAlert(data.error || 'Erro ao vincular encontrista.', 'danger', 'Erro');
      recarregarMantendoPainelAtual();
    }

    async function vincularEncontreiroEquipeEJC() {
      const entidadeId = document.getElementById('equipe_id').value;
      const pessoaIds = Array.from(document.getElementById('encontreiro_id').selectedOptions || [])
        .map((option) => String(option.value || '').trim())
        .filter(Boolean);
      const papel = document.getElementById('papel_equipe').value;
      if (!entidadeId || pessoaIds.length === 0 || !papel) return await appAlert('Selecione equipe, ao menos uma pessoa e vinculo.', 'warning', 'Dados incompletos');
      const res = await fetch('/admin/vincular-encontro', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ ejcId, entidadeTipo: 'equipe', entidadeId, pessoaTipo: 'encontreiro', pessoaIds, papel })
      });
      const data = await res.json();
      if (!data.success) return await appAlert(data.error || 'Erro ao vincular na equipe.', 'danger', 'Erro');
      recarregarMantendoPainelAtual();
    }

    function alternarCampoMoita() {
      const papel = document.getElementById('papel_circulo').value;
      const wrap = document.getElementById('wrap_papel_moita');
      if (!wrap) return;

      if (papel === 'moita') {
        wrap.style.display = '';
      } else {
        wrap.style.display = 'none';
        const input = document.getElementById('descricao_papel_moita');
        if (input) input.value = '';
      }
    }

    alternarCampoMoita();
    restaurarPainelAtivo();
    renderAll();
  </script>
