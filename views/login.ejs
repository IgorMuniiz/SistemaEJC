<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8" />
  <meta http-equiv="X-UA-Compatible" content="IE=edge" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content="Bem-vindo ao EJC COP - Escolha seu tipo de inscrição" />
  <title>EJC COP - Escolha sua Inscrição</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Manrope:wght@400;500;600;700;800&family=Sora:wght@500;600;700&display=swap" rel="stylesheet">
  <style>
    :root {
      --bg-primary: #090b14;
      --bg-elevated: rgba(255, 255, 255, 0.045);
      --bg-elevated-strong: rgba(255, 255, 255, 0.075);
      --line: rgba(255, 255, 255, 0.11);
      --line-strong: rgba(255, 255, 255, 0.2);
      --ink-main: #f3f6ff;
      --ink-muted: rgba(225, 233, 255, 0.75);
      --brand-blue: #4f8fff;
      --brand-cyan: #34d7ff;
      --brand-green: #14b985;
      --brand-violet: #7b61ff;
      --shadow-soft: 0 20px 46px rgba(4, 8, 20, 0.45);
      --shadow-glow: 0 0 42px rgba(79, 143, 255, 0.2);
    }

    * { box-sizing: border-box; }

    html, body {
      width: 100%;
      min-height: 100%;
    }

    body {
      margin: 0;
      font-family: 'Manrope', 'Segoe UI', sans-serif;
      color: var(--ink-main);
      min-height: 100vh;
      position: relative;
      overflow-x: hidden;
      background:
        radial-gradient(circle at 12% 10%, rgba(79, 143, 255, 0.22) 0%, transparent 34%),
        radial-gradient(circle at 88% 16%, rgba(123, 97, 255, 0.2) 0%, transparent 38%),
        radial-gradient(circle at 48% 90%, rgba(20, 185, 133, 0.18) 0%, transparent 35%),
        var(--bg-primary);
      padding: clamp(1rem, 2.6vw, 2.2rem);
      display: grid;
      place-items: center;
    }

    .ambient-layer {
      position: fixed;
      inset: 0;
      pointer-events: none;
      z-index: 0;
      background:
        linear-gradient(rgba(255, 255, 255, 0.025) 1px, transparent 1px),
        linear-gradient(90deg, rgba(255, 255, 255, 0.025) 1px, transparent 1px);
      background-size: 58px 58px;
      mask-image: radial-gradient(circle at 50% 50%, #000 45%, transparent 100%);
      animation: gridDrift 24s linear infinite;
    }

    @keyframes gridDrift {
      from { transform: translateY(0); }
      to { transform: translateY(-58px); }
    }

    .orb {
      position: fixed;
      border-radius: 50%;
      filter: blur(44px);
      pointer-events: none;
      z-index: 0;
      opacity: 0.46;
    }

    .orb-a {
      width: 280px;
      height: 280px;
      left: -70px;
      top: 12%;
      background: rgba(79, 143, 255, 0.4);
      animation: orbA 15s ease-in-out infinite;
    }

    .orb-b {
      width: 320px;
      height: 320px;
      right: -100px;
      top: 24%;
      background: rgba(123, 97, 255, 0.38);
      animation: orbB 16s ease-in-out infinite;
    }

    .orb-c {
      width: 260px;
      height: 260px;
      left: 38%;
      bottom: -90px;
      background: rgba(20, 185, 133, 0.28);
      animation: orbC 18s ease-in-out infinite;
    }

    @keyframes orbA {
      0%, 100% { transform: translate(0, 0) scale(1); }
      50% { transform: translate(24px, -14px) scale(1.08); }
    }

    @keyframes orbB {
      0%, 100% { transform: translate(0, 0) scale(1); }
      50% { transform: translate(-20px, 16px) scale(1.04); }
    }

    @keyframes orbC {
      0%, 100% { transform: translate(0, 0) scale(1); }
      50% { transform: translate(16px, -20px) scale(1.1); }
    }

    .home-shell {
      width: min(1100px, 100%);
      min-height: min(780px, calc(100vh - 3rem));
      border: 1px solid var(--line);
      border-radius: 28px;
      background: linear-gradient(180deg, rgba(255, 255, 255, 0.06), rgba(255, 255, 255, 0.03));
      backdrop-filter: blur(20px);
      box-shadow: var(--shadow-soft), var(--shadow-glow);
      overflow: hidden;
      position: relative;
      z-index: 2;
      display: grid;
      grid-template-columns: 1.1fr 1fr;
    }

    .home-shell::before {
      content: '';
      position: absolute;
      inset: 0;
      background: linear-gradient(130deg, rgba(79, 143, 255, 0.08), transparent 44%, rgba(20, 185, 133, 0.06));
      pointer-events: none;
    }

    .hero {
      padding: clamp(1.7rem, 4vw, 3rem);
      border-right: 1px solid var(--line);
      background:
        linear-gradient(175deg, rgba(255,255,255,0.06), rgba(255,255,255,0.02)),
        repeating-linear-gradient(
          -45deg,
          rgba(79, 143, 255, 0.07),
          rgba(79, 143, 255, 0.07) 10px,
          rgba(255, 255, 255, 0.025) 10px,
          rgba(255, 255, 255, 0.025) 20px
        );
      display: flex;
      flex-direction: column;
      justify-content: center;
      animation: revealIn 0.7s ease;
      position: relative;
      z-index: 1;
    }

    .brand-row {
      display: flex;
      align-items: center;
      gap: 12px;
      margin-bottom: 20px;
    }

    .brand-dot {
      width: 42px;
      height: 42px;
      border-radius: 12px;
      display: grid;
      place-items: center;
      color: #fff;
      background: linear-gradient(140deg, var(--brand-blue), var(--brand-violet));
      box-shadow: 0 12px 24px rgba(79, 143, 255, 0.4);
    }

    .icon {
      width: 1em;
      height: 1em;
      display: inline-block;
      vertical-align: -0.125em;
      fill: currentColor;
      flex: 0 0 auto;
    }

    .brand-dot .icon {
      width: 20px;
      height: 20px;
    }

    .choice-icon .icon {
      width: 22px;
      height: 22px;
    }

    .brand-text {
      font-size: 0.83rem;
      font-weight: 700;
      letter-spacing: 0.08em;
      color: rgba(220, 232, 255, 0.78);
      text-transform: uppercase;
    }

    .hero-title {
      margin: 0 0 14px;
      line-height: 1.06;
      font-size: clamp(2.2rem, 4.8vw, 4rem);
      font-family: 'Sora', 'Manrope', sans-serif;
      font-weight: 700;
      background: linear-gradient(110deg, #e5eeff 0%, #7ab2ff 46%, #6ef0c7 100%);
      -webkit-background-clip: text;
      background-clip: text;
      -webkit-text-fill-color: transparent;
      letter-spacing: 0.01em;
      text-shadow: none;
    }

    .hero-subtitle {
      margin: 0;
      max-width: 520px;
      font-size: 1rem;
      line-height: 1.65;
      color: var(--ink-muted);
    }

    .hero-metrics {
      margin-top: 26px;
      display: flex;
      gap: 10px;
      flex-wrap: wrap;
    }

    .metric-chip {
      border: 1px solid var(--line);
      background: var(--bg-elevated);
      border-radius: 999px;
      padding: 8px 12px;
      font-size: 0.82rem;
      color: rgba(232, 239, 255, 0.86);
      display: inline-flex;
      align-items: center;
      gap: 6px;
      backdrop-filter: blur(8px);
    }

    .actions {
      padding: clamp(1.4rem, 3.2vw, 2.3rem);
      display: flex;
      flex-direction: column;
      justify-content: center;
      gap: 14px;
      animation: revealIn 0.8s ease;
      background:
        radial-gradient(circle at 12% 10%, rgba(79, 143, 255, 0.18), transparent 44%),
        linear-gradient(180deg, rgba(255, 255, 255, 0.05), rgba(255, 255, 255, 0.03));
      position: relative;
      z-index: 1;
    }

    .logo-wrap {
      text-align: center;
      margin-bottom: 8px;
      border: 1px solid var(--line);
      border-radius: 16px;
      background: linear-gradient(180deg, rgba(255, 255, 255, 0.08), rgba(255, 255, 255, 0.04));
      padding: 14px 12px;
      box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.12);
    }

    .welcome-brand {
      width: min(100%, 320px);
      max-height: 100px;
      height: auto;
      object-fit: contain;
      display: block;
      margin: 0 auto;
      filter: drop-shadow(0 8px 16px rgba(0, 0, 0, 0.38));
    }

    .choice-card {
      border-radius: 16px;
      border: 1px solid var(--line);
      background: var(--bg-elevated);
      color: var(--ink-main);
      text-decoration: none;
      display: flex;
      align-items: center;
      gap: 14px;
      padding: 16px 15px;
      transition: transform 0.22s ease, box-shadow 0.22s ease, border-color 0.22s ease, background 0.22s ease;
      position: relative;
      overflow: hidden;
    }

    .choice-card::after {
      content: '';
      position: absolute;
      inset: 0;
      background: radial-gradient(circle at var(--mx, 80%) var(--my, 0%), rgba(255, 255, 255, 0.19), transparent 46%);
      opacity: 0;
      transition: opacity 0.2s ease;
      pointer-events: none;
    }

    .choice-card:hover {
      transform: translateY(-4px);
      box-shadow: 0 14px 28px rgba(0, 0, 0, 0.3);
      border-color: var(--line-strong);
      background: var(--bg-elevated-strong);
      color: #ffffff;
    }

    .choice-card:hover::after {
      opacity: 1;
    }

    .choice-icon {
      width: 48px;
      height: 48px;
      border-radius: 12px;
      display: grid;
      place-items: center;
      color: #fff;
      font-size: 1.25rem;
      flex: 0 0 auto;
    }

    .choice-card.encontrista .choice-icon {
      background: linear-gradient(140deg, var(--brand-blue), var(--brand-violet));
      box-shadow: 0 10px 17px rgba(79, 143, 255, 0.37);
    }

    .choice-card.encontreiro .choice-icon {
      background: linear-gradient(140deg, var(--brand-green), #0a7861);
      box-shadow: 0 10px 17px rgba(20, 185, 133, 0.37);
    }

    .choice-content {
      flex: 1;
      min-width: 0;
    }

    .choice-title {
      display: block;
      font-size: 1.04rem;
      font-weight: 800;
      color: #f0f5ff;
      margin-bottom: 1px;
    }

    .choice-description {
      display: block;
      font-size: 0.85rem;
      color: rgba(219, 230, 255, 0.7);
      line-height: 1.4;
    }

    .choice-arrow {
      color: rgba(220, 230, 255, 0.78);
      font-size: 1rem;
      flex: 0 0 auto;
    }

    .choice-arrow .icon {
      width: 16px;
      height: 16px;
    }

    .admin-link {
      margin-top: 4px;
      text-align: center;
    }

    .admin-link a {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      text-decoration: none;
      color: rgba(235, 241, 255, 0.86);
      border: 1px dashed rgba(255, 255, 255, 0.27);
      background: rgba(255, 255, 255, 0.045);
      border-radius: 999px;
      padding: 9px 14px;
      font-size: 0.85rem;
      font-weight: 700;
      transition: background 0.2s ease, color 0.2s ease, border-color 0.2s ease;
    }

    .admin-link a:hover {
      background: rgba(79, 143, 255, 0.14);
      color: #ffffff;
      border-color: rgba(79, 143, 255, 0.52);
    }

    @keyframes revealIn {
      from {
        opacity: 0;
        transform: translateY(8px);
      }
      to {
        opacity: 1;
        transform: translateY(0);
      }
    }

    @media (max-width: 992px) {
      .home-shell {
        grid-template-columns: 1fr;
        min-height: auto;
      }

      .hero {
        border-right: none;
        border-bottom: 1px solid var(--line);
      }

      .hero-metrics {
        gap: 8px;
      }
    }

    @media (max-width: 520px) {
      body { padding: 0.75rem; }

      .home-shell {
        border-radius: 18px;
      }

      .hero-title {
        font-size: 2.25rem;
      }

      .choice-card {
        padding: 13px 12px;
      }

      .choice-title {
        font-size: 0.98rem;
      }

      .orb-a,
      .orb-b,
      .orb-c {
        opacity: 0.3;
      }
    }
  </style>
</head>
<body>
  <div class="ambient-layer" aria-hidden="true"></div>
  <div class="orb orb-a" aria-hidden="true"></div>
  <div class="orb orb-b" aria-hidden="true"></div>
  <div class="orb orb-c" aria-hidden="true"></div>

  <main class="home-shell" role="main">
    <section class="hero">
      <div class="brand-row">
        <div class="brand-dot"><svg class="icon" viewBox="0 0 24 24" aria-hidden="true"><path d="M11 3h2v7h7v2h-7v9h-2v-9H4v-2h7Z"/></svg></div>
        <div class="brand-text">Encontro de Jovens com Cristo</div>
      </div>

      <h1 class="hero-title">Bem-vindo ao EJC COP</h1>
      <p class="hero-subtitle">
        Escolha seu tipo de acesso para entrar na jornada do encontro com uma experiencia fluida, moderna e segura.
      </p>

      <div class="hero-metrics">
        <span class="metric-chip">
          <svg class="icon" viewBox="0 0 24 24" aria-hidden="true"><path d="M12 2 4 5v6c0 5.2 3.4 9.9 8 11 4.6-1.1 8-5.8 8-11V5l-8-3Zm0 2.1 6 2.2V11c0 4.3-2.7 8.2-6 9.3-3.3-1.1-6-5-6-9.3V6.3l6-2.2Z"/></svg>
          Plataforma segura
        </span>
        <span class="metric-chip">
          <svg class="icon" viewBox="0 0 24 24" aria-hidden="true"><path d="M12 2a10 10 0 1 0 0 20 10 10 0 0 0 0-20Zm1 5v5.6l4 2.4-1 1.7L11 13.8V7h2Z"/></svg>
          Acesso imediato
        </span>
        <span class="metric-chip">
          <svg class="icon" viewBox="0 0 24 24" aria-hidden="true"><path d="M7 2h10a2 2 0 0 1 2 2v16a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2Zm0 3v14h10V5H7Z"/></svg>
          Mobile friendly
        </span>
      </div>
    </section>

    <section class="actions">
      <div class="logo-wrap">
        <img src="/images/rodape.png" loading="eager" decoding="async" alt="EJC COP" class="welcome-brand" />
      </div>

      <a href="/inscricao" class="choice-card encontrista">
        <div class="choice-icon"><svg class="icon" viewBox="0 0 24 24" aria-hidden="true"><path d="M12 3 2 8l10 5 8-4v5h2V8Zm-6 8.58V15c0 2.32 3.13 4 6 4s6-1.68 6-4v-3.42l-6 3Z"/></svg></div>
        <div class="choice-content">
          <span class="choice-title">Encontrista</span>
          <span class="choice-description">Realize sua inscrição como encontrista.</span>
        </div>
        <div class="choice-arrow"><svg class="icon" viewBox="0 0 24 24" aria-hidden="true"><path d="M13.17 5.17a1 1 0 0 1 1.41 0l6 6a1 1 0 0 1 0 1.41l-6 6a1 1 0 1 1-1.41-1.41L17.59 13H4a1 1 0 1 1 0-2h13.59l-4.42-4.41a1 1 0 0 1 0-1.42Z"/></svg></div>
      </a>

      <a href="/encontro" class="choice-card encontreiro">
        <div class="choice-icon"><svg class="icon" viewBox="0 0 24 24" aria-hidden="true"><path d="M7.5 11A3.5 3.5 0 1 1 11 7.5 3.5 3.5 0 0 1 7.5 11Zm9-1A2.5 2.5 0 1 0 14 7.5 2.5 2.5 0 0 0 16.5 10ZM2.5 19c0-2.49 2.91-4.5 6.5-4.5s6.5 2.01 6.5 4.5V20h-13Zm12.5 1v-1c0-1.12-.37-2.17-1.01-3.06.5-.11 1.01-.17 1.51-.17 3.04 0 5.5 1.58 5.5 3.53V20Z"/></svg></div>
        <div class="choice-content">
          <span class="choice-title">Encontreiro</span>
          <span class="choice-description">Inscreva-se para servir no encontro.</span>
        </div>
        <div class="choice-arrow"><svg class="icon" viewBox="0 0 24 24" aria-hidden="true"><path d="M13.17 5.17a1 1 0 0 1 1.41 0l6 6a1 1 0 0 1 0 1.41l-6 6a1 1 0 1 1-1.41-1.41L17.59 13H4a1 1 0 1 1 0-2h13.59l-4.42-4.41a1 1 0 0 1 0-1.42Z"/></svg></div>
      </a>

      <div class="admin-link">
        <a href="/admin/login">
          <svg class="icon" viewBox="0 0 24 24" aria-hidden="true"><path d="M7 10V7a5 5 0 0 1 10 0v3h1a2 2 0 0 1 2 2v8a2 2 0 0 1-2 2H6a2 2 0 0 1-2-2v-8a2 2 0 0 1 2-2Zm2 0h6V7a3 3 0 0 0-6 0Zm3 4a2 2 0 0 1 1 3.73V20h-2v-2.27A2 2 0 0 1 12 14Z"/></svg>
          Acessar painel administrativo
        </a>
      </div>
    </section>
  </main>

  <script>
    document.querySelectorAll('.choice-card').forEach((card) => {
      card.addEventListener('pointermove', (event) => {
        const rect = card.getBoundingClientRect();
        const x = ((event.clientX - rect.left) / rect.width) * 100;
        const y = ((event.clientY - rect.top) / rect.height) * 100;
        card.style.setProperty('--mx', `${x}%`);
        card.style.setProperty('--my', `${y}%`);
      });
    });
  </script>
</body>
</html>
