    <span class="rose" style="--left: 91%; --size: 21px; --duration: 10.2s; --delay: -7.1s; --drift: -21px;">&#127801;</span>
    <span class="rose" style="--left: 96%; --size: 19px; --duration: 9.4s; --delay: -1.6s; --drift: 22px;">&#127801;</span>
  </div>

  <main class="home-shell" role="main">
    <section class="hero">
      <div class="brand-row">
        <div class="brand-dot"><svg class="icon" viewBox="0 0 24 24" aria-hidden="true"><path d="M11 3h2v7h7v2h-7v9h-2v-9H4v-2h7Z"/></svg></div>
        <div class="brand-text">Encontro de Jovens com Cristo</div>
      </div>

      <h1 class="hero-title">Bem-vindo ao EJC COP</h1>
    </section>

    <section class="actions">
      <div class="logo-wrap">
        <img src="/images/rodape.png" loading="eager" decoding="async" alt="EJC COP" class="welcome-brand" />
      </div>

      <a href="/inscricao" class="choice-card encontrista">
        <div class="choice-icon"><svg class="icon" viewBox="0 0 24 24" aria-hidden="true"><path d="M12 3 2 8l10 5 8-4v5h2V8Zm-6 8.58V15c0 2.32 3.13 4 6 4s6-1.68 6-4v-3.42l-6 3Z"/></svg></div>
        <div class="choice-content">
          <span class="choice-title">Encontrista</span>
          <span class="choice-description">Realize sua inscrição como encontrista.</span>
        </div>
        <div class="choice-arrow"><svg class="icon" viewBox="0 0 24 24" aria-hidden="true"><path d="M13.17 5.17a1 1 0 0 1 1.41 0l6 6a1 1 0 0 1 0 1.41l-6 6a1 1 0 1 1-1.41-1.41L17.59 13H4a1 1 0 1 1 0-2h13.59l-4.42-4.41a1 1 0 0 1 0-1.42Z"/></svg></div>
      </a>

      <a href="/encontro" class="choice-card encontreiro">
        <div class="choice-icon"><svg class="icon" viewBox="0 0 24 24" aria-hidden="true"><path d="M7.5 11A3.5 3.5 0 1 1 11 7.5 3.5 3.5 0 0 1 7.5 11Zm9-1A2.5 2.5 0 1 0 14 7.5 2.5 2.5 0 0 0 16.5 10ZM2.5 19c0-2.49 2.91-4.5 6.5-4.5s6.5 2.01 6.5 4.5V20h-13Zm12.5 1v-1c0-1.12-.37-2.17-1.01-3.06.5-.11 1.01-.17 1.51-.17 3.04 0 5.5 1.58 5.5 3.53V20Z"/></svg></div>
        <div class="choice-content">
          <span class="choice-title">Encontreiro</span>
          <span class="choice-description">Inscreva-se para servir no encontro.</span>
        </div>
        <div class="choice-arrow"><svg class="icon" viewBox="0 0 24 24" aria-hidden="true"><path d="M13.17 5.17a1 1 0 0 1 1.41 0l6 6a1 1 0 0 1 0 1.41l-6 6a1 1 0 1 1-1.41-1.41L17.59 13H4a1 1 0 1 1 0-2h13.59l-4.42-4.41a1 1 0 0 1 0-1.42Z"/></svg></div>
      </a>

      <div class="admin-link">
        <a href="/admin/login">
          <svg class="icon" viewBox="0 0 24 24" aria-hidden="true"><path d="M7 10V7a5 5 0 0 1 10 0v3h1a2 2 0 0 1 2 2v8a2 2 0 0 1-2 2H6a2 2 0 0 1-2-2v-8a2 2 0 0 1 2-2Zm2 0h6V7a3 3 0 0 0-6 0Zm3 4a2 2 0 0 1 1 3.73V20h-2v-2.27A2 2 0 0 1 12 14Z"/></svg>
          Acessar painel administrativo
        </a>
      </div>
    </section>
  </main>
</body>
</html>
