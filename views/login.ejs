<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8" />
  <meta http-equiv="X-UA-Compatible" content="IE=edge" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content="Bem-vindo ao EJC COP - Escolha seu tipo de inscrição" />
  <title>EJC COP - Escolha sua Inscrição</title>
  <style>
    :root {
      --bg-soft: #f7fbff;
      --ink-main: #122942;
      --ink-muted: #607995;
      --line: rgba(146, 175, 205, 0.35);
      --brand-blue: #1d63c6;
      --brand-green: #168a5a;
      --card-bg: rgba(255, 255, 255, 0.55);
      --card-hover: rgba(255, 255, 255, 0.82);
    }

    * { box-sizing: border-box; }

    html, body {
      width: 100%;
      min-height: 100%;
    }

    body {
      margin: 0;
      font-family: 'Poppins', sans-serif;
      color: var(--ink-main);
      min-height: 100vh;
      position: relative;
      overflow-x: hidden;
      background:
        radial-gradient(circle at 15% 22%, #eef5ff 0%, transparent 40%),
        radial-gradient(circle at 86% 9%, #effaf3 0%, transparent 34%),
        #ffffff;
      padding: clamp(1rem, 2.6vw, 2.2rem);
      display: grid;
      place-items: center;
    }

    .rose-rain {
      position: fixed;
      inset: 0;
      pointer-events: none;
      z-index: 0;
      overflow: hidden;
    }

    .rose {
      position: absolute;
      top: -14vh;
      left: var(--left);
      font-size: var(--size);
      opacity: 0;
      filter: drop-shadow(0 2px 8px rgba(215, 45, 110, 0.42));
      animation: fallRose var(--duration) linear var(--delay) infinite;
    }

    @keyframes fallRose {
      0% {
        transform: translate3d(0, -8vh, 0) rotate(0deg);
        opacity: 0;
      }
      12% { opacity: 1; }
      100% {
        transform: translate3d(var(--drift), 120vh, 0) rotate(320deg);
        opacity: 0;
      }
    }

    .home-shell {
      width: min(1100px, 100%);
      min-height: min(780px, calc(100vh - 3rem));
      border: 1px solid var(--line);
      border-radius: 28px;
      background: var(--card-bg);
      backdrop-filter: blur(16px);
      box-shadow: 0 24px 60px rgba(23, 52, 84, 0.16);
      overflow: hidden;
      position: relative;
      z-index: 2;
      display: grid;
      grid-template-columns: 1.1fr 1fr;
    }

    .hero {
      padding: clamp(1.7rem, 4vw, 3rem);
      border-right: 1px solid rgba(157, 182, 211, 0.33);
      background:
        linear-gradient(175deg, rgba(255,255,255,0.58), rgba(250,253,255,0.45)),
        repeating-linear-gradient(
          -45deg,
          rgba(34, 91, 166, 0.06),
          rgba(34, 91, 166, 0.06) 10px,
          rgba(255, 255, 255, 0.07) 10px,
          rgba(255, 255, 255, 0.07) 20px
        );
      display: flex;
      flex-direction: column;
      justify-content: center;
      animation: revealIn 0.7s ease;
    }

    .brand-row {
      display: flex;
      align-items: center;
      gap: 12px;
      margin-bottom: 20px;
    }

    .brand-dot {
      width: 42px;
      height: 42px;
      border-radius: 12px;
      display: grid;
      place-items: center;
      color: #fff;
      background: linear-gradient(140deg, #1f68ca, #173f7b);
      box-shadow: 0 10px 18px rgba(28, 82, 159, 0.33);
    }

    .icon {
      width: 1em;
      height: 1em;
      display: inline-block;
      vertical-align: -0.125em;
      fill: currentColor;
      flex: 0 0 auto;
    }

    .brand-dot .icon {
      width: 20px;
      height: 20px;
    }

    .choice-icon .icon {
      width: 22px;
      height: 22px;
    }

    .brand-text {
      font-size: 0.83rem;
      font-weight: 700;
      letter-spacing: 0.08em;
      color: #4a6d91;
      text-transform: uppercase;
    }

    .hero-title {
      margin: 0 0 14px;
      line-height: 1.06;
      font-size: clamp(2.2rem, 4.8vw, 4rem);
      font-weight: 800;
      background: linear-gradient(120deg, #0f2a49 0%, #2268c7 52%, #1f9865 100%);
      -webkit-background-clip: text;
      background-clip: text;
      -webkit-text-fill-color: transparent;
      letter-spacing: 0.01em;
      text-shadow: none;
    }

    .actions {
      padding: clamp(1.4rem, 3.2vw, 2.3rem);
      display: flex;
      flex-direction: column;
      justify-content: center;
      gap: 14px;
      animation: revealIn 0.8s ease;
      background:
        radial-gradient(circle at 12% 10%, rgba(49, 112, 201, 0.12), transparent 44%),
        linear-gradient(180deg, rgba(255, 255, 255, 0.5), rgba(250, 253, 255, 0.72));
    }

    .logo-wrap {
      text-align: center;
      margin-bottom: 8px;
      border: 1px solid rgba(145, 173, 205, 0.25);
      border-radius: 16px;
      background: linear-gradient(180deg, rgba(255, 255, 255, 0.9), rgba(246, 251, 255, 0.84));
      padding: 14px 12px;
      box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.7);
    }

    .welcome-brand {
      width: min(100%, 320px);
      max-height: 100px;
      height: auto;
      object-fit: contain;
      display: block;
      margin: 0 auto;
      filter: drop-shadow(0 6px 12px rgba(15, 44, 75, 0.22));
    }

    .choice-card {
      border-radius: 16px;
      border: 1px solid rgba(145, 173, 205, 0.28);
      background: var(--card-bg);
      color: #143453;
      text-decoration: none;
      display: flex;
      align-items: center;
      gap: 14px;
      padding: 16px 15px;
      transition: transform 0.22s ease, box-shadow 0.22s ease, border-color 0.22s ease, background 0.22s ease;
    }

    .choice-card:hover {
      transform: translateY(-3px);
      box-shadow: 0 14px 28px rgba(29, 70, 113, 0.18);
      border-color: rgba(152, 185, 218, 0.68);
      background: var(--card-hover);
      color: #102b45;
    }

    .choice-icon {
      width: 48px;
      height: 48px;
      border-radius: 12px;
      display: grid;
      place-items: center;
      color: #fff;
      font-size: 1.25rem;
      flex: 0 0 auto;
    }

    .choice-card.encontrista .choice-icon {
      background: linear-gradient(140deg, var(--brand-blue), #1b4684);
      box-shadow: 0 10px 17px rgba(24, 79, 153, 0.33);
    }

    .choice-card.encontreiro .choice-icon {
      background: linear-gradient(140deg, var(--brand-green), #1a6547);
      box-shadow: 0 10px 17px rgba(22, 112, 74, 0.33);
    }

    .choice-content {
      flex: 1;
      min-width: 0;
    }

    .choice-title {
      display: block;
      font-size: 1.04rem;
      font-weight: 800;
      color: #183b5d;
      margin-bottom: 1px;
    }

    .choice-description {
      display: block;
      font-size: 0.85rem;
      color: #5a7591;
      line-height: 1.4;
    }

    .choice-arrow {
      color: #5c7fa3;
      font-size: 1rem;
      flex: 0 0 auto;
    }

    .choice-arrow .icon {
      width: 16px;
      height: 16px;
    }

    .admin-link {
      margin-top: 4px;
      text-align: center;
    }

    .admin-link a {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      text-decoration: none;
      color: #2e567e;
      border: 1px dashed rgba(153, 186, 220, 0.7);
      background: rgba(245, 251, 255, 0.95);
      border-radius: 999px;
      padding: 9px 14px;
      font-size: 0.85rem;
      font-weight: 700;
      transition: background 0.2s ease, color 0.2s ease, border-color 0.2s ease;
    }

    .admin-link a:hover {
      background: #edf6ff;
      color: #1d4670;
      border-color: rgba(126, 167, 207, 0.9);
    }

    @keyframes revealIn {
      from {
        opacity: 0;
        transform: translateY(8px);
      }
      to {
        opacity: 1;
        transform: translateY(0);
      }
    }

    @media (max-width: 992px) {
      .home-shell {
        grid-template-columns: 1fr;
        min-height: auto;
      }

      .hero {
        border-right: none;
        border-bottom: 1px solid #deebf8;
      }

      .hero-points {
        grid-template-columns: 1fr;
      }
    }

    @media (max-width: 520px) {
      body { padding: 0.75rem; }

      .home-shell {
        border-radius: 18px;
      }

      .hero-title {
        font-size: 2.25rem;
      }

      .choice-card {
        padding: 13px 12px;
      }

      .choice-title {
        font-size: 0.98rem;
      }
    }
  </style>
</head>
<body>
  <div class="rose-rain" aria-hidden="true">
    <span class="rose" style="--left: 2%; --size: 19px; --duration: 8.2s; --delay: -1.4s; --drift: 28px;">&#127801;</span>
    <span class="rose" style="--left: 8%; --size: 24px; --duration: 9.1s; --delay: -3.7s; --drift: -22px;">&#127801;</span>
    <span class="rose" style="--left: 14%; --size: 18px; --duration: 8.8s; --delay: -5.1s; --drift: 24px;">&#127801;</span>
    <span class="rose" style="--left: 19%; --size: 22px; --duration: 9.6s; --delay: -2.8s; --drift: -28px;">&#127801;</span>
    <span class="rose" style="--left: 25%; --size: 26px; --duration: 8.4s; --delay: -6.3s; --drift: 34px;">&#127801;</span>
    <span class="rose" style="--left: 31%; --size: 19px; --duration: 9.9s; --delay: -4.6s; --drift: -20px;">&#127801;</span>
    <span class="rose" style="--left: 37%; --size: 25px; --duration: 8.6s; --delay: -7.4s; --drift: 26px;">&#127801;</span>
    <span class="rose" style="--left: 43%; --size: 21px; --duration: 10.1s; --delay: -1.9s; --drift: -24px;">&#127801;</span>
    <span class="rose" style="--left: 49%; --size: 24px; --duration: 8.9s; --delay: -5.8s; --drift: 31px;">&#127801;</span>
    <span class="rose" style="--left: 55%; --size: 18px; --duration: 9.3s; --delay: -2.2s; --drift: -17px;">&#127801;</span>
    <span class="rose" style="--left: 61%; --size: 27px; --duration: 8.1s; --delay: -6.9s; --drift: 36px;">&#127801;</span>
    <span class="rose" style="--left: 67%; --size: 20px; --duration: 10.4s; --delay: -3.3s; --drift: -23px;">&#127801;</span>
    <span class="rose" style="--left: 73%; --size: 23px; --duration: 8.7s; --delay: -8.2s; --drift: 28px;">&#127801;</span>
