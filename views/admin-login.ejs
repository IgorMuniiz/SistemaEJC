<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8" />
  <meta http-equiv="X-UA-Compatible" content="IE=edge" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content="Login de Administrador - EJC COP" />
  <title>Admin - Login</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Manrope:wght@400;500;600;700;800&family=Sora:wght@500;600;700&display=swap" rel="stylesheet">
  <link rel="preload" href="/vendor/bootstrap/css/bootstrap.min.css" as="style" onload="this.onload=null;this.rel='stylesheet'">
  <noscript><link rel="stylesheet" href="/vendor/bootstrap/css/bootstrap.min.css"></noscript>
  <link rel="preload" href="/vendor/fontawesome/css/all.min.css" as="style" onload="this.onload=null;this.rel='stylesheet'">
  <noscript><link rel="stylesheet" href="/vendor/fontawesome/css/all.min.css"></noscript>
  <link rel="stylesheet" href="/css/admin-saas.css">
</head>
<body class="admin-panel admin-login-page">

  <!-- ░░ Background animado ░░ -->
  <div id="lpBg" class="lp-bg" aria-hidden="true">
    <div class="lp-orb lp-orb--a"></div>
    <div class="lp-orb lp-orb--b"></div>
    <div class="lp-orb lp-orb--c"></div>
    <div class="lp-grid"></div>
  </div>

  <!-- ░░ Conteúdo ░░ -->
  <div class="lp-wrap">

    <!-- Botão Voltar -->
    <a href="/" class="lp-back lp-reveal" style="--ri: 0;" aria-label="Voltar para a página inicial">
      <span class="lp-back__arrow"><i class="fas fa-arrow-left" aria-hidden="true"></i></span>
      <span>Voltar</span>
    </a>

    <!-- Card com borda gradiente -->
    <div class="lp-card lp-reveal" style="--ri: 1;">
      <div class="lp-card__body">
        <div class="lp-topline" aria-hidden="true"></div>

        <!-- Cabeçalho -->
        <header class="lp-header">
          <div class="lp-icon lp-reveal" style="--ri: 2;" aria-hidden="true">
            <i class="fas fa-lock"></i>
            <span class="lp-icon__ring"></span>
          </div>
          <h1 class="lp-reveal" style="--ri: 3;">Bem-Vindo ao EJC COP</h1>
          <p class="lp-reveal" style="--ri: 3;">Painel de Administração</p>
        </header>

        <!-- Alertas -->
        <% if (typeof error !== 'undefined' && error) { %>
          <div class="lp-alert lp-alert--error lp-reveal" style="--ri: 4;" role="alert">
            <i class="fas fa-exclamation-circle" aria-hidden="true"></i>
            <span><strong>Erro!</strong> <%= error %></span>
          </div>
        <% } %>

        <div class="lp-alert lp-alert--info lp-reveal" style="--ri: 4;" role="status">
          <i class="fas fa-shield-alt" aria-hidden="true"></i>
          <span>Acesso restrito a administradores</span>
        </div>

        <!-- Formulário -->
        <form method="POST" action="/admin/login">
          <div class="lp-field lp-reveal" style="--ri: 5;">
            <label for="username" class="lp-label">
              <i class="fas fa-user lp-label__icon" aria-hidden="true"></i>
              <span>Usuário</span>
            </label>
            <input
              class="lp-input"
              type="text"
              id="username"
              name="username"
              required
              placeholder="Digite seu usuário"
              autocomplete="username"
            />
          </div>

          <div class="lp-field lp-reveal" style="--ri: 6;">
            <label for="senha" class="lp-label">
              <i class="fas fa-key lp-label__icon" aria-hidden="true"></i>
              <span>Senha</span>
            </label>
            <div class="lp-input-wrap">
              <input
                class="lp-input lp-input--pass"
                type="password"
                id="senha"
                name="senha"
                required
                placeholder="Digite sua senha"
                autocomplete="current-password"
              />
              <button type="button" class="lp-eye-btn" aria-label="Mostrar senha">
                <i class="fas fa-eye" id="lpEyeIcon" aria-hidden="true"></i>
              </button>
            </div>
          </div>

          <button type="submit" class="lp-submit lp-reveal" style="--ri: 7;">
            <span class="lp-submit__shimmer" aria-hidden="true"></span>
            <i class="fas fa-sign-in-alt" aria-hidden="true"></i>
            <span>Entrar</span>
            <i class="fas fa-arrow-right lp-submit__arrow" aria-hidden="true"></i>
          </button>
        </form>

      </div>
    </div>
  </div>

  <script src="/vendor/bootstrap/js/bootstrap.bundle.min.js"></script>
  <script src="/js/page-transitions.js"></script>
  <script>
    // ── Cascade de entrada (após body fade-in do page-transitions.js) ──
    (function () {
      setTimeout(function () {
        document.querySelectorAll('.lp-reveal').forEach(function (el) {
          el.classList.add('lp-reveal--active');
        });
      }, 260);
    })();

    // ── Mouse parallax suave nos orbs de fundo ──
    (function () {
      var bg = document.getElementById('lpBg');
      if (!bg || window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;
      var mx = 0, my = 0, cx = 0, cy = 0;
      document.addEventListener('mousemove', function (e) {
        mx = (e.clientX / window.innerWidth  - 0.5) * 2;
        my = (e.clientY / window.innerHeight - 0.5) * 2;
      });
      function tick() {
        cx += (mx - cx) * 0.042;
        cy += (my - cy) * 0.042;
        bg.style.transform = 'translate(' + (cx * 24) + 'px,' + (cy * 16) + 'px) scale(1.07)';
        requestAnimationFrame(tick);
      }
      tick();
    })();

    // ── Toggle visibilidade da senha ──
    (function () {
      var btn      = document.querySelector('.lp-eye-btn');
      var input    = document.getElementById('senha');
      var icon     = document.getElementById('lpEyeIcon');
      if (!btn || !input) return;
      btn.addEventListener('click', function () {
        var show = input.type === 'password';
        input.type        = show ? 'text' : 'password';
        icon.className    = show ? 'fas fa-eye-slash' : 'fas fa-eye';
        btn.setAttribute('aria-label', show ? 'Ocultar senha' : 'Mostrar senha');
      });
    })();
  </script>
</body>
</html>
