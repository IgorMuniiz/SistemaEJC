<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="description" content="Editor visual para montar o quadrante com PDFs de circulos e equipes.">
  <title>Editor de Quadrante - <%= ejc.nome %></title>
  <link rel="preload" href="/vendor/bootstrap/css/bootstrap.min.css" as="style" onload="this.onload=null;this.rel='stylesheet'">
  <noscript><link rel="stylesheet" href="/vendor/bootstrap/css/bootstrap.min.css"></noscript>
  <link rel="preload" href="/vendor/fontawesome/css/all.min.css" as="style" onload="this.onload=null;this.rel='stylesheet'">
  <noscript><link rel="stylesheet" href="/vendor/fontawesome/css/all.min.css"></noscript>
  <link rel="stylesheet" href="/css/admin-saas.css">
  <style>
    body.admin-panel.quadrante-editor-page {
      background: radial-gradient(1200px 700px at 10% 5%, rgba(30, 41, 59, .55), transparent 60%), linear-gradient(180deg, #030712 0%, #020617 100%);
      color: rgba(226, 232, 240, .96);
      min-height: 100vh;
      font-family: "Manrope", "Segoe UI", Tahoma, sans-serif;
    }
    .qe-shell {
      max-width: 1400px;
      margin: 0 auto;
      padding: 22px 16px 28px;
      display: grid;
      grid-template-columns: 360px 1fr;
      gap: 14px;
    }
    .qe-card {
      background: rgba(10, 16, 31, .92);
      border: 1px solid rgba(71, 85, 105, .35);
      border-radius: 16px;
      box-shadow: 0 14px 44px rgba(2, 6, 23, .55);
      overflow: hidden;
    }
    .qe-head {
      padding: 14px 16px;
      border-bottom: 1px solid rgba(71, 85, 105, .28);
      background: linear-gradient(135deg, rgba(30, 41, 59, .66), rgba(15, 23, 42, .6));
    }
    .qe-head h1, .qe-head h2 {
      margin: 0;
      font-weight: 800;
      letter-spacing: .01em;
    }
    .qe-head h1 { font-size: 1.15rem; }
    .qe-head h2 { font-size: .95rem; }
    .qe-meta { margin-top: 6px; font-size: .78rem; color: rgba(148, 163, 184, .95); }

    .qe-left-body { padding: 12px; max-height: calc(100vh - 140px); overflow-y: auto; }
    .qe-tools { display: grid; gap: 8px; margin-bottom: 12px; }
    .qe-tools .btn { font-weight: 700; }

    .qe-source-item {
      border: 1px solid rgba(71, 85, 105, .4);
      border-radius: 12px;
      padding: 10px;
      background: rgba(15, 23, 42, .66);
      margin-bottom: 8px;
    }
    .qe-source-title {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 8px;
      font-size: .84rem;
      font-weight: 800;
      color: rgba(226, 232, 240, .98);
      margin-bottom: 6px;
    }
    .qe-source-kind { font-size: .67rem; color: rgba(148, 163, 184, .95); text-transform: uppercase; letter-spacing: .07em; }
    .qe-source-meta { font-size: .73rem; color: rgba(148, 163, 184, .95); margin-bottom: 8px; }
    .qe-source-actions { display: flex; flex-wrap: wrap; gap: 6px; }
    .qe-source-actions .btn { padding: 4px 8px; font-size: .72rem; }

    .qe-main { display: grid; grid-template-rows: auto 1fr auto; }
    .qe-main-body {
      padding: 12px;
      display: grid;
      grid-template-columns: 1.4fr .9fr;
      gap: 12px;
      min-height: 480px;
    }

    .qe-pages {
      background: rgba(5, 10, 22, .7);
      border: 1px solid rgba(71, 85, 105, .35);
      border-radius: 12px;
      padding: 10px;
      display: flex;
      flex-direction: column;
    }
    .qe-pages-title { font-size: .84rem; font-weight: 800; margin-bottom: 8px; color: rgba(191, 219, 254, .95); }
    .qe-pages-list {
      list-style: none;
      margin: 0;
      padding: 0;
      overflow-y: auto;
      max-height: calc(100vh - 300px);
      display: grid;
      gap: 8px;
    }
    .qe-page-item {
      background: rgba(15, 23, 42, .72);
      border: 1px solid rgba(96, 165, 250, .22);
      border-radius: 10px;
      padding: 8px;
      display: grid;
      grid-template-columns: auto 74px 1fr auto;
      align-items: center;
      gap: 8px;
      cursor: grab;
    }
    .qe-page-item.dragging { opacity: .45; }
    .qe-page-item.is-selected {
      border-color: rgba(56, 189, 248, .75);
      box-shadow: 0 0 0 2px rgba(56, 189, 248, .18);
      background: rgba(15, 23, 42, .95);
    }
    .qe-page-grip { color: rgba(125, 211, 252, .95); font-size: .9rem; }
    .qe-page-thumb {
      width: 68px;
      height: 92px;
      border: 1px solid rgba(148, 163, 184, .26);
      border-radius: 8px;
      background: rgba(2, 6, 23, .72);
      display: grid;
      place-items: center;
      overflow: hidden;
    }
    .qe-page-thumb img {
      width: 100%;
      height: 100%;
      object-fit: contain;
      background: #fff;
    }
    .qe-page-thumb-placeholder {
      font-size: .62rem;
      color: rgba(148, 163, 184, .85);
      text-align: center;
      line-height: 1.25;
      padding: 3px;
    }
    .qe-page-name { font-size: .78rem; color: rgba(226, 232, 240, .96); }
    .qe-page-sub { display: block; font-size: .69rem; color: rgba(148, 163, 184, .95); margin-top: 2px; }
    .qe-page-actions { display: flex; gap: 4px; }
    .qe-page-actions .btn { padding: 2px 7px; font-size: .68rem; }

    .qe-preview {
      background: rgba(5, 10, 22, .7);
      border: 1px solid rgba(71, 85, 105, .35);
      border-radius: 12px;
      display: flex;
      flex-direction: column;
      overflow: hidden;
      min-height: 420px;
    }
    /* --- Preview selecionada: container externo --- */
    .qe-preview-selected {
      border-bottom: 1px solid rgba(71, 85, 105, .3);
      background: rgba(2, 6, 23, .7);
      display: flex;
      flex-direction: column;
      user-select: none;
      -webkit-user-select: none;
    }
    /* Zona do canvas — ocupa o espaço disponível, clip da animação de slide */
    .qe-preview-canvas-area {
      flex: 1;
      min-height: 220px;
      display: flex;
      align-items: center;
      justify-content: center;
      position: relative;
      overflow: hidden;
      padding: 14px 46px;
      cursor: grab;
    }
    .qe-preview-canvas-area.is-dragging { cursor: grabbing; }
    /* Wrapper deslizante (animado no slide) */
    .qe-slide-wrapper {
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      will-change: transform;
    }
    .qe-slide-wrapper canvas {
      width: auto;
      max-width: 100%;
      max-height: 240px;
      height: auto;
      border-radius: 6px;
      background: #fff;
      border: 1px solid rgba(100, 116, 139, .25);
      box-shadow: 0 8px 28px rgba(2, 6, 23, .55);
      display: block;
    }
    /* Botões de navegação circulares */
    .qe-preview-nav-prev,
    .qe-preview-nav-next {
      position: absolute;
      top: 50%;
      transform: translateY(-50%);
      width: 34px;
      height: 34px;
      border-radius: 50%;
      border: 1px solid rgba(99, 102, 241, .35);
      background: rgba(15, 23, 42, .92);
      color: rgba(165, 180, 252, .95);
      font-size: .72rem;
      cursor: pointer;
      display: flex;
      align-items: center;
      justify-content: center;
      z-index: 4;
      backdrop-filter: blur(6px);
      transition: background .15s, border-color .15s, box-shadow .15s;
      opacity: .85;
      flex-shrink: 0;
    }
    .qe-preview-nav-prev:hover:not(:disabled),
    .qe-preview-nav-next:hover:not(:disabled) {
      background: rgba(49, 46, 129, .85);
      border-color: rgba(99, 102, 241, .7);
      box-shadow: 0 0 0 2px rgba(99, 102, 241, .2);
      opacity: 1;
    }
    .qe-preview-nav-prev:disabled,
    .qe-preview-nav-next:disabled { opacity: .2; cursor: default; pointer-events: none; }
    .qe-preview-nav-prev { left: 8px; }
    .qe-preview-nav-next { right: 8px; }
    /* Barra de informação na parte inferior */
    .qe-preview-info-bar {
      display: flex;
      justify-content: space-between;
      align-items: center;
      gap: 8px;
      padding: 7px 14px;
      border-top: 1px solid rgba(71, 85, 105, .28);
      background: rgba(8, 14, 36, .75);
      flex-shrink: 0;
    }
    .qe-preview-info-source {
      font-size: .74rem;
      font-weight: 600;
      color: rgba(191, 219, 254, .9);
      white-space: nowrap;
      overflow: hidden;
      text-overflow: ellipsis;
    }
    .qe-preview-info-counter {
      font-size: .72rem;
      color: rgba(148, 163, 184, .75);
      white-space: nowrap;
      flex-shrink: 0;
      letter-spacing: .04em;
    }
    /* Estado vazio */
    .qe-preview-selected-empty {
      font-size: .78rem;
      color: rgba(148, 163, 184, .7);
      padding: 24px;
      text-align: center;
    }
    .qe-preview-head {
      display: flex;
      justify-content: space-between;
      gap: 8px;
      align-items: center;
      padding: 10px;
      border-bottom: 1px solid rgba(71, 85, 105, .3);
      font-size: .78rem;
      color: rgba(191, 219, 254, .98);
      font-weight: 700;
    }
    .qe-preview iframe {
      border: none;
      width: 100%;
      height: 100%;
      min-height: 410px;
      background: #fff;
    }

    .qe-footer {
      border-top: 1px solid rgba(71, 85, 105, .28);
      padding: 10px 12px;
      display: flex;
      flex-wrap: wrap;
      justify-content: space-between;
      align-items: center;
      gap: 8px;
    }
    .qe-status { font-size: .78rem; color: rgba(148, 163, 184, .95); }

    .qe-file-input { display: none; }

    @media (max-width: 1120px) {
      .qe-shell { grid-template-columns: 1fr; }
      .qe-left-body { max-height: 380px; }
      .qe-main-body { grid-template-columns: 1fr; }
      .qe-pages-list { max-height: 320px; }
      .qe-preview-selected canvas { max-height: 180px; }
    }
  </style>
</head>
<body class="admin-panel quadrante-editor-page">
  <div class="qe-shell">
    <aside class="qe-card">
      <div class="qe-head">
        <h1><i class="fas fa-layer-group me-2"></i>Fontes do Quadrante</h1>
        <div class="qe-meta"><%= ejc.nome %> · circulos e equipes</div>
      </div>
      <div class="qe-left-body">
        <div class="qe-tools">
          <button class="btn btn-primary" type="button" id="btnCarregarPadrao"><i class="fas fa-rotate me-1"></i>Carregar PDFs do EJC</button>
          <button class="btn btn-outline-light" type="button" id="btnAnexarPdf"><i class="fas fa-paperclip me-1"></i>Anexar outros PDFs</button>
          <input id="inputPdfExtra" class="qe-file-input" type="file" accept="application/pdf" multiple>
          <a class="btn btn-outline-secondary" href="/admin/encontros/<%= ejc._id %>"><i class="fas fa-arrow-left me-1"></i>Voltar ao painel EJC</a>
        </div>
        <div id="sourcesList"></div>
      </div>
    </aside>

    <section class="qe-card qe-main">
      <div class="qe-head">
        <div class="d-flex justify-content-between align-items-center gap-2 flex-wrap">
          <div>
            <h2><i class="fas fa-file-pdf me-2"></i>Montagem do Quadrante</h2>
            <div class="qe-meta">Arraste as paginas para reordenar do jeito que voce quiser</div>
          </div>
          <a class="btn btn-sm btn-outline-light" href="/admin/encontros/<%= ejc._id %>"><i class="fas fa-arrow-left me-1"></i>Voltar</a>
        </div>
      </div>

      <div class="qe-main-body">
        <div class="qe-pages">
          <div class="qe-pages-title">Paginas no PDF final</div>
          <ul id="pagesList" class="qe-pages-list"></ul>
        </div>

        <div class="qe-preview">
          <div class="qe-preview-head">
            <span id="previewLabel">Preview do PDF montado</span>
            <button class="btn btn-sm btn-outline-light" type="button" id="btnAtualizarPreview"><i class="fas fa-sync-alt me-1"></i>Atualizar preview</button>
          </div>
          <div class="qe-preview-selected" id="selectedPagePreview">
            <span class="qe-preview-selected-empty">Selecione uma pagina para ver zoom aqui.</span>
          </div>
          <iframe id="pdfPreview" title="Preview PDF"></iframe>
        </div>
      </div>

      <div class="qe-footer">
        <div class="qe-status" id="statusText">Pronto para montar.</div>
        <div class="d-flex flex-wrap gap-2">
          <button class="btn btn-outline-warning" type="button" id="btnLimpar"><i class="fas fa-trash me-1"></i>Limpar paginas</button>
          <button class="btn btn-outline-info" type="button" id="btnImprimir"><i class="fas fa-print me-1"></i>Imprimir</button>
          <button class="btn btn-success" type="button" id="btnSalvar"><i class="fas fa-download me-1"></i>Salvar PDF</button>
        </div>
      </div>
    </section>
  </div>

  <script id="quadrante-sources-data" type="application/json"><%- JSON.stringify(quadranteSources || []) %></script>
  <script id="quadrante-meta-data" type="application/json"><%- JSON.stringify({ ejcId: String(ejc._id || ''), ejcNome: String(ejc.nome || 'ejc') }) %></script>

  <script src="/vendor/bootstrap/js/bootstrap.bundle.min.js"></script>
  <script src="https://unpkg.com/pdf-lib@1.17.1/dist/pdf-lib.min.js"></script>
  <script>
    const sourceSeed = JSON.parse(document.getElementById('quadrante-sources-data').textContent || '[]');
    const quadranteMeta = JSON.parse(document.getElementById('quadrante-meta-data').textContent || '{}');
    const ejcId = String(quadranteMeta.ejcId || '');
    const ejcNome = String(quadranteMeta.ejcNome || 'ejc');

    const state = {
      sources: sourceSeed.map((item) => ({ ...item, loaded: false, loading: false, pages: 0, bytes: null, error: null })),
      pages: [],
      dragId: null,
      previewUrl: null,
      seq: 0,
      thumbCache: new Map(),
      selectedPageId: null,
      selectedZoomToken: 0,
    };

    const pdfJsDocs = new Map();

    // Usa PDF.js quando disponivel para gerar miniaturas visuais das paginas.
    async function getPdfJsLib() {
      if (window.__pdfjsLibReady) return window.__pdfjsLibReady;

      window.__pdfjsLibReady = import('https://unpkg.com/pdfjs-dist@4.8.69/build/pdf.min.mjs')
        .then((pdfjsLib) => {
          pdfjsLib.GlobalWorkerOptions.workerSrc = 'https://unpkg.com/pdfjs-dist@4.8.69/build/pdf.worker.min.mjs';
          return pdfjsLib;
        })
        .catch(() => null);

      return window.__pdfjsLibReady;
    }

    async function getPdfJsDocForSource(source) {
      if (!source || !source.bytes) return null;
      if (pdfJsDocs.has(source.id)) return pdfJsDocs.get(source.id);

      const pdfjsLib = await getPdfJsLib();
      if (!pdfjsLib) return null;

      const loadingTask = pdfjsLib.getDocument({ data: source.bytes.slice() });
      const doc = await loadingTask.promise;
      pdfJsDocs.set(source.id, doc);
      return doc;
    }

    async function renderPageThumbnail(page, thumbNode) {
      const cacheKey = page.sourceId + '::' + page.pageIndex;
      const cached = state.thumbCache.get(cacheKey);
      if (cached) {
        thumbNode.innerHTML = '<img alt="Miniatura" src="' + cached + '">';
        return;
      }

      const source = getSourceById(page.sourceId);
      if (!source || !source.bytes) {
        thumbNode.innerHTML = '<span class="qe-page-thumb-placeholder">Sem PDF</span>';
        return;
      }

      thumbNode.innerHTML = '<span class="qe-page-thumb-placeholder">Renderizando...</span>';

      try {
        const doc = await getPdfJsDocForSource(source);
        if (!doc) {
          thumbNode.innerHTML = '<span class="qe-page-thumb-placeholder">Miniatura indisponivel</span>';
          return;
        }

        const pdfPage = await doc.getPage(page.pageIndex + 1);
        const viewport = pdfPage.getViewport({ scale: 1 });
        const targetWidth = 64;
        const scale = targetWidth / viewport.width;
        const scaledViewport = pdfPage.getViewport({ scale });

        const canvas = document.createElement('canvas');
        const context = canvas.getContext('2d', { alpha: false });
        canvas.width = Math.ceil(scaledViewport.width);
        canvas.height = Math.ceil(scaledViewport.height);

        await pdfPage.render({ canvasContext: context, viewport: scaledViewport }).promise;

        const dataUrl = canvas.toDataURL('image/png');
        state.thumbCache.set(cacheKey, dataUrl);
        thumbNode.innerHTML = '<img alt="Miniatura" src="' + dataUrl + '">';
      } catch (err) {
        thumbNode.innerHTML = '<span class="qe-page-thumb-placeholder">Falha miniatura</span>';
      }
    }

    const sourceListNode = document.getElementById('sourcesList');
    const pagesListNode = document.getElementById('pagesList');
    const statusNode = document.getElementById('statusText');
    const previewNode = document.getElementById('pdfPreview');
    const selectedPagePreviewNode = document.getElementById('selectedPagePreview');

    const setStatus = (text) => { statusNode.textContent = text; };

    const getSourceById = (id) => state.sources.find((item) => item.id === id);

    async function loadSourcePdf(source) {
      if (!source || source.loaded || source.loading) return source;
      source.loading = true;
      source.error = null;
      renderSources();
      try {
        const resp = await fetch(source.url, { credentials: 'same-origin' });
        if (!resp.ok) throw new Error('Falha ao carregar ' + source.nome);
        const ab = await resp.arrayBuffer();
        const bytes = new Uint8Array(ab);
        const doc = await PDFLib.PDFDocument.load(bytes);
        source.bytes = bytes;
        source.pages = doc.getPageCount();
        source.loaded = true;
        pdfJsDocs.delete(source.id);
        Array.from(state.thumbCache.keys())
          .filter((key) => key.startsWith(source.id + '::'))
          .forEach((key) => state.thumbCache.delete(key));
        return source;
      } catch (err) {
        source.error = err.message || 'erro desconhecido';
        source.loaded = false;
        return source;
      } finally {
        source.loading = false;
        renderSources();
      }
    }

    function sourceKindLabel(tipo) {
      if (tipo === 'circulo') return 'Circulo';
      if (tipo === 'equipe') return 'Equipe';
      return 'Anexo';
    }

    function addAllPagesFromSource(sourceId) {
      const source = getSourceById(sourceId);
      if (!source || !source.loaded || !source.pages) return;

      const jaTem = state.pages.some((item) => item.sourceId === source.id);
      if (jaTem) {
        setStatus('As paginas de "' + source.nome + '" ja estao na montagem.');
        return;
      }

      for (let idx = 0; idx < source.pages; idx += 1) {
        state.seq += 1;
        state.pages.push({
          id: 'p-' + state.seq,
          sourceId: source.id,
          sourceNome: source.nome,
          sourceTipo: source.tipo,
          pageIndex: idx,
        });
      }
      renderPages();
      setStatus('Paginas adicionadas: ' + source.nome + '.');
    }

    function removePagesFromSource(sourceId) {
      const before = state.pages.length;
      state.pages = state.pages.filter((item) => item.sourceId !== sourceId);
      const removed = before - state.pages.length;
      renderPages();
      setStatus(removed > 0 ? ('Removidas ' + removed + ' paginas.') : 'Nenhuma pagina removida.');
    }

    function movePage(fromIdx, toIdx) {
      if (fromIdx < 0 || toIdx < 0 || fromIdx >= state.pages.length || toIdx >= state.pages.length) return;
      const [item] = state.pages.splice(fromIdx, 1);
      state.pages.splice(toIdx, 0, item);
      renderPages();
    }

    function setSelectedPage(pageId) {
      state.selectedPageId = pageId;
      renderPages();
    }

    function renderSources() {
      sourceListNode.innerHTML = '';
      if (!state.sources.length) {
        sourceListNode.innerHTML = '<div class="text-muted small">Nao ha fontes para este EJC.</div>';
        return;
      }

      state.sources.forEach((source) => {
        const wrapper = document.createElement('article');
        wrapper.className = 'qe-source-item';

        const title = document.createElement('div');
        title.className = 'qe-source-title';
        title.innerHTML = '<span>' + source.nome + '</span><span class="qe-source-kind">' + sourceKindLabel(source.tipo) + '</span>';

        const meta = document.createElement('div');
        meta.className = 'qe-source-meta';
        if (source.loading) {
          meta.textContent = 'Carregando PDF...';
        } else if (source.error) {
          meta.textContent = 'Erro: ' + source.error;
        } else if (source.loaded) {
          meta.textContent = source.pages + ' pagina(s) carregada(s)';
        } else {
          meta.textContent = 'PDF ainda nao carregado';
        }

        const actions = document.createElement('div');
        actions.className = 'qe-source-actions';

        const btnLoad = document.createElement('button');
        btnLoad.type = 'button';
        btnLoad.className = 'btn btn-sm btn-outline-light';
        btnLoad.textContent = source.loaded ? 'Recarregar' : 'Carregar';
        btnLoad.addEventListener('click', async () => {
          await loadSourcePdf(source);
          setStatus('PDF carregado: ' + source.nome + '.');
        });

        const btnAdd = document.createElement('button');
        btnAdd.type = 'button';
        btnAdd.className = 'btn btn-sm btn-primary';
        btnAdd.textContent = 'Adicionar paginas';
        btnAdd.disabled = !source.loaded;
        btnAdd.addEventListener('click', () => addAllPagesFromSource(source.id));

        const btnRemove = document.createElement('button');
        btnRemove.type = 'button';
        btnRemove.className = 'btn btn-sm btn-outline-warning';
        btnRemove.textContent = 'Remover da montagem';
        btnRemove.addEventListener('click', () => removePagesFromSource(source.id));

        const btnOpen = document.createElement('button');
        btnOpen.type = 'button';
        btnOpen.className = 'btn btn-sm btn-outline-info';
        btnOpen.textContent = 'Abrir PDF';
        btnOpen.addEventListener('click', () => {
          if (source.url) window.open(source.url, '_blank', 'noopener');
        });

        actions.append(btnLoad, btnAdd, btnRemove, btnOpen);
        wrapper.append(title, meta, actions);
        sourceListNode.appendChild(wrapper);
      });
    }

    function renderPages() {
      pagesListNode.innerHTML = '';
      if (!state.pages.length) {
        state.selectedPageId = null;
        pagesListNode.innerHTML = '<li class="text-muted small">Nenhuma pagina adicionada ainda.</li>';
        selectedPagePreviewNode.innerHTML = '<span class="qe-preview-selected-empty">Selecione uma pagina para ver zoom aqui.</span>';
        clearPreview();
        return;
      }

      if (!state.pages.some((item) => item.id === state.selectedPageId)) {
        state.selectedPageId = state.pages[0].id;
      }

      state.pages.forEach((page, index) => {
        const li = document.createElement('li');
        li.className = 'qe-page-item';
        li.draggable = true;
        li.dataset.pageId = page.id;
        if (state.selectedPageId === page.id) {
          li.classList.add('is-selected');
        }

        const grip = document.createElement('span');
        grip.className = 'qe-page-grip';
        grip.innerHTML = '<i class="fas fa-grip-vertical"></i>';

        const thumb = document.createElement('div');
        thumb.className = 'qe-page-thumb';
        thumb.innerHTML = '<span class="qe-page-thumb-placeholder">Miniatura</span>';

        const text = document.createElement('div');
        text.className = 'qe-page-name';
        text.innerHTML = (index + 1) + '. ' + page.sourceNome + '<span class="qe-page-sub">Pagina ' + (page.pageIndex + 1) + ' · ' + sourceKindLabel(page.sourceTipo) + '</span>';

        const actions = document.createElement('div');
        actions.className = 'qe-page-actions';

        const btnUp = document.createElement('button');
        btnUp.type = 'button';
        btnUp.className = 'btn btn-outline-light';
        btnUp.innerHTML = '<i class="fas fa-arrow-up"></i>';
        btnUp.title = 'Mover para cima';
        btnUp.addEventListener('click', () => movePage(index, index - 1));

        const btnDown = document.createElement('button');
        btnDown.type = 'button';
        btnDown.className = 'btn btn-outline-light';
        btnDown.innerHTML = '<i class="fas fa-arrow-down"></i>';
        btnDown.title = 'Mover para baixo';
        btnDown.addEventListener('click', () => movePage(index, index + 1));

        const btnDelete = document.createElement('button');
        btnDelete.type = 'button';
        btnDelete.className = 'btn btn-outline-danger';
        btnDelete.innerHTML = '<i class="fas fa-times"></i>';
        btnDelete.title = 'Remover pagina';
        btnDelete.addEventListener('click', () => {
          state.pages.splice(index, 1);
          renderPages();
        });

        actions.append(btnUp, btnDown, btnDelete);
  li.append(grip, thumb, text, actions);

        li.addEventListener('dragstart', () => {
          state.dragId = page.id;
          li.classList.add('dragging');
        });
        li.addEventListener('click', () => {
          setSelectedPage(page.id);
        });
        li.addEventListener('dragend', () => {
          li.classList.remove('dragging');
          state.dragId = null;
        });
        li.addEventListener('dragover', (ev) => ev.preventDefault());
        li.addEventListener('drop', (ev) => {
          ev.preventDefault();
          if (!state.dragId || state.dragId === page.id) return;
          const fromIdx = state.pages.findIndex((item) => item.id === state.dragId);
          const toIdx = state.pages.findIndex((item) => item.id === page.id);
          if (fromIdx < 0 || toIdx < 0) return;
          movePage(fromIdx, toIdx);
        });

        pagesListNode.appendChild(li);

        // Renderiza miniatura sem bloquear a montagem da lista.
        renderPageThumbnail(page, thumb);
      });

      renderSelectedPageZoom();

      setStatus('Montagem com ' + state.pages.length + ' pagina(s).');
    }

    async function renderSelectedPageZoom(slideFrom) {
      if (!state.selectedPageId) {
        selectedPagePreviewNode.innerHTML = '<span class="qe-preview-selected-empty">Selecione uma pagina para ver zoom aqui.</span>';
        return;
      }

      const page = state.pages.find((item) => item.id === state.selectedPageId);
      if (!page) {
        selectedPagePreviewNode.innerHTML = '<span class="qe-preview-selected-empty">Selecione uma pagina para ver zoom aqui.</span>';
        return;
      }

      const source = getSourceById(page.sourceId);
      if (!source || !source.bytes) {
        selectedPagePreviewNode.innerHTML = '<span class="qe-preview-selected-empty">PDF da pagina ainda nao carregado.</span>';
        return;
      }

      const token = Date.now();
      state.selectedZoomToken = token;
      if (!slideFrom) {
        selectedPagePreviewNode.innerHTML = '<span class="qe-preview-selected-empty">Renderizando...</span>';
      }

      try {
        const doc = await getPdfJsDocForSource(source);
        if (!doc || state.selectedZoomToken !== token) return;

        const pdfPage = await doc.getPage(page.pageIndex + 1);
        if (state.selectedZoomToken !== token) return;

        const baseViewport = pdfPage.getViewport({ scale: 1 });
        const containerWidth = Math.max(260, selectedPagePreviewNode.clientWidth - 40);
        const scale = Math.min(2.4, containerWidth / baseViewport.width);
        const viewport = pdfPage.getViewport({ scale });

        const canvas = document.createElement('canvas');
        const context = canvas.getContext('2d', { alpha: false });
        canvas.width = Math.ceil(viewport.width);
        canvas.height = Math.ceil(viewport.height);

        await pdfPage.render({ canvasContext: context, viewport }).promise;
        if (state.selectedZoomToken !== token) return;

        const currentIdx = state.pages.findIndex((item) => item.id === state.selectedPageId);

        const slideWrapper = document.createElement('div');
        slideWrapper.className = 'qe-slide-wrapper';
        slideWrapper.append(canvas);

        const btnPrev = document.createElement('button');
        btnPrev.type = 'button';
        btnPrev.className = 'qe-preview-nav-prev';
        btnPrev.title = 'Pagina anterior';
        btnPrev.innerHTML = '<i class="fas fa-chevron-left"></i>';
        btnPrev.disabled = currentIdx <= 0;
        btnPrev.addEventListener('click', () => navigateSelectedPage(-1));

        const btnNext = document.createElement('button');
        btnNext.type = 'button';
        btnNext.className = 'qe-preview-nav-next';
        btnNext.title = 'Proxima pagina';
        btnNext.innerHTML = '<i class="fas fa-chevron-right"></i>';
        btnNext.disabled = currentIdx >= state.pages.length - 1;
        btnNext.addEventListener('click', () => navigateSelectedPage(1));

        const canvasArea = document.createElement('div');
        canvasArea.className = 'qe-preview-canvas-area';
        canvasArea.append(slideWrapper, btnPrev, btnNext);

        const infoBar = document.createElement('div');
        infoBar.className = 'qe-preview-info-bar';

        const infoSource = document.createElement('span');
        infoSource.className = 'qe-preview-info-source';
        infoSource.textContent = page.sourceNome + ' · Página ' + (page.pageIndex + 1);

        const infoCounter = document.createElement('span');
        infoCounter.className = 'qe-preview-info-counter';
        infoCounter.textContent = (currentIdx + 1) + ' / ' + state.pages.length;

        infoBar.append(infoSource, infoCounter);

        selectedPagePreviewNode.innerHTML = '';
        selectedPagePreviewNode.append(canvasArea, infoBar);

        if (slideFrom) {
          const startX = slideFrom === 'right' ? '110%' : '-110%';
          slideWrapper.style.transform = 'translateX(' + startX + ')';
          requestAnimationFrame(() => requestAnimationFrame(() => {
            slideWrapper.style.transition = 'transform 0.25s cubic-bezier(0.4, 0, 0.2, 1)';
            slideWrapper.style.transform = 'translateX(0)';
          }));
        }
      } catch (err) {
        if (state.selectedZoomToken !== token) return;
        selectedPagePreviewNode.innerHTML = '<span class="qe-preview-selected-empty">Falha ao renderizar zoom desta pagina.</span>';
      }
    }

    function navigateSelectedPage(direction) {
      const currentIdx = state.pages.findIndex((item) => item.id === state.selectedPageId);
      if (currentIdx < 0) return;
      const nextIdx = currentIdx + direction;

      if (nextIdx < 0 || nextIdx >= state.pages.length) {
        const wrapper = selectedPagePreviewNode.querySelector('.qe-slide-wrapper');
        if (wrapper) {
          wrapper.style.transition = 'transform 0.18s ease';
          wrapper.style.transform = 'translateX(0)';
        }
        return;
      }

      const wrapper = selectedPagePreviewNode.querySelector('.qe-slide-wrapper');
      if (wrapper) {
        wrapper.style.transition = 'transform 0.2s ease';
        wrapper.style.transform = direction > 0 ? 'translateX(-110%)' : 'translateX(110%)';
      }

      const slideFrom = direction > 0 ? 'right' : 'left';

      window.setTimeout(async () => {
        state.selectedPageId = state.pages[nextIdx].id;
        pagesListNode.querySelectorAll('.qe-page-item').forEach((li, idx) => {
          li.classList.toggle('is-selected', !!(state.pages[idx] && state.pages[idx].id === state.selectedPageId));
        });
        const selectedLi = pagesListNode.querySelector('.is-selected');
        if (selectedLi) selectedLi.scrollIntoView({ block: 'nearest', behavior: 'smooth' });
        await renderSelectedPageZoom(slideFrom);
      }, 215);
    }

    let swipeHandlersAttached = false;
    function attachSwipeHandlers() {
      if (swipeHandlersAttached) return;
      swipeHandlersAttached = true;

      let isDragging = false;
      let startX = 0;

      const getWrapper = () => selectedPagePreviewNode.querySelector('.qe-slide-wrapper');

      const getCanvasArea = () => selectedPagePreviewNode.querySelector('.qe-preview-canvas-area');

      const onStart = (x, target) => {
        if (target && !target.closest('.qe-preview-canvas-area')) return;
        const wrapper = getWrapper();
        if (!wrapper) return;
        isDragging = true;
        startX = x;
        wrapper.style.transition = 'none';
        const area = getCanvasArea();
        if (area) area.classList.add('is-dragging');
      };

      const onMove = (x) => {
        if (!isDragging) return;
        const wrapper = getWrapper();
        if (!wrapper) return;
        wrapper.style.transform = 'translateX(' + (x - startX) + 'px)';
      };

      const onEnd = (x) => {
        if (!isDragging) return;
        isDragging = false;
        const area = getCanvasArea();
        if (area) area.classList.remove('is-dragging');
        const delta = x - startX;
        if (delta < -60) {
          navigateSelectedPage(1);
        } else if (delta > 60) {
          navigateSelectedPage(-1);
        } else {
          const wrapper = getWrapper();
          if (wrapper) {
            wrapper.style.transition = 'transform 0.18s ease';
            wrapper.style.transform = 'translateX(0)';
          }
        }
      };

      selectedPagePreviewNode.addEventListener('mousedown', (e) => onStart(e.clientX, e.target));
      document.addEventListener('mousemove', (e) => { if (isDragging) { e.preventDefault(); onMove(e.clientX); } }, { passive: false });
      document.addEventListener('mouseup', (e) => { if (isDragging) onEnd(e.clientX); });

      selectedPagePreviewNode.addEventListener('touchstart', (e) => {
        if (e.touches[0]) onStart(e.touches[0].clientX, e.target);
      }, { passive: true });
      selectedPagePreviewNode.addEventListener('touchmove', (e) => {
        if (isDragging && e.touches[0]) onMove(e.touches[0].clientX);
      }, { passive: true });
      selectedPagePreviewNode.addEventListener('touchend', (e) => {
        if (isDragging) onEnd((e.changedTouches[0] || { clientX: startX }).clientX);
      });
    }

    async function buildMergedPdfBytes() {
      if (!state.pages.length) throw new Error('Nao ha paginas para montar.');
      const merged = await PDFLib.PDFDocument.create();
      const sourceDocCache = new Map();

      for (const page of state.pages) {
        const source = getSourceById(page.sourceId);
        if (!source || !source.bytes) {
          throw new Error('Fonte sem PDF carregado: ' + (page.sourceNome || page.sourceId));
        }

        let srcDoc = sourceDocCache.get(source.id);
        if (!srcDoc) {
          srcDoc = await PDFLib.PDFDocument.load(source.bytes);
          sourceDocCache.set(source.id, srcDoc);
        }

        const [copiedPage] = await merged.copyPages(srcDoc, [page.pageIndex]);
        merged.addPage(copiedPage);
      }

      return merged.save();
    }

    function clearPreview() {
      if (state.previewUrl) {
        URL.revokeObjectURL(state.previewUrl);
        state.previewUrl = null;
      }
      previewNode.removeAttribute('src');
    }

    async function refreshPreview() {
      if (!state.pages.length) {
        clearPreview();
        setStatus('Nao ha paginas para preview.');
        return;
      }

      setStatus('Gerando preview do PDF montado...');
      const bytes = await buildMergedPdfBytes();
      const blob = new Blob([bytes], { type: 'application/pdf' });
      clearPreview();
      state.previewUrl = URL.createObjectURL(blob);
      previewNode.src = state.previewUrl;
      setStatus('Preview atualizado.');
    }

    async function saveMergedPdf() {
      const bytes = await buildMergedPdfBytes();
      const blob = new Blob([bytes], { type: 'application/pdf' });
      const url = URL.createObjectURL(blob);
      const a = document.createElement('a');
      const nomeArquivo = 'quadrante_montado_' + String(ejcNome || 'ejc').toLowerCase().replace(/[^a-z0-9]+/g, '_') + '.pdf';
      a.href = url;
      a.download = nomeArquivo;
      document.body.appendChild(a);
      a.click();
      a.remove();
      setTimeout(() => URL.revokeObjectURL(url), 1000);
      setStatus('PDF salvo com sucesso.');
    }

    async function printMergedPdf() {
      const bytes = await buildMergedPdfBytes();
      const blob = new Blob([bytes], { type: 'application/pdf' });
      const url = URL.createObjectURL(blob);
      const frame = document.createElement('iframe');
      frame.style.position = 'fixed';
      frame.style.right = '0';
      frame.style.bottom = '0';
      frame.style.width = '0';
      frame.style.height = '0';
      frame.style.border = '0';
      frame.src = url;
      document.body.appendChild(frame);
      frame.onload = () => {
        try {
          frame.contentWindow.focus();
          frame.contentWindow.print();
        } finally {
          setTimeout(() => {
            URL.revokeObjectURL(url);
            frame.remove();
          }, 3000);
        }
      };
      setStatus('Enviando para impressao...');
    }

    async function attachExternalPdfs(files) {
      if (!files || !files.length) return;

      for (const file of files) {
        try {
          const ab = await file.arrayBuffer();
          const bytes = new Uint8Array(ab);
          const doc = await PDFLib.PDFDocument.load(bytes);
          const id = 'anexo-' + Date.now() + '-' + Math.random().toString(36).slice(2, 8);
          const source = {
            id,
            tipo: 'anexo',
            nome: file.name,
            url: '',
            loaded: true,
            loading: false,
            pages: doc.getPageCount(),
            bytes,
            error: null,
          };
          state.sources.push(source);
          addAllPagesFromSource(id);
        } catch (err) {
          setStatus('Falha ao anexar ' + file.name + ': ' + (err.message || 'arquivo invalido'));
        }
      }

      renderSources();
      renderPages();
    }

    async function loadDefaultSourcesAndAssemble() {
      setStatus('Carregando PDFs de circulos e equipes...');
      state.pages = [];
      renderPages();

      for (const source of state.sources) {
        if (source.tipo === 'anexo') continue;
        await loadSourcePdf(source);
        if (source.loaded) addAllPagesFromSource(source.id);
      }

      await refreshPreview();
      setStatus('PDFs do EJC carregados. Voce pode mover paginas, anexar PDFs e salvar.');
    }

    document.getElementById('btnCarregarPadrao').addEventListener('click', () => {
      loadDefaultSourcesAndAssemble().catch((err) => setStatus('Erro: ' + err.message));
    });

    document.getElementById('btnAnexarPdf').addEventListener('click', () => {
      document.getElementById('inputPdfExtra').click();
    });

    document.getElementById('inputPdfExtra').addEventListener('change', async (event) => {
      const files = Array.from(event.target.files || []);
      await attachExternalPdfs(files);
      event.target.value = '';
      await refreshPreview().catch(() => {});
    });

    document.getElementById('btnAtualizarPreview').addEventListener('click', () => {
      refreshPreview().catch((err) => setStatus('Erro no preview: ' + err.message));
    });

    document.getElementById('btnLimpar').addEventListener('click', () => {
      state.pages = [];
      renderPages();
      setStatus('Montagem limpa.');
    });

    document.getElementById('btnSalvar').addEventListener('click', () => {
      saveMergedPdf().catch((err) => setStatus('Erro ao salvar: ' + err.message));
    });

    document.getElementById('btnImprimir').addEventListener('click', () => {
      printMergedPdf().catch((err) => setStatus('Erro ao imprimir: ' + err.message));
    });

    attachSwipeHandlers();
    renderSources();
    renderPages();
    loadDefaultSourcesAndAssemble().catch((err) => setStatus('Erro ao carregar fontes: ' + err.message));
  </script>
</body>
</html>
