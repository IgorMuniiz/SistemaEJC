            <div class="admin-form-card admin-config-card admin-admins-card" data-required-permission="admins.gerenciar">
              <div class="admin-card-head">
                <div>
                  <p class="admin-card-kicker">Acesso</p>
                  <h5><i class="fas fa-user-plus me-2"></i>Cadastrar Novo Administrador</h5>
                  <p class="admin-card-subtitle">Crie acessos administrativos com credenciais mínimas e fluxo direto de cadastro.</p>
                </div>
                <span class="admin-card-badge">Gestão de credenciais</span>
              </div>
              <form id="formAdmin" class="row g-3">
                <div class="col-lg-3 col-md-6">
                  <label class="form-label">Usuário *</label>
                  <input type="text" id="admin_username" class="form-control" required>
                </div>
                <div class="col-lg-3 col-md-6">
                  <label class="form-label">Senha *</label>
                  <input type="password" id="admin_senha" class="form-control" minlength="6" required>
                </div>
                <div class="col-lg-3 col-md-6">
                  <label class="form-label">Nível hierárquico *</label>
                  <select id="admin_nivel" class="form-select" <%= podeGerenciarAdmins ? '' : 'disabled' %>>
                    <option value="consulta">Consulta</option>
                    <option value="operador">Operador</option>
                    <option value="coordenador" selected>Coordenador</option>
                    <option value="super_admin">Super Admin</option>
                  </select>
                </div>
                <div class="col-lg-3 col-md-6 d-flex align-items-end">
                  <button type="button" class="btn btn-primary w-100 admin-primary-action" onclick="cadastrarAdmin()">
                    <i class="fas fa-save me-1"></i>Salvar
                  </button>
                </div>
                <div class="col-12">
                  <label class="form-label">Permissões extras</label>
                  <div id="admin_permissions" class="admin-perm-pill-group">
                    <% adminPermissionOptionsList.forEach(function(option) { %>
                      <div class="admin-perm-pill">
                        <input class="admin-perm-item" type="checkbox" id="perm-new-<%= option.key %>" value="<%= option.key %>">
                        <label class="admin-perm-pill-label" for="perm-new-<%= option.key %>">
                          <span class="admin-perm-pill-name"><i class="fas fa-check admin-perm-check-icon"></i><%= option.label %></span>
                          <small><%= option.description %></small>
                        </label>
                      </div>
                    <% }); %>
                  </div>
                </div>
              </form>
              <small class="text-muted admin-helper-note">Senha mínima: 6 caracteres. O nível define o acesso base e você pode complementar com permissões extras.</small>
            </div>

            <div class="admin-form-card admin-config-card admin-lgpd-card" data-required-permission="lgpd.executar">
              <div class="admin-card-head">
                <div>
                  <p class="admin-card-kicker">Conformidade</p>
                  <h5><i class="fas fa-shield-halved me-2"></i>LGPD e Retenção</h5>
                  <p class="admin-card-subtitle">Defina a janela de retenção e execute a anonimização de dados antigos com segurança.</p>
                </div>
                <span class="admin-card-badge">Proteção de dados</span>
              </div>
              <div class="row g-3 align-items-end">
                <div class="col-md-8">
                  <label class="form-label">Retenção em dias</label>
                  <input type="number" id="lgpd_retencao_dias" class="form-control" value="730" min="30" max="3650">
                </div>
                <div class="col-md-4">
                  <button type="button" class="btn btn-outline-primary w-100 admin-secondary-action" onclick="executarRetencaoLgpd()">
                    <i class="fas fa-user-shield me-1"></i>Executar retenção
                  </button>
                </div>
              </div>
              <small class="text-muted admin-helper-note">Anonimiza dados antigos de cadastros não aprovados conforme o prazo informado.</small>
            </div>

            <div class="admin-form-card admin-config-card admin-table-card mb-3" data-required-permission="admins.gerenciar">
              <div class="admin-card-head">
                <div>
                  <p class="admin-card-kicker">Rastreabilidade</p>
                  <h5><i class="fas fa-clipboard-list me-2"></i>Auditoria</h5>
                  <p class="admin-card-subtitle">Acompanhe eventos administrativos com paginação para revisão, conferência e histórico operacional.</p>
                </div>
                <span class="admin-card-badge">Total: <%= auditoriaTotal || 0 %> eventos</span>
              </div>
              <div class="audit-pagination-head">
                <span class="audit-page-meta">Página <strong><%= auditoriaPaginaAtual || 1 %></strong> de <strong><%= auditoriaTotalPaginas || 1 %></strong></span>
                <div class="audit-pagination-actions">
                  <% const prevAuditPage = Math.max(1, (auditoriaPaginaAtual || 1) - 1); %>
                  <% const nextAuditPage = Math.min((auditoriaTotalPaginas || 1), (auditoriaPaginaAtual || 1) + 1); %>
                  <a class="btn btn-sm btn-outline-light <%= (auditoriaPaginaAtual || 1) <= 1 ? 'disabled' : '' %>" href="/admin/gerenciar-cadastros?tab=admins&auditPage=<%= prevAuditPage %>&auditLimit=<%= auditoriaLimite || 40 %>">Anterior</a>
                  <a class="btn btn-sm btn-outline-light <%= (auditoriaPaginaAtual || 1) >= (auditoriaTotalPaginas || 1) ? 'disabled' : '' %>" href="/admin/gerenciar-cadastros?tab=admins&auditPage=<%= nextAuditPage %>&auditLimit=<%= auditoriaLimite || 40 %>">Próxima</a>
                </div>
              </div>
              <div class="table-wrap admin-table-shell">
                <table class="table table-hover">
                  <thead>
                    <tr>
                      <th>Data</th>
                      <th>Admin</th>
                      <th>Ação</th>
                      <th>Alvo</th>
                      <th>Status</th>
                    </tr>
                  </thead>
                  <tbody>
                    <% if (!auditoriaLogs || auditoriaLogs.length === 0) { %>
                      <tr><td colspan="5" class="empty-state">Nenhum evento de auditoria registrado.</td></tr>
                    <% } else { %>
                      <% auditoriaLogs.forEach(function(log) { %>
                        <tr>
                          <td><%= new Date(log.createdAt).toLocaleString('pt-BR') %></td>
                          <td><%= log.adminUsername || '-' %></td>
                          <td><%= log.action || '-' %></td>
                          <td><%= [log.targetType, log.targetId].filter(Boolean).join(': ') || '-' %></td>
                          <td>
                            <% if (log.status === 'success') { %>
                              <span class="status-badge status-ok">Sucesso</span>
                            <% } else { %>
                              <span class="status-badge status-warn">Erro</span>
                            <% } %>
                          </td>
                        </tr>
                      <% }); %>
                    <% } %>
                  </tbody>
                </table>
              </div>
            </div>

            <div class="admin-form-card admin-config-card admin-table-card" data-required-permission="admins.gerenciar">
              <div class="admin-card-head">
                <div>
                  <p class="admin-card-kicker">Equipe de acesso</p>
                  <h5><i class="fas fa-user-shield me-2"></i>Administradores Cadastrados</h5>
                  <p class="admin-card-subtitle">Visualize, edite e mantenha a lista de acessos administrativos do sistema organizada.</p>
                </div>
                <span class="admin-card-badge">Admins: <%= (administradores || []).length %></span>
              </div>
              <div class="table-wrap admin-table-shell">
                <table class="table table-hover">
                  <thead>
                    <tr>
                      <th>Usuário</th>
                      <th>Nível</th>
                      <th>Permissões</th>
                      <th>Data de Criação</th>
                      <th>Ações</th>
                    </tr>
                  </thead>
                  <tbody>
                    <% if (administradores.length === 0) { %>
                      <tr><td colspan="5" class="empty-state">Nenhum administrador cadastrado.</td></tr>
                    <% } else { %>
                      <% administradores.forEach(function(admin) { %>
                        <tr>
                          <td><strong><%= admin.username %></strong></td>
                          <td><span class="status-badge"><%= admin.nivelAcesso || 'super_admin' %></span></td>
                          <td><small><%= (admin.permissoesEfetivas || []).join(', ') %></small></td>
                          <td><%= new Date(admin.dataCriacao).toLocaleDateString('pt-BR') %></td>
                          <td>
                            <button type="button" class="btn btn-edit js-edit-admin" data-admin-id="<%= admin._id %>" onclick="editarAdmin('<%= admin._id %>', '<%= (admin.username || '').replace(/'/g, '\\\'') %>', '<%= admin.nivelAcesso || 'super_admin' %>', '<%= (admin.permissoes || []).join(',').replace(/'/g, '\\\'') %>')" title="<%= podeGerenciarAdmins ? 'Editar administrador' : 'Voce nao possui permissao para editar administradores' %>">
                              <i class="fas fa-edit me-1"></i>Editar
                            </button>
                            <button type="button" class="btn btn-delete js-delete-admin" data-admin-id="<%= admin._id %>" onclick="deletarAdmin('<%= admin._id %>', '<%= (admin.username || '').replace(/'/g, '\\\'') %>')" title="<%= podeGerenciarAdmins ? 'Deletar administrador' : 'Voce nao possui permissao para deletar administradores' %>">
                              <i class="fas fa-trash me-1"></i>Deletar
                            </button>
                          </td>
                        </tr>
                      <% }); %>
                    <% } %>
                  </tbody>
                </table>
              </div>
            </div>
          </div>
        </div>
      </section>
    </main>
  </div>

