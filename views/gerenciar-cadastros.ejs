    function setupAdminKeyboardShortcuts() {
      const tabsByShortcut = {
        '1': 'principal-tab',
        '2': 'encontristas-tab',
        '3': 'encontreiros-tab',
        '4': 'tios-tab',
        '5': 'aprovacoes-tab',
        '6': 'encontros-tab',
        '7': 'admins-tab',
      };

      document.addEventListener('keydown', (event) => {
        const key = String(event.key || '').toLowerCase();
        const target = event.target;
        const isTyping = target && (
          target.tagName === 'INPUT'
          || target.tagName === 'TEXTAREA'
          || target.tagName === 'SELECT'
          || target.isContentEditable
        );

        if (isTyping) return;
        if (!event.altKey) return;

        if (tabsByShortcut[key]) {
          event.preventDefault();
          abrirAba(tabsByShortcut[key]);
          return;
        }

        if (key === 'd') {
          event.preventDefault();
          window.location.href = '/admin/dashboard';
          return;
        }

        if (key === 's') {
          event.preventDefault();
          const activePane = document.querySelector('.tab-pane.active.show') || document;
          const saveButton = activePane.querySelector('.admin-primary-action, .btn-primary, button[type="submit"]');
          if (saveButton && !saveButton.disabled) {
            saveButton.click();
          }
        }
      });
    }

    function atualizarNavegacaoAtiva(tabButtonId) {
      document.querySelectorAll('[data-tab-target]').forEach((item) => {
        item.classList.toggle('active', item.dataset.tabTarget === tabButtonId);
      });
