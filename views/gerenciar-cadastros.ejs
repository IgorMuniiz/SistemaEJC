<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="description" content="Painel de gestao de cadastros do EJC COP com controle de encontristas, encontreiros, tios, encontros e administradores.">
  <title>Painel Administrativo - EJC COP</title>
  <link rel="preload" href="/vendor/bootstrap/css/bootstrap.min.css" as="style" onload="this.onload=null;this.rel='stylesheet'">
  <noscript><link rel="stylesheet" href="/vendor/bootstrap/css/bootstrap.min.css"></noscript>
  <link rel="preload" href="/vendor/fontawesome/css/all.min.css" as="style" onload="this.onload=null;this.rel='stylesheet'">
  <noscript><link rel="stylesheet" href="/vendor/fontawesome/css/all.min.css"></noscript>
  <link rel="stylesheet" href="/css/admin-saas.css">
  <style>
    :root {
      --bg-main: #f4f7fc;
      --sidebar-bg: linear-gradient(180deg, #0f2c44 0%, #173f61 52%, #1d557f 100%);
      --sidebar-hover: rgba(255, 255, 255, 0.12);
      --card-bg: #ffffff;
      --text-main: #1d2b39;
      --text-muted: #6b7d90;
      --brand: #1a78d6;
      --brand-dark: #1257a0;
      --ok: #2f9b5d;
      --warn: #d3981f;
    }

    body {
      margin: 0;
      background: radial-gradient(circle at 12% 18%, #dfeeff 0%, #f4f7fc 42%, #edf2f9 100%);
      color: var(--text-main);
      font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
      min-height: 100vh;
    }

    .admin-shell {
      display: flex;
      min-height: 100vh;
    }

    .sidebar {
      width: 78px;
      background: var(--sidebar-bg);
      color: #fff;
      transition: width 0.28s ease;
      overflow: hidden;
      position: sticky;
      top: 0;
      height: 100vh;
      box-shadow: 10px 0 30px rgba(6, 18, 29, 0.2);
      z-index: 20;
    }

    .sidebar:hover {
      width: 270px;
    }

    .sidebar-top {
      padding: 20px 16px 10px;
      border-bottom: 1px solid rgba(255, 255, 255, 0.15);
    }

    .brand-inline {
      display: flex;
      align-items: center;
      gap: 12px;
      min-height: 44px;
      margin-bottom: 10px;
    }

    .brand-badge {
      width: 44px;
      height: 44px;
      border-radius: 12px;
      background: rgba(255, 255, 255, 0.18);
      display: grid;
      place-items: center;
      font-size: 1.1rem;
      flex: 0 0 auto;
    }

    .brand-text {
      opacity: 0;
      transition: opacity 0.2s ease;
      white-space: nowrap;
      font-weight: 700;
      letter-spacing: 0.02em;
    }

    .sidebar:hover .brand-text {
      opacity: 1;
    }

    .side-menu {
      padding: 14px 10px 18px;
      display: flex;
      flex-direction: column;
      gap: 8px;
    }

    .menu-link {
      display: flex;
      align-items: center;
      gap: 12px;
      color: #fff;
      text-decoration: none;
      border-radius: 12px;
      padding: 10px 12px;
      font-size: 0.9rem;
      font-weight: 600;
      transition: background 0.2s ease, transform 0.2s ease;
      border: none;
      width: 100%;
      background: transparent;
      text-align: left;
      cursor: pointer;
    }

    .menu-link i {
      width: 28px;
      text-align: center;
      font-size: 1rem;
      flex: 0 0 auto;
    }

    .menu-label {
      white-space: nowrap;
      opacity: 0;
      transition: opacity 0.2s ease;
    }

    .sidebar:hover .menu-label {
      opacity: 1;
    }

    .menu-link:hover,
    .menu-link.active {
      background: var(--sidebar-hover);
      transform: translateX(2px);
      color: #fff;
    }

    .sidebar-note {
      margin: auto 12px 16px;
      padding: 10px;
      border-radius: 12px;
      background: rgba(255, 255, 255, 0.12);
      font-size: 0.75rem;
      line-height: 1.35;
      opacity: 0;
      transition: opacity 0.2s ease;
      text-align: center;
    }

    .sidebar:hover .sidebar-note {
      opacity: 1;
    }

    .main-panel {
      flex: 1;
      padding: 24px;
      min-width: 0;
    }

    .topbar {
      display: flex;
      justify-content: space-between;
      align-items: center;
      gap: 14px;
      margin-bottom: 18px;
      background: rgba(255, 255, 255, 0.95);
      border: 1px solid #dce6f1;
      border-radius: 14px;
      padding: 16px 18px;
      box-shadow: 0 6px 18px rgba(25, 52, 78, 0.08);
    }

    .topbar h1 {
      margin: 0;
      font-size: 1.35rem;
      font-weight: 800;
      color: #12304b;
    }

    .topbar p {
      margin: 3px 0 0;
      color: var(--text-muted);
      font-size: 0.9rem;
    }

    .admin-pill {
      background: #e8f2ff;
      border: 1px solid #c7defa;
      color: #184f85;
      padding: 7px 12px;
      border-radius: 999px;
      font-size: 0.82rem;
      font-weight: 700;
      white-space: nowrap;
    }

    .content-card {
      background: var(--card-bg);
      border: 1px solid #dce5f1;
      border-radius: 14px;
      padding: 18px;
      box-shadow: 0 6px 20px rgba(26, 49, 71, 0.08);
    }

    .nav-tabs .nav-link {
      border: none;
      border-radius: 10px;
      font-weight: 700;
      color: #3f5872;
      padding: 10px 14px;
      margin-right: 5px;
    }

    .nav-tabs .nav-link.active {
      background: #1a78d6;
      color: #fff;
    }

    .table-wrap {
      margin-top: 16px;
      border: 1px solid #e1eaf4;
      border-radius: 12px;
      overflow: auto;
    }

    table {
      margin-bottom: 0 !important;
      min-width: 850px;
    }

    thead th {
      background: #eff5fc !important;
      color: #29445c !important;
      border-bottom: 1px solid #dbe5f0 !important;
      font-size: 0.84rem;
      letter-spacing: 0.02em;
      text-transform: uppercase;
    }

    td {
      vertical-align: middle;
    }

    .table-photo {
      width: 52px;
      height: 52px;
      border-radius: 8px;
      object-fit: cover;
      border: 1px solid #dce5f2;
    }

    .status-badge {
      padding: 6px 10px;
      border-radius: 999px;
      font-weight: 700;
      font-size: 0.74rem;
    }

    .status-ok {
      background: #e7f7ee;
      border: 1px solid #bce8cf;
      color: var(--ok);
    }

    .status-warn {
      background: #fff4e0;
      border: 1px solid #f2d9aa;
      color: var(--warn);
    }

    .btn-edit {
      background: linear-gradient(135deg, var(--brand) 0%, #2f8fe6 100%);
      color: #fff;
      border: none;
      border-radius: 10px;
      font-weight: 700;
      font-size: 0.78rem;
      padding: 7px 11px;
      margin-right: 5px;
    }

    .btn-edit:hover {
      background: linear-gradient(135deg, var(--brand-dark) 0%, #2a7bc2 100%);
      color: #fff;
    }

    .btn-delete {
      background: linear-gradient(135deg, #dc3545 0%, #a0252f 100%);
      color: #fff;
      border: none;
      border-radius: 10px;
      font-weight: 700;
      font-size: 0.78rem;
      padding: 7px 11px;
      margin-right: 5px;
    }

    .btn-delete:hover {
      background: linear-gradient(135deg, #c82333 0%, #8a1e27 100%);
      color: #fff;
    }

    .btn-approve {
      background: linear-gradient(135deg, var(--ok) 0%, #1e7a47 100%);
      color: #fff;
      border: none;
      border-radius: 10px;
      font-weight: 700;
      font-size: 0.78rem;
      padding: 7px 11px;
      margin-right: 5px;
    }

    .btn-approve:hover {
      background: linear-gradient(135deg, #2a8a5a 0%, #176139 100%);
      color: #fff;
    }

    .btn-reject {
      background: linear-gradient(135deg, var(--warn) 0%, #b8771a 100%);
      color: #fff;
      border: none;
      border-radius: 10px;
      font-weight: 700;
      font-size: 0.78rem;
      padding: 7px 11px;
    }

    .btn-reject:hover {
      background: linear-gradient(135deg, #c27f1f 0%, #9d6615 100%);
      color: #fff;
    }

    .admin-form-card {
      border: 1px solid #dce6f2;
      background: #f8fbff;
      border-radius: 12px;
      padding: 14px;
      margin-bottom: 14px;
    }

    .import-result {
      margin-top: 10px;
      border-radius: 10px;
      padding: 10px 12px;
      font-size: 0.86rem;
      display: none;
    }

    .import-result.success {
      display: block;
      background: #e8f8ef;
      border: 1px solid #bfe5cd;
      color: #186a3b;
    }

    .import-result.error {
      display: block;
      background: #fdecec;
      border: 1px solid #f4c5c5;
      color: #8a1f1f;
    }

    .form-label {
      font-weight: 700;
      font-size: 0.84rem;
      color: #35506a;
    }

    .modal-foto-preview {
      max-width: 180px;
      max-height: 180px;
      border-radius: 10px;
      object-fit: cover;
      border: 1px solid #dbe4ef;
    }

    .empty-state {
      text-align: center;
      color: #6e8297;
      padding: 16px;
      font-weight: 600;
    }

    .export-group-actions {
      display: flex;
      gap: 8px;
      align-items: center;
      flex-wrap: wrap;
    }

    .export-btn {
      background: #f0f4f8;
      color: #36526d;
      border: 1px solid #d9e6f2;
      border-radius: 8px;
      padding: 6px 12px;
      font-size: 0.78rem;
      font-weight: 600;
      transition: all 0.2s ease;
      text-decoration: none;
      display: inline-flex;
      align-items: center;
      gap: 4px;
      white-space: nowrap;
    }

    .export-btn:hover {
      background: #1a78d6;
      color: #fff;
      border-color: #1a78d6;
      transform: translateY(-1px);
      text-decoration: none;
    }

    .search-toolbar {
      margin-bottom: 12px;
      display: flex;
      justify-content: flex-end;
      gap: 8px;
      align-items: center;
      flex-wrap: wrap;
    }

    .search-input-wrap {
      position: relative;
      width: min(420px, 100%);
    }

    .search-input-wrap i {
      position: absolute;
      left: 12px;
      top: 50%;
      transform: translateY(-50%);
      color: #6b7d90;
      font-size: 0.9rem;
      pointer-events: none;
    }

    .search-input {
      width: 100%;
      border: 1px solid #d9e5f2;
      border-radius: 10px;
      padding: 9px 12px 9px 34px;
      font-size: 0.9rem;
      color: #1d2b39;
      background: #fff;
    }

    .search-input:focus {
      outline: none;
      border-color: #1a78d6;
      box-shadow: 0 0 0 3px rgba(26, 120, 214, 0.14);
    }

    .search-empty-row td {
      text-align: center;
      color: #6e8297;
      font-weight: 600;
      padding: 14px;
    }

    .list-section-title {
      margin: 14px 0 10px;
      font-weight: 800;
      color: #173f61;
      display: flex;
      align-items: center;
      gap: 8px;
    }

    .transfer-lote-bar {
      margin-bottom: 12px;
      display: flex;
      align-items: center;
      gap: 10px;
      flex-wrap: wrap;
    }

    .checkbox-col {
      width: 42px;
      text-align: center;
    }

    .btn-clear-search {
      border: 1px solid #d9e5f2;
      background: #fff;
      color: #35506a;
      border-radius: 10px;
      font-size: 0.85rem;
      font-weight: 700;
      padding: 8px 12px;
      transition: all 0.2s ease;
    }

    .btn-clear-search:hover {
      border-color: #1a78d6;
      color: #1a78d6;
      background: #f4f9ff;
    }

    @media (max-width: 991px) {
      .sidebar {
        width: 68px;
      }

      .sidebar:hover {
        width: 220px;
      }

      .main-panel {
        padding: 16px;
      }

      .topbar {
        flex-direction: column;
        align-items: flex-start;
      }
    }
  </style>
</head>
<body>
  <% const encontreirosIndividuais = (encontreiros || []).filter(function(c){ return c.tipo !== 'tios'; }); %>
  <% const tios = (encontreiros || []).filter(function(c){ return c.tipo === 'tios'; }); %>
  <% const statusCadastro = function(c){
    if (c && c.statusAprovacao === 'aprovado') return 'aprovado';
    if (c && c.statusAprovacao === 'reprovado') return 'reprovado';
    if (c && c.aprovado) return 'aprovado';
    return 'pendente';
  }; %>
  <% const encontristasAprovados = (encontristas || []).filter(function(c){ return statusCadastro(c) === 'aprovado'; }); %>
  <% const encontristasReprovados = (encontristas || []).filter(function(c){ return statusCadastro(c) === 'reprovado'; }); %>
  <% const encontristasPendentes = (encontristas || []).filter(function(c){ return statusCadastro(c) === 'pendente'; }); %>
  <% const encontreirosAprovados = (encontreirosIndividuais || []).filter(function(c){ return statusCadastro(c) === 'aprovado'; }); %>
  <% const encontreirosReprovados = (encontreirosIndividuais || []).filter(function(c){ return statusCadastro(c) === 'reprovado'; }); %>
  <% const encontreirosPendentes = (encontreirosIndividuais || []).filter(function(c){ return statusCadastro(c) === 'pendente'; }); %>

  <div class="admin-shell">
    <aside class="sidebar">
      <div class="sidebar-top">
        <div class="brand-inline">
          <div class="brand-badge"><i class="fas fa-shield-heart"></i></div>
          <div class="brand-text">Painel Admin</div>
        </div>
      </div>

      <nav class="side-menu">
        <button type="button" class="menu-link" onclick="abrirAba('encontristas-tab')"><i class="fas fa-user"></i><span class="menu-label">Encontristas</span></button>
        <button type="button" class="menu-link" onclick="abrirAba('encontreiros-tab')"><i class="fas fa-user-group"></i><span class="menu-label">Encontreiros</span></button>
        <button type="button" class="menu-link" onclick="abrirAba('tios-tab')"><i class="fas fa-heart"></i><span class="menu-label">Tios</span></button>
        <button type="button" class="menu-link" onclick="abrirAba('aprovacoes-tab')"><i class="fas fa-check-circle"></i><span class="menu-label">Aprovações</span></button>
        <button type="button" class="menu-link" onclick="abrirAba('encontros-tab')"><i class="fas fa-calendar-days"></i><span class="menu-label">Encontros</span></button>
        <button type="button" class="menu-link" onclick="abrirAba('admins-tab')"><i class="fas fa-user-shield"></i><span class="menu-label">Administradores</span></button>
        <a href="/admin/logout" class="menu-link"><i class="fas fa-right-from-bracket"></i><span class="menu-label">Sair</span></a>
      </nav>

      <div class="sidebar-note">
        Passe o mouse para expandir
      </div>
    </aside>

    <main class="main-panel">
      <header class="topbar">
        <div>
          <h1><i class="fas fa-users-cog me-2"></i>Painel de Gestão</h1>
          <p>Gerencie cadastros, aprovações e administradores do sistema.</p>
        </div>
        <div class="admin-pill"><i class="fas fa-user-circle me-2"></i><%= adminUsername %></div>
      </header>

      <section class="content-card">
        <ul class="nav nav-tabs" id="cadastroTabs" role="tablist">
          <li class="nav-item" role="presentation">
            <button class="nav-link active" id="encontristas-tab" data-bs-toggle="tab" data-bs-target="#encontristas" type="button">
              <i class="fas fa-user me-1"></i>Encontristas (<%= encontristas.length %>)
            </button>
          </li>
          <li class="nav-item" role="presentation">
            <button class="nav-link" id="encontreiros-tab" data-bs-toggle="tab" data-bs-target="#encontreiros" type="button">
              <i class="fas fa-user-group me-1"></i>Encontreiros (<%= encontreirosIndividuais.length %>)
            </button>
          </li>
          <li class="nav-item" role="presentation">
            <button class="nav-link" id="tios-tab" data-bs-toggle="tab" data-bs-target="#tios" type="button">
              <i class="fas fa-heart me-1"></i>Tios (<%= tios.length %>)
            </button>
          </li>
          <li class="nav-item" role="presentation">
            <button class="nav-link" id="aprovacoes-tab" data-bs-toggle="tab" data-bs-target="#aprovacoes" type="button">
              <i class="fas fa-check-circle me-1"></i>Aprovações
            </button>
          </li>
          <li class="nav-item" role="presentation">
            <button class="nav-link" id="encontros-tab" data-bs-toggle="tab" data-bs-target="#encontros" type="button">
              <i class="fas fa-calendar-days me-1"></i>Encontros
            </button>
          </li>
          <li class="nav-item" role="presentation">
            <button class="nav-link" id="admins-tab" data-bs-toggle="tab" data-bs-target="#admins" type="button">
              <i class="fas fa-user-shield me-1"></i>Administradores (<%= administradores.length %>)
            </button>
          </li>
        </ul>

        <div class="tab-content" id="cadastroTabsContent">
          <!-- TAB: ENCONTRISTAS -->
          <div class="tab-pane fade show active" id="encontristas" role="tabpanel">
            <div class="export-group-actions mb-3">
              <a href="/export?format=pdf" class="btn btn-sm btn-outline-secondary export-btn" target="_blank" rel="noreferrer" title="Exportar como PDF">
                <i class="fas fa-file-pdf me-1"></i>PDF
              </a>
              <a href="/export-encontrista-excel" class="btn btn-sm btn-outline-secondary export-btn" target="_blank" rel="noreferrer" title="Exportar Relatório em Excel">
                <i class="fas fa-table me-1"></i>Relatório
              </a>
              <a href="/export-images-encontristas" class="btn btn-sm btn-outline-secondary export-btn" target="_blank" rel="noreferrer" title="Exportar Imagens">
                <i class="fas fa-file-archive me-1"></i>Imagens
              </a>
            </div>
            <div class="transfer-lote-bar">
              <button id="btn-transferir-selecionados" class="btn btn-approve" type="button" onclick="transferirSelecionadosEncontristas()" disabled>
                <i class="fas fa-right-left me-1"></i>Transferir selecionados (0)
              </button>
              <small class="text-muted">Voce pode selecionar varios encontristas e transferir todos de uma vez.</small>
            </div>
            <div class="search-toolbar">
              <div class="search-input-wrap">
                <i class="fas fa-search"></i>
                <input id="search-encontristas" class="search-input" type="text" placeholder="Pesquisar encontristas por nome ou EJC">
              </div>
              <button id="clear-search-encontristas" type="button" class="btn-clear-search">
                <i class="fas fa-eraser me-1"></i>Limpar busca
              </button>
            </div>
            <div class="table-wrap">
              <div class="list-section-title"><i class="fas fa-circle-check text-success"></i>Encontristas aprovados (<%= encontristasAprovados.length %>)</div>
              <table class="table table-hover">
                <thead>
                  <tr>
                    <th class="checkbox-col"><input type="checkbox" onchange="toggleSelecionarTodosEncontristas(this, 'aprovado')" title="Selecionar todos aprovados"></th>
                    <th>Foto</th>
                    <th>Nome</th>
                    <th>EJC</th>
                    <th>Telefone</th>
                    <th>Email</th>
                    <th>Status</th>
                    <th>Ações</th>
                  </tr>
                </thead>
                <tbody>
                  <% if (encontristasAprovados.length === 0) { %>
                    <tr><td colspan="8" class="empty-state">Nenhum encontrista aprovado.</td></tr>
                  <% } else { %>
                    <% encontristasAprovados.forEach(function(cadastro) { %>
                      <tr data-searchable="true" data-transfer-group="aprovado">
                        <td class="checkbox-col">
                          <input class="transfer-encontrista-check" type="checkbox" value="<%= cadastro._id %>" onchange="atualizarTransferenciaLoteUI()">
                        </td>
                        <td>
                          <% if (cadastro.foto) { %>
                            <img src="/img/uploads/<%= encodeURIComponent(cadastro.foto) %>?w=120&h=120&fit=cover&format=webp" loading="lazy" decoding="async" alt="Foto" class="table-photo">
                          <% } else { %>
                            <i class="fas fa-user-circle fa-2x text-secondary"></i>
                          <% } %>
                        </td>
                        <td><%= cadastro.nomeCompleto %></td>
                        <td><%= cadastro.ejc %></td>
                        <td><%= cadastro.telefone %></td>
                        <td><%= cadastro.email %></td>
                        <td>
                          <% if (statusCadastro(cadastro) === 'aprovado') { %>
                            <span class="status-badge status-ok">Aprovado</span>
                          <% } else if (statusCadastro(cadastro) === 'reprovado') { %>
                            <span class="status-badge status-warn">Reprovado</span>
                          <% } else { %>
                            <span class="status-badge status-warn">Pendente</span>
                          <% } %>
                        </td>
                        <td>
                          <button class="btn btn-edit" onclick="editarCadastro('encontrista', '<%= cadastro._id %>')">
                            <i class="fas fa-edit me-1"></i>Editar
                          </button>
                          <button class="btn btn-approve" onclick="transferirParaEncontreiros('<%= cadastro._id %>', '<%= cadastro.nomeCompleto.replace(/'/g, "\\'") %>')">
                            <i class="fas fa-right-left me-1"></i>Transferir
                          </button>
                          <button class="btn btn-delete" data-nome="<%= cadastro.nomeCompleto %>" onclick="deletarCadastro('encontrista', '<%= cadastro._id %>', this.dataset.nome)">
                            <i class="fas fa-trash me-1"></i>Deletar
                          </button>
                        </td>
                      </tr>
                    <% }); %>
                  <% } %>
                </tbody>
              </table>
            </div>

            <div class="table-wrap">
              <div class="list-section-title"><i class="fas fa-circle-xmark text-warning"></i>Encontristas reprovados (<%= encontristasReprovados.length %>)</div>
              <table class="table table-hover">
                <thead>
                  <tr>
                    <th class="checkbox-col"><input type="checkbox" onchange="toggleSelecionarTodosEncontristas(this, 'reprovado')" title="Selecionar todos reprovados"></th>
                    <th>Foto</th>
                    <th>Nome</th>
                    <th>EJC</th>
                    <th>Telefone</th>
                    <th>Email</th>
                    <th>Status</th>
                    <th>Ações</th>
                  </tr>
                </thead>
                <tbody>
                  <% if (encontristasReprovados.length === 0) { %>
                    <tr><td colspan="8" class="empty-state">Nenhum encontrista reprovado.</td></tr>
                  <% } else { %>
