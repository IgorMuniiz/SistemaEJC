    function salvarAbaAtiva() {
      const abaId = getAbaAtivaId();
      localStorage.setItem('admin_gerenciar_cadastros_aba_ativa', abaId);

      const url = new URL(window.location.href);
      url.searchParams.set('tab', abaId);
      window.history.replaceState({}, '', url.toString());
    }

    function restaurarAbaAtiva() {
      const url = new URL(window.location.href);
      const abaNaUrl = url.searchParams.get('tab');
      const abaNoStorage = localStorage.getItem('admin_gerenciar_cadastros_aba_ativa');
      const fallbackAba = getPrimeiraAbaDisponivelId();
      const abaDesejada = abaNaUrl || abaNoStorage || fallbackAba;
      const botao = document.getElementById(`${abaDesejada}-tab`);

      if (!botao || botao.style.display === 'none') {
        const fallbackButton = document.getElementById(`${fallbackAba}-tab`);
        if (fallbackButton && fallbackButton.style.display !== 'none') {
          bootstrap.Tab.getOrCreateInstance(fallbackButton).show();
          atualizarNavegacaoAtiva(`${fallbackAba}-tab`);
        }
        salvarAbaAtiva();
        return;
      }

      bootstrap.Tab.getOrCreateInstance(botao).show();
      atualizarNavegacaoAtiva(`${abaDesejada}-tab`);
      salvarAbaAtiva();
    }

    function recarregarMantendoAbaAtual() {
