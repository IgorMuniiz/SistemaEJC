    async function salvarEdicao() {
      const formData = new FormData(document.getElementById('formEdicao'));
      const tipo = document.getElementById('edit_tipo').value;
      const id = document.getElementById('edit_id').value;

      try {
        const response = await fetch(`/admin/atualizar-cadastro/${tipo}/${id}`, {
          method: 'POST',
          body: formData
        });
        
        const contentType = response.headers.get('content-type');
        if (!contentType || !contentType.includes('application/json')) {
          console.error('Resposta não-JSON recebida:', await response.text());
          await appAlert('Erro: Resposta invalida do servidor.', 'danger', 'Erro');
          return;
        }
        
        const result = await response.json();

        if (result.success) {
          await appAlert('Cadastro atualizado com sucesso.', 'success', 'Sucesso');
          modalEdicao.hide();
          recarregarMantendoAbaAtual();
        } else {
          await appAlert(result.error || 'Erro ao atualizar cadastro.', 'danger', 'Erro');
        }
      } catch (error) {
        console.error('Erro ao salvar alterações:', error);
        await appAlert('Erro ao salvar alteracoes: ' + error.message, 'danger', 'Erro');
      }
    }

