    async function transferirSelecionadosEncontristas() {
      const ids = getEncontristasSelecionadosTransferencia();
      if (ids.length === 0) {
        await appAlert('Selecione ao menos um encontrista para transferir.', 'warning', 'Nenhum selecionado');
        return;
      }

      const confirmar = await appConfirm(
        `Transferir ${ids.length} encontrista(s) para Encontreiros?\n\nEles serao removidos da lista de Encontristas.`,
        'Confirmar transferencia em lote'
      );
      if (!confirmar) return;

      try {
        const response = await fetch('/admin/transferir-encontristas-lote', {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json',
            Accept: 'application/json',
          },
          body: JSON.stringify({ ids }),
        });

        const result = await response.json();
        if (!result.success) {
          await appAlert(result.error || 'Nao foi possivel transferir os selecionados.', 'danger', 'Erro');
          return;
        }

        const resumo = result.resumo || {};
        await appAlert(
          `Transferencia concluida.\n\nTransferidos: ${resumo.transferidos || 0}\nDuplicados ignorados: ${resumo.duplicados || 0}\nNao encontrados: ${resumo.naoEncontrados || 0}`,
          'success',
          'Sucesso'
        );
        recarregarMantendoAbaAtual();
      } catch (error) {
        await appAlert('Erro ao transferir selecionados: ' + (error.message || 'falha de conexao'), 'danger', 'Erro');
      }
