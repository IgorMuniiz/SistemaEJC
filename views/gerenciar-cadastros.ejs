    async function deletarCadastro(tipo, id, nome) {
      if (!await appConfirm(`Tem certeza que deseja deletar o cadastro de "${nome}"? Esta acao nao pode ser desfeita.`, 'Confirmar exclusao')) return;

      try {
        const response = await fetch(`/admin/deletar-cadastro/${encodeURIComponent(tipo)}/${encodeURIComponent(id)}`, {
          method: 'POST',
          headers: { Accept: 'application/json' }
        });

        const contentType = response.headers.get('content-type') || '';
        const result = contentType.includes('application/json')
          ? await response.json()
          : { success: false, error: await response.text() };

        if (result.success) {
          await appAlert('Cadastro deletado com sucesso.', 'success', 'Sucesso');
          recarregarMantendoAbaAtual();
        } else {
          await appAlert(result.error || 'Erro ao deletar cadastro.', 'danger', 'Erro');
        }
      } catch (error) {
        await appAlert('Erro ao deletar cadastro: ' + (error.message || 'falha de conexao'), 'danger', 'Erro');
      }
    }

