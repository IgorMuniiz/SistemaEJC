      `;

      const wrapper = document.createElement('div');
      wrapper.innerHTML = html;
      while (wrapper.firstChild) {
        document.documentElement.appendChild(wrapper.firstChild);
      }

      overlay = document.getElementById('beautiful-dialog-overlay');
      return overlay;
    }

    function showBeautifulDialog({ title, message, isPrompt = false, defaultValue = '', isDanger = false, confirmText = 'OK', cancelText = null }) {
      const overlay = createBeautifulDialog();
      const titleEl = document.getElementById('beautiful-dialog-title');
      const bodyEl = document.getElementById('beautiful-dialog-body');
      const inputWrap = document.getElementById('beautiful-dialog-input-wrap');
      const inputEl = document.getElementById('beautiful-dialog-input');
      const confirmBtn = document.getElementById('beautiful-dialog-confirm');
      const cancelBtn = document.getElementById('beautiful-dialog-cancel');
      const closeBtn = document.getElementById('beautiful-dialog-close');

      if (!overlay || !titleEl || !bodyEl || !inputWrap || !inputEl || !confirmBtn || !cancelBtn || !closeBtn) {
        return Promise.reject(new Error('Dialog elements unavailable'));
      }

      titleEl.textContent = title || 'Aviso';
      bodyEl.textContent = message || '';
      inputEl.value = String(defaultValue || '');

      inputWrap.style.display = isPrompt ? 'block' : 'none';
      cancelBtn.style.display = cancelText ? 'inline-block' : 'none';
      if (cancelText) cancelBtn.textContent = cancelText;
      confirmBtn.textContent = confirmText || 'OK';

      if (isDanger) {
        confirmBtn.classList.add('danger');
      } else {
        confirmBtn.classList.remove('danger');
      }

      overlay.classList.add('visible');
      overlay.setAttribute('aria-hidden', 'false');
      const prevBodyOverflow = document.body.style.overflow;
      document.body.style.overflow = 'hidden';

      if (isPrompt) {
        setTimeout(() => {
          inputEl.focus();
          inputEl.select();
        }, 10);
      }

      return new Promise((resolve) => {
        let settled = false;

        const cleanup = () => {
          if (settled) return;
          settled = true;
          overlay.classList.remove('visible');
          overlay.setAttribute('aria-hidden', 'true');
          document.body.style.overflow = prevBodyOverflow;

          confirmBtn.removeEventListener('click', onConfirm);
          cancelBtn.removeEventListener('click', onCancel);
          closeBtn.removeEventListener('click', onCancel);
          overlay.removeEventListener('click', onOverlayClick);
          document.removeEventListener('keydown', onKeyDown);
        };

        const finish = (value) => {
          cleanup();
          resolve(value);
        };

        const onConfirm = () => finish(isPrompt ? inputEl.value : true);
        const onCancel = () => finish(isPrompt ? null : false);
        const onOverlayClick = (event) => {
          if (event.target === overlay) onCancel();
        };
        const onKeyDown = (event) => {
          if (event.key === 'Escape') {
            onCancel();
            return;
          }
          if (isPrompt && event.key === 'Enter') {
            event.preventDefault();
            onConfirm();
          }
        };

        confirmBtn.addEventListener('click', onConfirm);
        cancelBtn.addEventListener('click', onCancel);
        closeBtn.addEventListener('click', onCancel);
        overlay.addEventListener('click', onOverlayClick);
        document.addEventListener('keydown', onKeyDown);
      });
    }

    // Substituir funções de diálogo
    async function showAlert(message, title = 'Aviso') {
      return showBeautifulDialog({ title, message, isPrompt: false });
    }

    async function showConfirm(message, title = 'Confirmação') {
      return showBeautifulDialog({ title, message, isPrompt: false, cancelText: 'Cancelar' });
    }

    async function showPrompt(message, defaultValue = '', title = 'Digite um valor') {
      return showBeautifulDialog({ title, message, isPrompt: true, defaultValue, confirmText: 'Salvar', cancelText: 'Cancelar' });
    }

    async function showDangerConfirm(message, title = 'Confirmar exclusão') {
      return showBeautifulDialog({ title, message, isPrompt: false, cancelText: 'Cancelar', isDanger: true, confirmText: 'Deletar' });
    }
  </script>
