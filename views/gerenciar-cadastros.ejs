    function toggleSelecionarTodosEncontristas(master, groupName) {
      const checkboxes = Array.from(document.querySelectorAll(`tr[data-transfer-group="${groupName}"] .transfer-encontrista-check`));
      checkboxes.forEach((checkbox) => {
        if (checkbox.closest('tr') && checkbox.closest('tr').style.display === 'none') return;
        checkbox.checked = !!master.checked;
      });
      atualizarTransferenciaLoteUI();
