    function getAbaAtivaId() {
      const ativa = document.querySelector('#cadastroTabs .nav-link.active');
      if (!ativa || !ativa.id || ativa.style.display === 'none') return getPrimeiraAbaDisponivelId();
      return ativa.id.replace(/-tab$/, '');
