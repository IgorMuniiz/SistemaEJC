    function renderVinculadosEquipe() {
      const equipeSelecionada = document.getElementById('visualizar_equipe').value;
      const tabela = document.getElementById('tabela-vinculados-equipe');
      if (!tabela) return;

      const tbody = tabela.querySelector('tbody');
      if (!tbody) return;

      if (!equipeSelecionada) {
        tbody.innerHTML = '<tr><td colspan="4" class="empty-state">Selecione uma equipe para visualizar os vinculados.</td></tr>';
        return;
      }

      const vinculados = (encontreiros || []).filter((pessoa) => {
        const serviu = Array.isArray(pessoa.equipeServiu) && pessoa.equipeServiu.includes(equipeSelecionada);
        const coordenou = Array.isArray(pessoa.equipeCoordenou) && pessoa.equipeCoordenou.includes(equipeSelecionada);
        return serviu || coordenou;
      });

      if (vinculados.length === 0) {
        tbody.innerHTML = '<tr><td colspan="4" class="empty-state">Nenhuma pessoa vinculada nesta equipe.</td></tr>';
        return;
      }

      tbody.innerHTML = vinculados.map((pessoa) => {
        const tipoTxt = pessoa.tipo === 'tios' ? 'Tios' : 'Jovens';
        const serviuTxt = Array.isArray(pessoa.equipeServiu) ? pessoa.equipeServiu.filter((e) => e === equipeSelecionada).join(', ') : '';
        const coordTxt = Array.isArray(pessoa.equipeCoordenou) ? pessoa.equipeCoordenou.filter((e) => e === equipeSelecionada).join(', ') : '';
        return `<tr>
          <td>${pessoa.nomeCompleto || '-'}</td>
          <td>${tipoTxt}</td>
          <td>${serviuTxt || '-'}</td>
          <td>${coordTxt || '-'}</td>
        </tr>`;
      }).join('');
    }

    async function editarAdmin(adminId, username) {
      document.getElementById('edit_admin_id').value = adminId;
      document.getElementById('edit_admin_username').value = username || '';
      document.getElementById('edit_admin_senha').value = '';
      modalEdicaoAdmin.show();
    }

    async function salvarEdicaoAdmin() {
      const adminId = String(document.getElementById('edit_admin_id').value || '').trim();
      const usernameTratado = String(document.getElementById('edit_admin_username').value || '').trim();
      const novaSenha = String(document.getElementById('edit_admin_senha').value || '');

      if (!adminId) {
        await appAlert('Administrador invalido para atualizacao.', 'danger', 'Erro');
        return;
      }

      if (!usernameTratado && !novaSenha) {
        await appAlert('Informe ao menos um campo para atualizar.', 'warning', 'Sem alteracoes');
        return;
      }

      if (novaSenha && novaSenha.length < 6) {
        await appAlert('A nova senha deve ter no minimo 6 caracteres.', 'warning', 'Senha invalida');
        return;
      }

      const payload = {};
      if (usernameTratado) payload.username = usernameTratado;
      if (novaSenha) payload.senha = novaSenha;

      try {
        const response = await fetch(`/admin/atualizar-admin/${encodeURIComponent(adminId)}`, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(payload)
        });
        const result = await response.json();

        if (result.success) {
          await appAlert('Administrador atualizado com sucesso.', 'success', 'Sucesso');
          modalEdicaoAdmin.hide();
          recarregarMantendoAbaAtual();
        } else {
          await appAlert(result.error || 'Erro ao atualizar administrador.', 'danger', 'Erro');
        }
      } catch (error) {
        await appAlert('Erro ao atualizar administrador.', 'danger', 'Erro');
      }
    }

    async function deletarAdmin(adminId, username) {
      if (!await appConfirm(`Tem certeza que deseja deletar o administrador "${username}"? Esta acao nao pode ser desfeita.`, 'Confirmar exclusao')) return;
      
      try {
        const response = await fetch(`/admin/deletar-admin/${adminId}`, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' }
        });
        const result = await response.json();

        if (result.success) {
          await appAlert('Administrador deletado com sucesso.', 'success', 'Sucesso');
          recarregarMantendoAbaAtual();
        } else {
          await appAlert(result.error || 'Erro ao deletar administrador.', 'danger', 'Erro');
        }
      } catch (error) {
        await appAlert('Erro ao deletar administrador.', 'danger', 'Erro');
      }
    }

    function atualizarCamposImportacao() {
      const sourceType = document.getElementById('import_sourceType').value;
      const dbFields = document.getElementById('import_db_fields');
      const fileFields = document.getElementById('import_file_fields');
      const dbEngineEl = document.getElementById('import_dbEngine');
      const dbEngine = dbEngineEl ? dbEngineEl.value : 'mongodb';
      const labelConnection = document.getElementById('import_connection_label');
      const tableLabel = document.getElementById('import_table_label');
      const sqlQueryWrap = document.getElementById('import_sqlquery_wrap');
      const connectionInput = document.getElementById('import_connectionString');
      const tableInput = document.getElementById('import_tableName');

      if (sourceType === 'database') {
        dbFields.style.display = 'flex';
        fileFields.style.display = 'none';

        if (dbEngine === 'mongodb') {
          labelConnection.textContent = 'URI do MongoDB Externo *';
          tableLabel.textContent = 'Colecao de Encontreiros';
          connectionInput.placeholder = 'mongodb+srv://usuario:senha@cluster.exemplo.mongodb.net';
          tableInput.value = tableInput.value || 'Encontro';
          sqlQueryWrap.style.display = 'none';
        } else if (dbEngine === 'postgresql') {
          labelConnection.textContent = 'String de Conexao PostgreSQL *';
          tableLabel.textContent = 'Tabela de Encontreiros';
          connectionInput.placeholder = 'postgresql://usuario:senha@host:5432/banco';
          tableInput.value = tableInput.value || 'encontro';
          sqlQueryWrap.style.display = 'block';
        } else {
          labelConnection.textContent = 'String de Conexao MySQL *';
          tableLabel.textContent = 'Tabela de Encontreiros';
          connectionInput.placeholder = 'mysql://usuario:senha@host:3306/banco';
          tableInput.value = tableInput.value || 'encontro';
          sqlQueryWrap.style.display = 'block';
        }
      } else {
        dbFields.style.display = 'none';
        fileFields.style.display = 'flex';
      }
    }

    async function importarCadastros() {
      const sourceType = document.getElementById('import_sourceType').value;
      const dbEngine = document.getElementById('import_dbEngine').value;
      const connectionString = document.getElementById('import_connectionString').value.trim();
      const databaseName = document.getElementById('import_databaseName').value.trim();
      const tableName = document.getElementById('import_tableName').value.trim() || 'Encontro';
      const sqlQuery = document.getElementById('import_sqlQuery').value.trim();
      const limite = document.getElementById('import_limite').value;
      const atualizarExistentes = document.getElementById('import_atualizarExistentes').checked;
      const arquivoInput = document.getElementById('import_arquivo');
      const fotoPadrao = document.getElementById('import_fotoPadrao').value.trim();
      const resultBox = document.getElementById('import_result');

      resultBox.className = 'import-result';
      resultBox.textContent = '';

      if (sourceType === 'database' && !connectionString) {
        resultBox.className = 'import-result error';
        resultBox.textContent = 'Informe a conexao do banco externo para continuar.';
        return;
      }

      if (sourceType !== 'database' && (!arquivoInput.files || !arquivoInput.files[0])) {
        resultBox.className = 'import-result error';
        resultBox.textContent = 'Selecione um arquivo para importar.';
        return;
      }

      if (!await appConfirm('Deseja iniciar a importacao de encontreiros agora?', 'Confirmar importacao')) return;

      try {
        const formData = new FormData();
        formData.append('sourceType', sourceType);
        formData.append('dbEngine', dbEngine);
        formData.append('connectionString', connectionString);
        formData.append('mongoUri', connectionString);
        formData.append('databaseName', databaseName);
        formData.append('colecaoEncontreiros', tableName);
        formData.append('tableName', tableName);
        formData.append('sqlQuery', sqlQuery);
        formData.append('limite', limite);
        formData.append('atualizarExistentes', atualizarExistentes ? 'true' : 'false');
        formData.append('fotoPadrao', fotoPadrao);

        if (sourceType !== 'database' && arquivoInput.files && arquivoInput.files[0]) {
          formData.append('arquivo', arquivoInput.files[0]);
        }

        const response = await fetch('/admin/importar-cadastros', {
          method: 'POST',
          body: formData
        });

        const responseType = response.headers.get('content-type') || '';
        const isJson = responseType.includes('application/json');
        const result = isJson
          ? await response.json()
          : { success: false, error: await response.text() };

        if (!result.success) {
          resultBox.className = 'import-result error';
          const message = (result.error || 'Erro ao importar encontreiros.').toString();
          resultBox.textContent = message.replace(/<[^>]*>/g, '').slice(0, 300);
          return;
        }

        const s = result.summary;
        const origemLabel = result.sourceType === 'database' ? `${result.sourceType}/${result.dbEngine || dbEngine}` : result.sourceType;
        const totalIgnorados = s.ignoradosExistentes + s.ignoradosSemCampos + s.ignoradosSemFoto + s.ignoradosTipoInvalido;
        const totalPlaceholders = (s.placeholdersNome || 0) + (s.placeholdersEmail || 0);
        const detalhePlaceholders = totalPlaceholders > 0
          ? ` Campos preenchidos automaticamente: ${totalPlaceholders} (nome: ${s.placeholdersNome || 0}, email: ${s.placeholdersEmail || 0}).`
          : '';

        if ((s.importados + s.atualizados) === 0) {
          resultBox.className = 'import-result error';
          resultBox.textContent = `Nenhum cadastro foi salvo (${origemLabel}). Ignorados: ${totalIgnorados}. Verifique os dados do arquivo (tipo/foto/formato).`;
          return;
        }

        resultBox.className = 'import-result success';
        resultBox.textContent = `Importacao concluida (${origemLabel}). Importados: ${s.importados}. Atualizados: ${s.atualizados}. Ignorados: ${totalIgnorados}. Erros: ${s.erros}.${detalhePlaceholders}`;

        setTimeout(() => {
          recarregarMantendoAbaAtual();
        }, 1800);
      } catch (error) {
        resultBox.className = 'import-result error';
        resultBox.textContent = 'Falha ao executar importacao. Verifique o arquivo (formato/tamanho) e tente novamente.';
      }
    }

    async function aprovarCadastro(tipo, id) {
      if (!await appConfirm('Aprovar este cadastro?', 'Confirmar aprovacao')) return;

      try {
        const response = await fetch('/admin/aprovar', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ tipo, id })
        });
        const result = await response.json();

        if (result.success) {
          await appAlert('Cadastro aprovado com sucesso!', 'success', 'Sucesso');
          recarregarMantendoAbaAtual();
        } else {
          await appAlert(result.error || 'Erro ao aprovar.', 'danger', 'Erro');
        }
      } catch (error) {
        await appAlert('Erro ao aprovar cadastro.', 'danger', 'Erro');
      }
    }

    async function reprovarCadastro(tipo, id) {
      if (!await appConfirm('Reprovar este cadastro?', 'Confirmar reprovacao')) return;

      try {
        const response = await fetch('/admin/desaprovar', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ tipo, id })
        });
        const result = await response.json();

        if (result.success) {
          await appAlert('Cadastro reprovado!', 'success', 'Sucesso');
          recarregarMantendoAbaAtual();
        } else {
          await appAlert(result.error || 'Erro ao reprovar.', 'danger', 'Erro');
        }
      } catch (error) {
        await appAlert('Erro ao reprovar cadastro.', 'danger', 'Erro');
      }
    }

    atualizarTransferenciaLoteUI();
    atualizarCamposImportacao();
  </script>
