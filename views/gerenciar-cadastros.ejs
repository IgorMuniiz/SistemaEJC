              <button id="clear-search-tios" type="button" class="btn-clear-search">
                <i class="fas fa-eraser me-1"></i>Limpar busca
              </button>
            </div>

            <div class="admin-form-card admin-config-card manager-status-card manager-status-card-tios">
              <div class="admin-card-head manager-status-card-head">
                <div>
                  <p class="admin-card-kicker">Apoio pastoral</p>
                  <h5><i class="fas fa-heart me-2"></i>Tios cadastrados</h5>
                  <p class="admin-card-subtitle">Visualize os casais e tios solo com um bloco mais limpo, organizado e consistente com o restante da gestão.</p>
                </div>
                <span class="admin-card-badge"><%= tios.length %> cadastros</span>
              </div>
              <div class="table-wrap manager-table-shell">
              <table class="table table-hover">
                <thead>
                  <tr>
                    <th>Foto</th>
                    <th>Nome</th>
                    <th>Categoria</th>
                    <th>EJC</th>
                    <th>Telefone</th>
                    <th>Email</th>
                    <th>Ações</th>
                  </tr>
                </thead>
                <tbody>
                  <% if (tios.length === 0) { %>
                    <tr><td colspan="7" class="empty-state">Nenhum tios cadastrado.</td></tr>
                  <% } else { %>
                    <% tios.forEach(function(cadastro) { %>
                      <tr data-searchable="true">
                        <td>
                          <% if (cadastro.foto) { %>
                            <img src="/img/uploads/<%= encodeURIComponent(cadastro.foto) %>?w=120&h=120&fit=cover&format=webp" loading="lazy" decoding="async" alt="Foto" class="table-photo">
                          <% } else { %>
                            <i class="fas fa-user-circle fa-2x text-secondary"></i>
                          <% } %>
                        </td>
                        <td><%= cadastro.nomeCompleto %></td>
                        <td><%= cadastro.tiosCategoria === 'casal' ? 'Casal' : 'Tio Solo' %></td>
                        <td><%= cadastro.ejc %></td>
                        <td><%= cadastro.telefone %></td>
                        <td><%= cadastro.email %></td>
                        <td>
                          <button class="btn btn-edit" onclick="editarCadastro('encontreiro', '<%= cadastro._id %>')">
                            <i class="fas fa-edit me-1"></i>Editar
                          </button>
                          <button class="btn btn-delete" data-nome="<%= cadastro.nomeCompleto %>" onclick="deletarCadastro('encontreiro', '<%= cadastro._id %>', this.dataset.nome)">
                            <i class="fas fa-trash me-1"></i>Deletar
                          </button>
                        </td>
                      </tr>
                    <% }); %>
                  <% } %>
                </tbody>
              </table>
              </div>
            </div>
          </div>

          <!-- TAB: APROVACOES -->
          <div class="tab-pane fade" id="aprovacoes" data-required-permission="cadastros.aprovar" role="tabpanel">
            <% const encontristasPendentesAprovacoes = (encontristas || []).filter(c => statusCadastroGrupo(c) === 'pendente'); %>
            <% const encontreirosPendentesAprovacoes = (encontreiros || []).filter(c => statusCadastroGrupo(c) === 'pendente'); %>
            <% const totalPendentesAprovacoes = encontristasPendentesAprovacoes.length + encontreirosPendentesAprovacoes.length; %>
            <% const filaCriticaAprovacoes = totalPendentesAprovacoes >= 12; %>
            <% const filaAtencaoAprovacoes = !filaCriticaAprovacoes && totalPendentesAprovacoes >= 6; %>
            <div class="tab-workspace-head approval-workspace-head <%= filaCriticaAprovacoes ? 'approval-queue-critical' : (filaAtencaoAprovacoes ? 'approval-queue-attention' : '') %>">
              <div>
                <p class="tab-kicker">Area Aprovações</p>
                <h5><i class="fas fa-check-circle me-2"></i>Central de Aprovação</h5>
              </div>
              <div class="tab-head-chips">
                <span class="tab-chip">Fila total: <%= totalPendentesAprovacoes %></span>
                <% if (filaCriticaAprovacoes) { %>
                  <span class="tab-chip tab-chip-alert">Fila critica</span>
                <% } else if (filaAtencaoAprovacoes) { %>
                  <span class="tab-chip tab-chip-alert">Fila em atenção</span>
                <% } %>
                <span class="tab-chip tab-chip-pending">Encontristas: <%= encontristasPendentesAprovacoes.length %></span>
                <span class="tab-chip tab-chip-soft">Encontreiros: <%= encontreirosPendentesAprovacoes.length %></span>
              </div>
            </div>

            <div class="approval-overview">
              <article class="approval-metric-card <%= filaCriticaAprovacoes ? 'approval-metric-card-critical' : (filaAtencaoAprovacoes ? 'approval-metric-card-attention' : '') %>">
                <span class="approval-metric-icon approval-metric-icon-pending"><i class="fas fa-hourglass-half"></i></span>
                <div>
                  <span class="approval-metric-label">Aguardando triagem</span>
                  <strong class="approval-metric-value"><%= totalPendentesAprovacoes %></strong>
                  <p class="approval-metric-note">Cadastros prontos para análise manual.</p>
                </div>
              </article>
              <article class="approval-metric-card">
                <span class="approval-metric-icon approval-metric-icon-ok"><i class="fas fa-user"></i></span>
                <div>
                  <span class="approval-metric-label">Encontristas pendentes</span>
                  <strong class="approval-metric-value"><%= encontristasPendentesAprovacoes.length %></strong>
                  <p class="approval-metric-note">Revise dados e libere a participação no encontro.</p>
                </div>
              </article>
              <article class="approval-metric-card">
                <span class="approval-metric-icon approval-metric-icon-info"><i class="fas fa-user-group"></i></span>
                <div>
                  <span class="approval-metric-label">Encontreiros pendentes</span>
                  <strong class="approval-metric-value"><%= encontreirosPendentesAprovacoes.length %></strong>
                  <p class="approval-metric-note">Mantenha a fila organizada por perfil e edição.</p>
                </div>
              </article>
            </div>

            <div class="search-toolbar approval-search-toolbar">
              <div class="search-input-wrap">
                <i class="fas fa-search"></i>
                <input id="search-aprovacoes" class="search-input" type="text" placeholder="Pesquisar aprovações por nome ou EJC">
              </div>
              <button id="clear-search-aprovacoes" type="button" class="btn-clear-search">
                <i class="fas fa-eraser me-1"></i>Limpar busca
              </button>
            </div>

            <section class="approval-section">
              <div class="approval-section-head">
                <div>
                  <p class="approval-section-kicker">Fila principal</p>
                  <h6><i class="fas fa-hourglass-half me-2"></i>Encontristas pendentes de aprovação</h6>
                </div>
                <span class="tab-chip tab-chip-pending">Pendentes: <%= encontristasPendentesAprovacoes.length %></span>
              </div>
            <div class="table-wrap approval-table-wrap">
              <table class="table table-hover">
                <thead>
                  <tr>
                    <th>Foto</th>
                    <th>Nome</th>
                    <th>EJC</th>
                    <th>Telefone</th>
                    <th>Email</th>
                    <th>Ações</th>
                  </tr>
                </thead>
                <tbody>
                  <% if (encontristasPendentesAprovacoes.length === 0) { %>
                    <tr><td colspan="6" class="empty-state">Todos os encontristas estão aprovados!</td></tr>
                  <% } else { %>
                    <% encontristasPendentesAprovacoes.forEach(function(cadastro) { %>
                      <tr data-searchable="true">
                        <td>
                          <% if (cadastro.foto) { %>
                            <img src="/img/uploads/<%= encodeURIComponent(cadastro.foto) %>?w=120&h=120&fit=cover&format=webp" loading="lazy" decoding="async" alt="Foto" class="table-photo">
                          <% } else { %>
                            <i class="fas fa-user-circle fa-2x text-secondary"></i>
                          <% } %>
                        </td>
                        <td><%= cadastro.nomeCompleto %></td>
                        <td><%= cadastro.ejc %></td>
                        <td><%= cadastro.telefone %></td>
                        <td><%= cadastro.email %></td>
                        <td class="approval-actions-cell">
                          <button class="btn btn-approve btn-sm" onclick="aprovarCadastro('encontrista', '<%= cadastro._id %>')">
                            <i class="fas fa-check me-1"></i>Aprovar
                          </button>
                          <button class="btn btn-reject btn-sm" onclick="reprovarCadastro('encontrista', '<%= cadastro._id %>')">
                            <i class="fas fa-times me-1"></i>Reprovar
                          </button>
                        </td>
                      </tr>
                    <% }); %>
                  <% } %>
                </tbody>
              </table>
            </div>
            </section>

            <section class="approval-section">
              <div class="approval-section-head">
                <div>
                  <p class="approval-section-kicker">Fila de serviço</p>
                  <h6><i class="fas fa-hourglass-half me-2"></i>Encontreiros pendentes de aprovação</h6>
                </div>
                <span class="tab-chip tab-chip-soft">Pendentes: <%= encontreirosPendentesAprovacoes.length %></span>
              </div>
            <div class="table-wrap approval-table-wrap">
              <table class="table table-hover">
                <thead>
                  <tr>
                    <th>Foto</th>
                    <th>Nome</th>
                    <th>Tipo</th>
                    <th>EJC</th>
                    <th>Telefone</th>
                    <th>Email</th>
                    <th>Ações</th>
                  </tr>
                </thead>
                <tbody>
                  <% if (encontreirosPendentesAprovacoes.length === 0) { %>
                    <tr><td colspan="7" class="empty-state">Todos os encontreiros estão aprovados!</td></tr>
                  <% } else { %>
                    <% encontreirosPendentesAprovacoes.forEach(function(cadastro) { %>
                      <tr data-searchable="true">
                        <td>
                          <% if (cadastro.foto) { %>
                            <img src="/img/uploads/<%= encodeURIComponent(cadastro.foto) %>?w=120&h=120&fit=cover&format=webp" loading="lazy" decoding="async" alt="Foto" class="table-photo">
                          <% } else { %>
                            <i class="fas fa-user-circle fa-2x text-secondary"></i>
                          <% } %>
                        </td>
                        <td><%= cadastro.nomeCompleto %></td>
                        <td>
                          <% if (cadastro.tipo !== 'tios') { %>
                            <i class="fas fa-users text-primary"></i> Jovens
                          <% } else { %>
                            <i class="fas fa-heart text-danger"></i> Tios <%= cadastro.tiosCategoria === 'casal' ? '(Casal)' : '(Solo)' %>
                          <% } %>
                        </td>
                        <td><%= cadastro.ejc %></td>
                        <td><%= cadastro.telefone %></td>
                        <td><%= cadastro.email %></td>
                        <td class="approval-actions-cell">
                          <button class="btn btn-approve btn-sm" onclick="aprovarCadastro('encontreiro', '<%= cadastro._id %>')">
                            <i class="fas fa-check me-1"></i>Aprovar
                          </button>
                          <button class="btn btn-reject btn-sm" onclick="reprovarCadastro('encontreiro', '<%= cadastro._id %>')">
                            <i class="fas fa-times me-1"></i>Reprovar
                          </button>
                        </td>
                      </tr>
                    <% }); %>
                  <% } %>
                </tbody>
              </table>
            </div>
            </section>
          </div>

          <!-- TAB: ENCONTROS -->
          <div class="tab-pane fade" id="encontros" data-required-permission="encontros.gerenciar" role="tabpanel">
            <div class="tab-workspace-head">
              <div>
                <p class="tab-kicker">Area Encontros</p>
                <h5><i class="fas fa-calendar-days me-2"></i>Gestao de Encontros</h5>
              </div>
              <div class="tab-head-chips">
                <span class="tab-chip">EJCs: <%= (ejcs || []).length %></span>
                <span class="tab-chip tab-chip-soft">Acesso e criacao rapidos</span>
              </div>
            </div>
            <div class="admin-form-card">
              <h5 class="mb-3"><i class="fas fa-location-arrow me-2"></i>Selecionar EJC</h5>
              <div class="row g-3 ejc-row">
                <div class="col-lg-9 col-md-8">
                  <label for="seletor_ejc_pagina" class="form-label">EJC disponível</label>
                  <select id="seletor_ejc_pagina" class="form-select">
                    <option value="">Selecione um EJC</option>
                    <% (ejcs || []).forEach(function(item) { %>
                      <option value="<%= item._id %>" <%= item.ativo ? 'selected' : '' %>><%= item.nome %><%= item.ativo ? ' (Ativo)' : '' %></option>
                    <% }); %>
                  </select>
                </div>
                <div class="col-lg-3 col-md-4 d-flex align-items-end ejc-action-col">
                  <button type="button" class="btn btn-primary w-100 btn-ejc-action" onclick="abrirPaginaEjc()">
                    <i class="fas fa-arrow-right me-1"></i>Acessar EJC
                  </button>
                </div>
              </div>
            </div>

            <div class="admin-form-card">
              <h5 class="mb-3"><i class="fas fa-plus-circle me-2"></i>Criar EJC</h5>
              <form id="formEjc" class="row g-3 ejc-row">
                <div class="col-lg-9 col-md-8">
                  <label for="ejc_nome" class="form-label">Nome do EJC *</label>
                  <input type="text" id="ejc_nome" class="form-control" placeholder="Ex: EJC São José" required>
                </div>
                <div class="col-lg-3 col-md-4 d-flex align-items-end ejc-action-col">
                  <button type="button" class="btn btn-primary w-100 btn-ejc-action" onclick="criarEjc()">
                    <i class="fas fa-save me-1"></i>Criar
                  </button>
                </div>
              </form>
            </div>

            <div class="admin-form-card mb-3">
              <div class="d-flex flex-wrap align-items-center justify-content-between gap-2">
                <h5 class="mb-0"><i class="fas fa-bullseye me-2"></i>Encontro Ativo</h5>
                <% if (encontroAtivoNome) { %>
                  <span class="status-badge status-ok"><%= encontroAtivoNome %></span>
                <% } else { %>
                  <span class="status-badge">Nenhum encontro ativo definido</span>
                <% } %>
              </div>
              <p class="text-muted mb-0 mt-2">Novas inscricoes sao vinculadas automaticamente ao encontro ativo.</p>
            </div>

            <div class="table-wrap mb-3">
              <table class="table table-hover">
                <thead>
                  <tr>
                    <th>Nome do EJC</th>
                    <th>Status</th>
                    <th>Data de Criação</th>
                    <th>Ações</th>
                  </tr>
                </thead>
                <tbody>
                  <% if (!ejcs || ejcs.length === 0) { %>
                    <tr><td colspan="4" class="empty-state">Nenhum EJC cadastrado.</td></tr>
                  <% } else { %>
                    <% ejcs.forEach(function(item) { %>
                      <tr>
                        <td><strong><%= item.nome %></strong></td>
                        <td>
                          <% if (item.ativo) { %>
                            <span class="status-badge status-ok has-led"><span class="status-led-dot is-active" aria-hidden="true"></span>Ativo</span>
                          <% } else { %>
                            <span class="status-badge has-led"><span class="status-led-dot is-inactive" aria-hidden="true"></span>Inativo</span>
                          <% } %>
                        </td>
                        <td><%= new Date(item.dataCriacao).toLocaleDateString('pt-BR') %></td>
                        <td>
                          <button class="btn btn-edit btn-ejc-state <%= item.ativo ? 'is-active' : 'is-inactive' %>" onclick="definirEjcAtivo('<%= item._id %>', '<%= item.nome.replace(/'/g, "\\'") %>')" <%= item.ativo ? 'disabled' : '' %>>
                            <span class="ejc-led-dot" aria-hidden="true"></span>
                            <%= item.ativo ? 'Encontro ativo' : 'Definir como ativo' %>
                          </button>
                          <button class="btn btn-delete" onclick="deletarEjc('<%= item._id %>', '<%= item.nome.replace(/'/g, "\\'") %>')">
                            <i class="fas fa-trash me-1"></i>Excluir Encontro
                          </button>
                        </td>
                      </tr>
                    <% }); %>
                  <% } %>
                </tbody>
              </table>
            </div>
          </div>

          <!-- TAB: ADMINISTRADORES -->
          <div class="tab-pane fade" id="admins" data-required-permission="admins.gerenciar" role="tabpanel">
            <div class="tab-workspace-head">
              <div>
                <p class="tab-kicker">Area Administradores</p>
                <h5><i class="fas fa-user-shield me-2"></i>Gestao de Administradores e Importacao</h5>
              </div>
              <div class="tab-head-chips">
                <span class="tab-chip">Admins: <%= (administradores || []).length %></span>
                <span class="tab-chip tab-chip-soft">Importacao segura</span>
              </div>
            </div>
            <div class="admin-form-card admin-config-card admin-block-card" data-required-permission="bloqueio.gerenciar">
              <div class="admin-card-head">
                <div>
                  <p class="admin-card-kicker">Disponibilidade</p>
                  <h5><i class="fas fa-ban me-2"></i>Controle de Formulários</h5>
                  <p class="admin-card-subtitle">Gerencie bloqueios temporários com período e mensagem exibida ao usuário final.</p>
                </div>
                <span class="admin-card-badge">Bloqueio temporário</span>
              </div>
              <div class="row g-3 admin-block-grid">
                <!-- Controle encontrista -->
                <div class="col-md-6">
                  <div class="card border-light admin-mini-panel admin-mini-panel-encontrista">
                    <div class="card-body">
                      <div class="admin-mini-panel-head">
                        <div>
                          <h6 class="card-title mb-1"><i class="fas fa-user-graduate me-2"></i>Formulário Encontrista</h6>
                          <p class="admin-mini-panel-subtitle">Controle de abertura, período e justificativa para inscrições de encontristas.</p>
                        </div>
                      </div>
                      <div class="form-check form-switch mb-3 admin-switch-row">
                        <input class="form-check-input" type="checkbox" id="bloquear_encontrista" onchange="atualizarCamposEncontrista()">
                        <label class="form-check-label" for="bloquear_encontrista">
                          Bloquear formulário encontrista
                        </label>
                      </div>
                      <div id="campos-encontrista" style="display:none;" class="row g-2 admin-block-fields">
                        <div class="col-12">
                          <label class="form-label">Data/Hora de Início (opcional)</label>
                          <input type="datetime-local" id="data_inicio_encontrista" class="form-control">
                          <small class="text-muted">Deixe em branco para bloquear imediatamente</small>
                        </div>
                        <div class="col-12">
                          <label class="form-label">Data/Hora de Término (opcional)</label>
                          <input type="datetime-local" id="data_fim_encontrista" class="form-control">
                          <small class="text-muted">Deixe em branco para bloqueio indefinido</small>
                        </div>
                        <div class="col-12">
                          <label class="form-label">Motivo (para exibir ao usuário)</label>
                          <textarea id="motivo_encontrista" class="form-control" rows="2" placeholder="Ex: Inscrições encerradas para esta etapa"></textarea>
                        </div>
                      </div>
                    </div>
                  </div>
                </div>

                <!-- Controle encontreiro -->
                <div class="col-md-6">
                  <div class="card border-light admin-mini-panel admin-mini-panel-encontreiros">
                    <div class="card-body">
                      <div class="admin-mini-panel-head">
                        <div>
                          <h6 class="card-title mb-1"><i class="fas fa-users me-2"></i>Formulário Encontreiros</h6>
                          <p class="admin-mini-panel-subtitle">Defina janelas de bloqueio e observações para o formulário de encontreiros.</p>
                        </div>
                      </div>
                      <div class="form-check form-switch mb-3 admin-switch-row">
                        <input class="form-check-input" type="checkbox" id="bloquear_encontreiros" onchange="atualizarCamposEncontreiros()">
                        <label class="form-check-label" for="bloquear_encontreiros">
                          Bloquear formulário encontreiros
                        </label>
                      </div>
                      <div id="campos-encontreiros" style="display:none;" class="row g-2 admin-block-fields">
                        <div class="col-12">
                          <label class="form-label">Data/Hora de Início (opcional)</label>
                          <input type="datetime-local" id="data_inicio_encontreiros" class="form-control">
                          <small class="text-muted">Deixe em branco para bloquear imediatamente</small>
                        </div>
                        <div class="col-12">
                          <label class="form-label">Data/Hora de Término (opcional)</label>
                          <input type="datetime-local" id="data_fim_encontreiros" class="form-control">
                          <small class="text-muted">Deixe em branco para bloqueio indefinido</small>
                        </div>
                        <div class="col-12">
                          <label class="form-label">Motivo (para exibir ao usuário)</label>
                          <textarea id="motivo_encontreiros" class="form-control" rows="2" placeholder="Ex: Inscrições encerradas para esta etapa"></textarea>
                        </div>
                      </div>
                    </div>
                  </div>
                </div>

                <div class="col-12">
                  <button type="button" class="btn btn-primary w-100 admin-primary-action" onclick="salvarConfiguracoesBloqueio()">
                    <i class="fas fa-save me-1"></i>Salvar Configurações de Bloqueio
                  </button>
                </div>
              </div>
              <div id="bloqueio-resultado" class="mt-3"></div>
            </div>

            <div class="admin-form-card admin-config-card admin-import-card" data-required-permission="importacao.executar">
              <div class="admin-card-head">
                <div>
                  <p class="admin-card-kicker">Integração</p>
                  <h5><i class="fas fa-file-import me-2"></i>Importar Apenas Encontreiros</h5>
                  <p class="admin-card-subtitle">Traga dados externos com mais segurança, padronização e controle de volume.</p>
                </div>
                <span class="admin-card-badge">Importação segura</span>
              </div>
              <form id="formImportacao" class="row g-3">
                <div class="col-md-4">
                  <label class="form-label">Origem da Importacao *</label>
                  <select id="import_sourceType" class="form-select" onchange="atualizarCamposImportacao()">
                    <option value="database">Link direto do banco</option>
                    <option value="excel">Arquivo Excel</option>
                    <option value="pdf">Arquivo PDF</option>
                  </select>
                </div>

                <div class="col-md-4">
                  <label class="form-label">Limite de Registros</label>
                  <input type="number" id="import_limite" class="form-control" value="1000" min="1" max="5000">
                </div>

                <div id="import_db_fields" class="row g-3 m-0 p-0">
                  <div class="col-md-4">
                    <label class="form-label">Banco de Origem *</label>
                    <select id="import_dbEngine" class="form-select" onchange="atualizarCamposImportacao()">
                      <option value="mongodb">MongoDB</option>
                      <option value="postgresql">PostgreSQL</option>
                      <option value="mysql">MySQL</option>
                    </select>
                  </div>
                  <div class="col-12">
                    <label class="form-label" id="import_connection_label">Conexao do Banco Externo *</label>
                    <input type="text" id="import_connectionString" class="form-control" placeholder="mongodb+srv://usuario:senha@cluster.exemplo.mongodb.net">
                  </div>
                  <div class="col-md-6">
                    <label class="form-label">Nome do Banco (opcional)</label>
                    <input type="text" id="import_databaseName" class="form-control" placeholder="nome_do_banco">
                  </div>
                  <div class="col-md-6">
                    <label class="form-label" id="import_table_label">Colecao/Tabela de Encontreiros</label>
                    <input type="text" id="import_tableName" class="form-control" value="Encontro">
                  </div>
