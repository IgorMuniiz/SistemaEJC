        await appAlert('Erro ao reprovar cadastro.', 'danger', 'Erro');
      }
    }

    async function executarRetencaoLgpd() {
      if (!ensurePermission('lgpd.executar')) return;
      const days = document.getElementById('lgpd_retencao_dias').value;
      if (!await appConfirm('Executar agora a política de retenção LGPD?', 'Confirmar retenção')) return;

      try {
        const response = await fetch('/admin/executar-retencao-lgpd', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ days })
        });
        const result = await response.json();

        if (!result.success) {
          await appAlert(result.error || 'Erro ao executar política LGPD.', 'danger', 'Erro');
          return;
        }

        const r = result.result || {};
        await appAlert(
          `Retenção concluída.\n\nCadastros anonimizados: ${r.cadastrosAnonimizados || 0}\nEncontros anonimizados: ${r.encontrosAnonimizados || 0}\nTotal: ${r.totalAnonimizados || 0}`,
          'success',
          'LGPD'
        );
        recarregarMantendoAbaAtual();
      } catch (error) {
        await appAlert('Erro ao executar retenção LGPD.', 'danger', 'Erro');
      }
    }

    atualizarTransferenciaLoteUI();
    atualizarCamposImportacao();

    // Funções para Bloqueio de Formulários
    async function carregarConfiguracoesBloqueio() {
      if (!hasPermission('bloqueio.gerenciar')) return;
      try {
        console.log('[BLOQUEIO-UI] Carregando configurações...');
        const response = await fetch('/admin/config-bloqueio');
        const data = await response.json();
        
        console.log('[BLOQUEIO-UI] Dados recebidos:', data);
        
        if (data.success) {
          // Atualizar encontrista
          document.getElementById('bloquear_encontrista').checked = data.bloquearEncontrista === true;
          document.getElementById('data_inicio_encontrista').value = data.dataInicioEncontrista 
            ? new Date(data.dataInicioEncontrista).toISOString().slice(0, 16)
            : '';
          document.getElementById('data_fim_encontrista').value = data.dataFimEncontrista
            ? new Date(data.dataFimEncontrista).toISOString().slice(0, 16)
            : '';
          document.getElementById('motivo_encontrista').value = data.motivoEncontrista || '';
          
          // Atualizar encontreiros
          document.getElementById('bloquear_encontreiros').checked = data.bloquearEncontreiros === true;
          document.getElementById('data_inicio_encontreiros').value = data.dataInicioEncontreiros
            ? new Date(data.dataInicioEncontreiros).toISOString().slice(0, 16)
            : '';
          document.getElementById('data_fim_encontreiros').value = data.dataFimEncontreiros
            ? new Date(data.dataFimEncontreiros).toISOString().slice(0, 16)
            : '';
          document.getElementById('motivo_encontreiros').value = data.motivoEncontreiros || '';

          // Atualizar visibilidade dos campos
          atualizarCamposEncontrista();
          atualizarCamposEncontreiros();
          
          console.log('[BLOQUEIO-UI] Configurações carregadas com sucesso');
        }
      } catch (error) {
        console.error('Erro ao carregar configurações de bloqueio:', error);
      }
    }

    function atualizarCamposEncontrista() {
      const checked = document.getElementById('bloquear_encontrista')?.checked || false;
      const camposDiv = document.getElementById('campos-encontrista');
      if (camposDiv) {
        camposDiv.style.display = checked ? 'flex' : 'none';
      }
    }

    function atualizarCamposEncontreiros() {
      const checked = document.getElementById('bloquear_encontreiros')?.checked || false;
      const camposDiv = document.getElementById('campos-encontreiros');
      if (camposDiv) {
        camposDiv.style.display = checked ? 'flex' : 'none';
      }
    }

    function setupEventScopeControls() {
      const buttons = Array.from(document.querySelectorAll('.event-scope-btn[data-event-scope]'));
      if (buttons.length === 0) return;

      buttons.forEach((button) => {
        button.addEventListener('click', async () => {
          const nextScope = button.dataset.eventScope === 'todos' ? 'todos' : 'ativo';

          buttons.forEach((btn) => {
            const isActive = btn === button;
            btn.classList.toggle('active', isActive);
            btn.setAttribute('aria-pressed', String(isActive));
            btn.disabled = true;
          });

          try {
            const response = await fetch('/admin/evento-scope', {
              method: 'POST',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify({ scope: nextScope }),
            });

            const result = await response.json();
            if (!response.ok || !result.success) {
              throw new Error(result.error || 'Falha ao atualizar escopo de evento.');
            }

            window.location.reload();
          } catch (error) {
            buttons.forEach((btn) => {
              btn.disabled = false;
            });
            appAlert('Erro: ' + (error.message || 'Falha ao trocar escopo.'), 'danger', 'Escopo de evento');
          }
        });
      });
    }

    async function salvarConfiguracoesBloqueio() {
      if (!ensurePermission('bloqueio.gerenciar')) return;
      try {
        const payload = {
          bloquearEncontrista: document.getElementById('bloquear_encontrista').checked,
          bloquearEncontreiros: document.getElementById('bloquear_encontreiros').checked,
          dataInicioEncontrista: document.getElementById('data_inicio_encontrista').value || '',
          dataFimEncontrista: document.getElementById('data_fim_encontrista').value || '',
          dataInicioEncontreiros: document.getElementById('data_inicio_encontreiros').value || '',
          dataFimEncontreiros: document.getElementById('data_fim_encontreiros').value || '',
          motivoEncontrista: document.getElementById('motivo_encontrista').value || '',
          motivoEncontreiros: document.getElementById('motivo_encontreiros').value || '',
        };

        console.log('[BLOQUEIO-UI] Salvando:', payload);

        const response = await fetch('/admin/atualizar-config-bloqueio', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(payload),
        });

        const data = await response.json();
        const resultDiv = document.getElementById('bloqueio-resultado');
        
        console.log('[BLOQUEIO-UI] Resposta do servidor:', data);
        
        if (data.success) {
          resultDiv.innerHTML = '<div class="alert alert-success" role="alert"><i class="fas fa-check-circle me-2"></i>Configurações salvas com sucesso!</div>';
          setTimeout(() => { resultDiv.innerHTML = ''; }, 3000);
        } else {
          resultDiv.innerHTML = '<div class="alert alert-danger" role="alert"><i class="fas fa-exclamation-triangle me-2"></i>Erro ao salvar: ' + (data.error || 'Desconhecido') + '</div>';
        }
      } catch (error) {
        console.error('Erro ao salvar configurações:', error);
        document.getElementById('bloqueio-resultado').innerHTML = '<div class="alert alert-danger" role="alert"><i class="fas fa-exclamation-triangle me-2"></i>Erro na requisição</div>';
      }
    }

    // Carregar configurações sempre que a página iniciar (independente da aba ativa)
    applyRoleDefaultPermissions('admin_nivel', '#admin_permissions .admin-perm-item');
    const adminNivelNode = document.getElementById('admin_nivel');
    if (adminNivelNode) {
      adminNivelNode.addEventListener('change', () => {
        applyRoleDefaultPermissions('admin_nivel', '#admin_permissions .admin-perm-item');
      });
    }

    setupEventScopeControls();

    carregarConfiguracoesBloqueio();

    // Recarregar quando a aba de admins for clicada (garante atualização ao trocar de aba)
    const adminsTab = document.getElementById('admins-tab') || document.querySelector('[data-bs-target="#admins"]');
    if (adminsTab) {
      adminsTab.addEventListener('shown.bs.tab', function() {
        carregarConfiguracoesBloqueio();
      });
    }

    document.addEventListener('click', (event) => {
      const editBtn = event.target.closest('.js-edit-admin');
      if (editBtn) {
        event.preventDefault();
        editarAdmin(editBtn.getAttribute('data-admin-id'));
        return;
      }

      const deleteBtn = event.target.closest('.js-delete-admin');
      if (deleteBtn) {
        event.preventDefault();
        deletarAdmin(deleteBtn.getAttribute('data-admin-id'));
      }
    });

    // ===== MODAL CUSTOMIZADO BONITO E RESPONSIVO =====
    function createBeautifulDialog() {
      let overlay = document.getElementById('beautiful-dialog-overlay');
      if (overlay) return overlay;

      const html = `
        <style id="beautiful-dialog-style">
          @keyframes dialog-pop-in {
            from {
              opacity: 0;
              transform: translateY(22px) scale(0.98);
            }
            to {
              opacity: 1;
              transform: translateY(0) scale(1);
            }
          }

          #beautiful-dialog-overlay {
            position: fixed;
            top: 0;
            left: 0;
            width: 100vw;
            height: 100vh;
            z-index: 30000;
            display: none;
            align-items: center;
            justify-content: center;
            padding: 12px;
            box-sizing: border-box;
            background: rgba(7, 12, 24, 0.72);
            backdrop-filter: blur(6px);
          }

          #beautiful-dialog-overlay.visible {
            display: flex;
          }

          #beautiful-dialog-card {
            width: min(560px, calc(100vw - 24px));
            max-height: calc(100vh - 24px);
            margin: auto;
            background: #0f1627;
            border: 1px solid rgba(137, 160, 255, 0.25);
            border-radius: 16px;
            box-shadow: 0 30px 90px rgba(0, 0, 0, 0.48);
            overflow: hidden;
            display: flex;
            flex-direction: column;
            animation: dialog-pop-in 0.22s ease-out;
          }

          #beautiful-dialog-header {
            background: linear-gradient(135deg, #2b4ad9 0%, #6a4bc0 100%);
            color: #f8fbff;
            padding: 18px 20px;
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 16px;
          }

          #beautiful-dialog-title {
            margin: 0;
            font-size: 1.35rem;
            font-weight: 700;
          }

          #beautiful-dialog-close {
            background: transparent;
            color: #e8eeff;
            border: none;
            font-size: 30px;
            line-height: 1;
            cursor: pointer;
            opacity: 0.9;
            padding: 0;
            width: 34px;
            height: 34px;
          }

          #beautiful-dialog-close:hover {
            opacity: 1;
          }

          #beautiful-dialog-body {
            padding: 22px 20px 14px;
            color: #e6eeff;
            font-size: 1.08rem;
            line-height: 1.6;
            background: #0f1627;
            overflow-y: auto;
          }

          #beautiful-dialog-input-wrap {
            padding: 0 20px 14px;
            background: #0f1627;
            display: none;
          }

          #beautiful-dialog-input {
            width: 100%;
            border: 1px solid rgba(126, 156, 255, 0.38);
            background: #0b1322;
            color: #f4f7ff;
            border-radius: 12px;
            padding: 12px 14px;
            font-size: 1.05rem;
            outline: none;
          }

          #beautiful-dialog-input:focus {
            border-color: #8ea7ff;
            box-shadow: 0 0 0 4px rgba(97, 125, 255, 0.22);
          }

          #beautiful-dialog-footer {
            padding: 16px 20px 20px;
            background: #0f1627;
            display: flex;
            gap: 10px;
            justify-content: flex-end;
            flex-wrap: wrap;
            border-top: 1px solid rgba(137, 160, 255, 0.2);
          }

          .beautiful-dialog-btn {
            border: none;
            border-radius: 10px;
            font-weight: 700;
            font-size: 1rem;
            padding: 10px 20px;
            cursor: pointer;
            min-width: 110px;
          }

          #beautiful-dialog-cancel {
            background: #121a2c;
            color: #dce7ff;
            border: 1px solid rgba(143, 166, 255, 0.35);
            display: none;
          }

          #beautiful-dialog-confirm {
            background: linear-gradient(135deg, #5176ff 0%, #8057d8 100%);
            color: #ffffff;
            box-shadow: 0 10px 22px rgba(76, 110, 255, 0.36);
          }

          #beautiful-dialog-confirm.danger {
            background: linear-gradient(135deg, #e45a6a 0%, #b73b53 100%);
            box-shadow: 0 10px 22px rgba(228, 90, 106, 0.34);
          }

          @media (max-width: 640px) {
            #beautiful-dialog-card {
              width: calc(100vw - 16px);
              max-height: calc(100vh - 16px);
            }

            #beautiful-dialog-title {
              font-size: 1.15rem;
            }

            #beautiful-dialog-body {
              font-size: 1rem;
            }

            .beautiful-dialog-btn {
              flex: 1;
              min-width: 96px;
            }
          }
        </style>

        <div id="beautiful-dialog-overlay" aria-hidden="true">
          <div id="beautiful-dialog-card" role="dialog" aria-modal="true" aria-labelledby="beautiful-dialog-title">
            <div id="beautiful-dialog-header">
              <h3 id="beautiful-dialog-title">Aviso</h3>
              <button type="button" id="beautiful-dialog-close" aria-label="Fechar">×</button>
            </div>
            <div id="beautiful-dialog-body"></div>
            <div id="beautiful-dialog-input-wrap">
              <input type="text" id="beautiful-dialog-input" autocomplete="off" />
            </div>
            <div id="beautiful-dialog-footer">
              <button type="button" id="beautiful-dialog-cancel" class="beautiful-dialog-btn">Cancelar</button>
