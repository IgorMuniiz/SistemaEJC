    function normalizeSearchText(value) {
      return String(value || '')
        .toLowerCase()
        .normalize('NFD')
        .replace(/[\u0300-\u036f]/g, '');
    }

    function filtrarTabela(table, query) {
      if (!table) return;

      const tbody = table.querySelector('tbody');
      if (!tbody) return;

      const rows = Array.from(tbody.querySelectorAll('tr[data-searchable="true"]'));
      if (rows.length === 0) return;

      const headers = Array.from(table.querySelectorAll('thead th')).map((th) => normalizeSearchText(th.textContent));
      const idxNome = headers.findIndex((h) => h === 'nome');
      const idxEjc = headers.findIndex((h) => h === 'ejc');

      let visiveis = 0;

      rows.forEach((row) => {
        const cells = Array.from(row.querySelectorAll('td'));
        const nomeText = idxNome >= 0 && cells[idxNome] ? cells[idxNome].textContent : '';
        const ejcText = idxEjc >= 0 && cells[idxEjc] ? cells[idxEjc].textContent : '';
        const texto = normalizeSearchText(`${nomeText} ${ejcText}`);
        const corresponde = !query || texto.includes(query);
        row.style.display = corresponde ? '' : 'none';
        if (corresponde) visiveis += 1;
      });

      let noResults = tbody.querySelector('.search-empty-row');

      if (query && visiveis === 0) {
        if (!noResults) {
          noResults = document.createElement('tr');
          noResults.className = 'search-empty-row';

          const cell = document.createElement('td');
          const colCount = table.querySelectorAll('thead th').length || 1;
          cell.colSpan = colCount;
          cell.textContent = 'Nenhum cadastro encontrado para a pesquisa.';
          noResults.appendChild(cell);
          tbody.appendChild(noResults);
        }
      } else if (noResults) {
        noResults.remove();
      }
    }

    function configurarPesquisaPorAba(inputId, tabSelector) {
      const input = document.getElementById(inputId);
      const tab = document.querySelector(tabSelector);
      if (!input || !tab) return;

      const tables = Array.from(tab.querySelectorAll('.table-wrap table'));

      const applyFilter = () => {
        const query = normalizeSearchText(input.value.trim());
        tables.forEach((table) => filtrarTabela(table, query));
      };

      input.addEventListener('input', applyFilter);
    }

    function configurarBotaoLimparBusca(inputId, buttonId) {
      const input = document.getElementById(inputId);
      const button = document.getElementById(buttonId);
      if (!input || !button) return;

      button.addEventListener('click', () => {
        input.value = '';
        input.dispatchEvent(new Event('input'));
        input.focus();
      });
    }

