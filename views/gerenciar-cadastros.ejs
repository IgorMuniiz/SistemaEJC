    function initSidebarDockGlow() {
      const sidebar = document.querySelector('.admin-shell .sidebar');
      if (!sidebar) return;

      const supportsFinePointer = window.matchMedia('(hover: hover) and (pointer: fine)').matches;
      const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
      if (!supportsFinePointer || prefersReducedMotion) return;

      const updateGlowPosition = (event) => {
        const rect = sidebar.getBoundingClientRect();
        if (!rect.width || !rect.height) return;
        const x = ((event.clientX - rect.left) / rect.width) * 100;
        const y = ((event.clientY - rect.top) / rect.height) * 100;
        sidebar.style.setProperty('--dock-glow-x', `${Math.max(0, Math.min(100, x)).toFixed(2)}%`);
        sidebar.style.setProperty('--dock-glow-y', `${Math.max(0, Math.min(100, y)).toFixed(2)}%`);
      };

      sidebar.addEventListener('mouseenter', (event) => {
        updateGlowPosition(event);
        sidebar.classList.add('is-dock-glow');
      });

      sidebar.addEventListener('mousemove', updateGlowPosition);

      sidebar.addEventListener('mouseleave', () => {
        sidebar.classList.remove('is-dock-glow');
      });
    }

