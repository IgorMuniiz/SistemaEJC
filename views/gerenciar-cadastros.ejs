<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="description" content="Painel de gestao de cadastros do EJC COP com controle de encontristas, encontreiros, tios, encontros e administradores.">
  <title>Painel Administrativo - EJC COP</title>
  <link rel="preload" href="/vendor/bootstrap/css/bootstrap.min.css" as="style" onload="this.onload=null;this.rel='stylesheet'">
  <noscript><link rel="stylesheet" href="/vendor/bootstrap/css/bootstrap.min.css"></noscript>
  <link rel="preload" href="/vendor/fontawesome/css/all.min.css" as="style" onload="this.onload=null;this.rel='stylesheet'">
  <noscript><link rel="stylesheet" href="/vendor/fontawesome/css/all.min.css"></noscript>
  <link rel="stylesheet" href="/css/admin-saas.css">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Manrope:wght@400;500;600;700;800&family=Sora:wght@500;600;700&display=swap" rel="stylesheet">
</head>
<body class="admin-panel admin-manager-page admin-manager-revamp">
  <% const encontreirosIndividuais = (encontreiros || []).filter(function(c){ return c.tipo !== 'tios'; }); %>
  <% const tios = (encontreiros || []).filter(function(c){ return c.tipo === 'tios'; }); %>
  <% const statusCadastroRaw = function(c){
    if (c && c.statusAprovacao) return c.statusAprovacao;
    if (c && c.aprovado) return 'aprovado';
    return 'pendente';
  }; %>
  <% const statusCadastroGrupo = function(c){
    const raw = statusCadastroRaw(c);
    if (raw === 'aprovado') return 'aprovado';
    if (raw === 'reprovado' || raw === 'desistiu') return 'reprovado';
    return 'pendente';
  }; %>
  <% const encontristasAprovados = (encontristas || []).filter(function(c){ return statusCadastroGrupo(c) === 'aprovado'; }); %>
  <% const encontristasReprovados = (encontristas || []).filter(function(c){ return statusCadastroGrupo(c) === 'reprovado'; }); %>
  <% const encontristasPendentes = (encontristas || []).filter(function(c){ return statusCadastroGrupo(c) === 'pendente'; }); %>
  <% const encontreirosAprovados = (encontreirosIndividuais || []).filter(function(c){ return statusCadastroGrupo(c) === 'aprovado'; }); %>
  <% const encontreirosReprovados = (encontreirosIndividuais || []).filter(function(c){ return statusCadastroGrupo(c) === 'reprovado'; }); %>
  <% const encontreirosPendentes = (encontreirosIndividuais || []).filter(function(c){ return statusCadastroGrupo(c) === 'pendente'; }); %>
  <% const tiosAprovados = (tios || []).filter(function(c){ return statusCadastroGrupo(c) === 'aprovado'; }); %>
  <% const tiosReprovados = (tios || []).filter(function(c){ return statusCadastroGrupo(c) === 'reprovado'; }); %>
  <% const tiosPendentes = (tios || []).filter(function(c){ return statusCadastroGrupo(c) === 'pendente'; }); %>
  <% const totalCadastrosVisiveis = (encontristas || []).length + (encontreirosIndividuais || []).length + (tios || []).length; %>
  <% const totalPendencias = (encontristasPendentes || []).length + (encontreirosPendentes || []).length; %>
  <% const totalAprovadosGeral = (encontristasAprovados || []).length + (encontreirosAprovados || []).length + (tiosAprovados || []).length; %>
  <% const totalReprovadosGeral = (encontristasReprovados || []).length + (encontreirosReprovados || []).length + (tiosReprovados || []).length; %>
  <% const totalPendenciasGeral = (encontristasPendentes || []).length + (encontreirosPendentes || []).length + (tiosPendentes || []).length; %>
  <% const taxaAprovacaoGeral = totalCadastrosVisiveis ? Math.round((totalAprovadosGeral / totalCadastrosVisiveis) * 100) : 0; %>
  <% const taxaPendenciaGeral = totalCadastrosVisiveis ? Math.round((totalPendenciasGeral / totalCadastrosVisiveis) * 100) : 0; %>
  <% const taxaReprovacaoGeral = totalCadastrosVisiveis ? Math.round((totalReprovadosGeral / totalCadastrosVisiveis) * 100) : 0; %>
  <% const atividadeRecente = [
    ...((encontristas || []).map(function(item){ return Object.assign({}, item, { __tipoPainel: 'Encontrista' }); })),
    ...((encontreirosIndividuais || []).map(function(item){ return Object.assign({}, item, { __tipoPainel: 'Encontreiro' }); })),
    ...((tios || []).map(function(item){ return Object.assign({}, item, { __tipoPainel: 'Tio' }); }))
  ].sort(function(a, b){
    return new Date(b.dataCadastro || 0).getTime() - new Date(a.dataCadastro || 0).getTime();
  }).slice(0, 8); %>
  <% const pendenciasCriticasMenu = totalPendencias >= 12; %>
  <% const pendenciasAtencaoMenu = !pendenciasCriticasMenu && totalPendencias >= 6; %>
  <% const pendenciasClasseMenu = pendenciasCriticasMenu ? 'is-critical' : (pendenciasAtencaoMenu ? 'is-attention' : 'is-normal'); %>
  <% const pendenciasTituloMenu = pendenciasCriticasMenu ? 'Fila critica de aprovacoes' : (pendenciasAtencaoMenu ? 'Fila em atencao' : 'Fila sob controle'); %>
  <% const adminPermissoesLista = Array.isArray(adminPermissoes) ? adminPermissoes : []; %>
  <% const adminPermissionOptionsList = Array.isArray(adminPermissionOptions) ? adminPermissionOptions : []; %>
  <% const adminRoleDefaults = adminRoleDefaultPermissions || {}; %>
  <% const adminNivelAtual = adminNivelAcesso || 'super_admin'; %>
  <% const podeGerenciarAdmins = adminPermissoesLista.includes('admins.gerenciar'); %>
  <% const podeVisualizarPainel = adminPermissoesLista.includes('painel.visualizar'); %>

  <div class="admin-shell">
    <aside class="sidebar">
      <div class="sidebar-top">
        <div class="brand-inline">
          <div class="brand-badge"><img src="/images/rodape.png" alt="EJC COP" loading="lazy" decoding="async"></div>
          <div class="brand-text">EJC COP</div>
        </div>
      </div>

      <nav class="side-menu">
          <button type="button" class="menu-link" data-menu-title="Principal" data-tab-target="principal-tab" data-required-permission="painel.visualizar" onclick="abrirAba('principal-tab')"><i class="fas fa-chart-line"></i><span class="menu-label">Principal</span></button>
          <button type="button" class="menu-link" data-menu-title="Encontristas" data-tab-target="encontristas-tab" data-required-permission="cadastros.visualizar" onclick="abrirAba('encontristas-tab')"><i class="fas fa-user"></i><span class="menu-label">Encontristas</span></button>
          <button type="button" class="menu-link" data-menu-title="Encontreiros" data-tab-target="encontreiros-tab" data-required-permission="cadastros.visualizar" onclick="abrirAba('encontreiros-tab')"><i class="fas fa-user-group"></i><span class="menu-label">Encontreiros</span></button>
          <button type="button" class="menu-link" data-menu-title="Tios" data-tab-target="tios-tab" data-required-permission="cadastros.visualizar" onclick="abrirAba('tios-tab')"><i class="fas fa-heart"></i><span class="menu-label">Tios</span></button>
          <button type="button" class="menu-link menu-link-aprovacoes" data-menu-title="Aprovações" data-tab-target="aprovacoes-tab" data-required-permission="cadastros.aprovar" onclick="abrirAba('aprovacoes-tab')" title="<%= pendenciasTituloMenu %>">
            <i class="fas fa-check-circle"></i>
            <span class="menu-label">Aprovações</span>
            <span class="menu-alert-counter <%= pendenciasClasseMenu %>"><%= totalPendencias %></span>
          </button>
          <button type="button" class="menu-link" data-menu-title="Encontros" data-tab-target="encontros-tab" data-required-permission="encontros.gerenciar" onclick="abrirAba('encontros-tab')"><i class="fas fa-calendar-days"></i><span class="menu-label">Encontros</span></button>
          <button type="button" class="menu-link" data-menu-title="Administradores" data-tab-target="admins-tab" data-required-permission="admins.gerenciar" onclick="abrirAba('admins-tab')"><i class="fas fa-user-shield"></i><span class="menu-label">Administradores</span></button>
          <a href="/admin/logout" class="menu-link" data-menu-title="Sair"><i class="fas fa-right-from-bracket"></i><span class="menu-label">Sair</span></a>
        </nav>

        <div class="sidebar-note">
          Passe o mouse para expandir
        </div>
      </aside>

      <main class="main-panel">
        <header class="topbar workspace-hero-manager <%= pendenciasCriticasMenu ? 'is-critical' : (pendenciasAtencaoMenu ? 'is-attention' : '') %>">
          <div class="workspace-hero-main">
            <h1 class="workspace-title">
              <span class="workspace-title-icon" aria-hidden="true"><i class="fas fa-users-cog"></i></span>
              <span class="workspace-title-copy">
                <span class="workspace-title-kicker">Painel</span>
                <span class="workspace-title-main">Gestão Administrativa</span>
              </span>
            </h1>
            <div class="workspace-hero-strip" aria-label="Destaques da gestão">
              <span class="hero-strip-pill"><i class="fas fa-bullseye"></i>Encontro ativo: <strong><%= encontroAtivoNome || 'Nenhum definido' %></strong></span>
              <span class="hero-strip-pill"><i class="fas fa-circle-check"></i><%= encontristasAprovados.length %> encontristas aprovados</span>
              <span class="hero-strip-pill"><i class="fas fa-user-group"></i><%= encontreirosAprovados.length %> encontreiros liberados</span>
              <span class="hero-strip-pill"><i class="fas fa-heart"></i><%= (tios || []).length %> tios em apoio</span>
            </div>
            <% if (podeVisualizarPainel) { %>
              <div class="event-scope-workbench" aria-label="Escopo dos dados do painel administrativo">
                <div class="event-scope-switch" role="group" aria-label="Filtro de escopo por encontro">
                  <button
                    type="button"
                    class="event-scope-btn <%= (escopoEventoAdmin || 'ativo') === 'ativo' ? 'active' : '' %>"
                    data-event-scope="ativo"
                    aria-pressed="<%= (escopoEventoAdmin || 'ativo') === 'ativo' ? 'true' : 'false' %>"
                  >
                    <i class="fas fa-bullseye"></i>Somente encontro ativo
                  </button>
                  <button
                    type="button"
                    class="event-scope-btn <%= (escopoEventoAdmin || 'ativo') === 'todos' ? 'active' : '' %>"
                    data-event-scope="todos"
                    aria-pressed="<%= (escopoEventoAdmin || 'ativo') === 'todos' ? 'true' : 'false' %>"
                  >
                    <i class="fas fa-layer-group"></i>Todos os encontros
                  </button>
                </div>
                <span class="event-filter-banner" role="status">
                  <i class="fas fa-filter"></i>
                  Exibindo: <strong><%= (escopoEventoAdmin || 'ativo') === 'todos' ? 'todos os encontros' : (eventoFiltroNome || encontroAtivoNome || 'encontro ativo') %></strong>
                </span>
              </div>
            <% } %>
          </div>
          <div class="manager-stats" aria-label="Resumo da gestão">
            <article class="workspace-stat-card">
              <span class="stat-label">Cadastros</span>
              <strong class="stat-value"><%= totalCadastrosVisiveis %></strong>
            </article>
            <article class="workspace-stat-card">
              <span class="stat-label">Pendências</span>
              <strong class="stat-value"><%= totalPendencias %></strong>
            </article>
            <article class="workspace-stat-card">
              <span class="stat-label">Encontros</span>
              <strong class="stat-value"><%= (ejcs || []).length %></strong>
            </article>
            <article class="workspace-stat-card">
              <span class="stat-label">Admins</span>
              <strong class="stat-value"><%= (administradores || []).length %></strong>
            </article>
          </div>
          <div class="admin-pill hero-admin-pill"><span class="hero-admin-avatar"><i class="fas fa-user-shield"></i></span><span class="hero-admin-meta"><small>Logado como</small><strong><%= adminUsername %></strong><small>Nivel: <%= adminNivelAtual %></small></span></div>
        </header>

        <section class="manager-module-grid" aria-label="Atalhos da gestão">
          <button type="button" class="manager-module-card" data-tab-target="principal-tab" data-required-permission="painel.visualizar" onclick="abrirAba('principal-tab')">
            <span class="manager-module-icon"><i class="fas fa-chart-line"></i></span>
            <span class="manager-module-copy">
              <span class="manager-module-title">Principal</span>
              <span class="manager-module-subtitle">Visão executiva e operação em tempo real</span>
            </span>
            <span class="manager-module-count"><%= totalCadastrosVisiveis %></span>
          </button>
          <button type="button" class="manager-module-card" data-tab-target="encontristas-tab" data-required-permission="cadastros.visualizar" onclick="abrirAba('encontristas-tab')">
            <span class="manager-module-icon"><i class="fas fa-user"></i></span>
            <span class="manager-module-copy">
              <span class="manager-module-title">Encontristas</span>
              <span class="manager-module-subtitle">Cadastros e acompanhamento individual</span>
            </span>
            <span class="manager-module-count"><%= (encontristas || []).length %></span>
          </button>
          <button type="button" class="manager-module-card" data-tab-target="encontreiros-tab" data-required-permission="cadastros.visualizar" onclick="abrirAba('encontreiros-tab')">
            <span class="manager-module-icon"><i class="fas fa-user-group"></i></span>
            <span class="manager-module-copy">
              <span class="manager-module-title">Encontreiros</span>
              <span class="manager-module-subtitle">Equipes de serviço e apoio jovem</span>
            </span>
            <span class="manager-module-count"><%= (encontreirosIndividuais || []).length %></span>
          </button>
          <button type="button" class="manager-module-card" data-tab-target="tios-tab" data-required-permission="cadastros.visualizar" onclick="abrirAba('tios-tab')">
            <span class="manager-module-icon"><i class="fas fa-heart"></i></span>
            <span class="manager-module-copy">
              <span class="manager-module-title">Tios</span>
              <span class="manager-module-subtitle">Apoio pastoral e serviço no encontro</span>
            </span>
            <span class="manager-module-count"><%= (tios || []).length %></span>
          </button>
          <button type="button" class="manager-module-card" data-tab-target="aprovacoes-tab" data-required-permission="cadastros.aprovar" onclick="abrirAba('aprovacoes-tab')">
            <span class="manager-module-icon"><i class="fas fa-check-circle"></i></span>
            <span class="manager-module-copy">
              <span class="manager-module-title">Aprovações</span>
              <span class="manager-module-subtitle">Triagem, status e decisão dos cadastros</span>
            </span>
            <span class="manager-module-count"><%= totalPendencias %></span>
          </button>
          <button type="button" class="manager-module-card" data-tab-target="encontros-tab" data-required-permission="encontros.gerenciar" onclick="abrirAba('encontros-tab')">
            <span class="manager-module-icon"><i class="fas fa-calendar-days"></i></span>
            <span class="manager-module-copy">
              <span class="manager-module-title">Encontros</span>
              <span class="manager-module-subtitle">Criação e manutenção dos eventos EJC</span>
            </span>
            <span class="manager-module-count"><%= (ejcs || []).length %></span>
          </button>
          <button type="button" class="manager-module-card" data-tab-target="admins-tab" data-required-permission="admins.gerenciar" onclick="abrirAba('admins-tab')">
            <span class="manager-module-icon"><i class="fas fa-user-shield"></i></span>
            <span class="manager-module-copy">
              <span class="manager-module-title">Administradores</span>
              <span class="manager-module-subtitle">Permissões, bloqueios e importações</span>
            </span>
            <span class="manager-module-count"><%= (administradores || []).length %></span>
          </button>
        </section>
        <p class="manager-shortcut-hint" aria-label="Atalhos de teclado">
          Atalhos: <strong>Alt+1..7</strong> para abas, <strong>Alt+D</strong> para dashboard e <strong>Alt+S</strong> para salvar formulário ativo.
        </p>

        <section class="content-card content-card-premium">
        <ul class="nav nav-tabs" id="cadastroTabs" role="tablist">
          <li class="nav-item" role="presentation">
            <button class="nav-link active" id="principal-tab" data-bs-toggle="tab" data-bs-target="#principal" data-required-permission="painel.visualizar" type="button">
              <i class="fas fa-chart-line me-1"></i>Principal
            </button>
          </li>
          <li class="nav-item" role="presentation">
            <button class="nav-link" id="encontristas-tab" data-bs-toggle="tab" data-bs-target="#encontristas" data-required-permission="cadastros.visualizar" type="button">
              <i class="fas fa-user me-1"></i>Encontristas (<%= encontristas.length %>)
            </button>
          </li>
          <li class="nav-item" role="presentation">
            <button class="nav-link" id="encontreiros-tab" data-bs-toggle="tab" data-bs-target="#encontreiros" data-required-permission="cadastros.visualizar" type="button">
              <i class="fas fa-user-group me-1"></i>Encontreiros (<%= encontreirosIndividuais.length %>)
            </button>
          </li>
          <li class="nav-item" role="presentation">
            <button class="nav-link" id="tios-tab" data-bs-toggle="tab" data-bs-target="#tios" data-required-permission="cadastros.visualizar" type="button">
              <i class="fas fa-heart me-1"></i>Tios (<%= tios.length %>)
            </button>
          </li>
          <li class="nav-item" role="presentation">
            <button class="nav-link" id="aprovacoes-tab" data-bs-toggle="tab" data-bs-target="#aprovacoes" data-required-permission="cadastros.aprovar" type="button">
              <i class="fas fa-check-circle me-1"></i>Aprovações
            </button>
          </li>
          <li class="nav-item" role="presentation">
            <button class="nav-link" id="encontros-tab" data-bs-toggle="tab" data-bs-target="#encontros" data-required-permission="encontros.gerenciar" type="button">
              <i class="fas fa-calendar-days me-1"></i>Encontros
            </button>
          </li>
          <li class="nav-item" role="presentation">
            <button class="nav-link" id="admins-tab" data-bs-toggle="tab" data-bs-target="#admins" data-required-permission="admins.gerenciar" type="button">
              <i class="fas fa-user-shield me-1"></i>Administradores (<%= administradores.length %>)
            </button>
          </li>
        </ul>

        <div class="tab-content" id="cadastroTabsContent">
          <!-- TAB: PRINCIPAL -->
          <div class="tab-pane fade show active" id="principal" data-required-permission="painel.visualizar" role="tabpanel">
            <div class="tab-workspace-head tab-workspace-head-principal">
              <div>
                <p class="tab-kicker">Painel Executivo</p>
                <h5><i class="fas fa-gauge-high me-2"></i>Dashboard Premium do Sistema</h5>
              </div>
              <div class="tab-head-chips">
                <span class="tab-chip">Total operacional: <%= totalCadastrosVisiveis %></span>
                <span class="tab-chip tab-chip-ok">Aprovação: <%= taxaAprovacaoGeral %>%</span>
                <span class="tab-chip tab-chip-pending">Pendências: <%= totalPendenciasGeral %></span>
              </div>
            </div>

            <div class="principal-kpi-grid">
              <article class="principal-kpi-card principal-kpi-card-primary">
                <span class="principal-kpi-label">Cadastros Monitorados</span>
                <strong class="principal-kpi-value"><%= totalCadastrosVisiveis %></strong>
                <small class="principal-kpi-meta">Encontristas, encontreiros e tios em uma única visão</small>
              </article>
              <article class="principal-kpi-card principal-kpi-card-success">
                <span class="principal-kpi-label">Aprovados</span>
                <strong class="principal-kpi-value"><%= totalAprovadosGeral %></strong>
                <small class="principal-kpi-meta"><%= taxaAprovacaoGeral %>% do volume total</small>
              </article>
              <article class="principal-kpi-card principal-kpi-card-warning">
                <span class="principal-kpi-label">Pendentes</span>
                <strong class="principal-kpi-value"><%= totalPendenciasGeral %></strong>
                <small class="principal-kpi-meta"><%= taxaPendenciaGeral %>% aguardando decisão</small>
              </article>
              <article class="principal-kpi-card principal-kpi-card-danger">
                <span class="principal-kpi-label">Reprovados</span>
                <strong class="principal-kpi-value"><%= totalReprovadosGeral %></strong>
                <small class="principal-kpi-meta"><%= taxaReprovacaoGeral %>% fora do fluxo ativo</small>
              </article>
            </div>

            <div class="principal-ops-grid">
              <section class="principal-panel-card">
                <div class="principal-panel-head">
                  <h6><i class="fas fa-filter-circle-dollar me-2"></i>Funil Operacional</h6>
                  <span>Atualizado em tempo real</span>
                </div>
                <div class="principal-funnel-list">
                  <div class="principal-funnel-item">
                    <div class="principal-funnel-row"><strong>Aprovados</strong><span><%= totalAprovadosGeral %> registro(s)</span></div>
                    <div class="principal-funnel-bar"><span style="width: <%= taxaAprovacaoGeral %>%;"></span></div>
                  </div>
                  <div class="principal-funnel-item">
                    <div class="principal-funnel-row"><strong>Pendentes</strong><span><%= totalPendenciasGeral %> registro(s)</span></div>
                    <div class="principal-funnel-bar"><span class="is-pending" style="width: <%= taxaPendenciaGeral %>%;"></span></div>
                  </div>
                  <div class="principal-funnel-item">
                    <div class="principal-funnel-row"><strong>Reprovados</strong><span><%= totalReprovadosGeral %> registro(s)</span></div>
                    <div class="principal-funnel-bar"><span class="is-rejected" style="width: <%= taxaReprovacaoGeral %>%;"></span></div>
                  </div>
                </div>

                <div class="principal-quick-actions">
                  <button class="btn btn-sm btn-outline-light" type="button" onclick="abrirAba('aprovacoes-tab')"><i class="fas fa-check-circle me-1"></i>Ir para Aprovações</button>
                  <button class="btn btn-sm btn-outline-light" type="button" onclick="abrirAba('encontros-tab')"><i class="fas fa-calendar-days me-1"></i>Ir para Encontros</button>
                  <button class="btn btn-sm btn-outline-light" type="button" onclick="abrirAba('admins-tab')"><i class="fas fa-user-shield me-1"></i>Ir para Admins</button>
                </div>
              </section>

              <section class="principal-panel-card">
                <div class="principal-panel-head">
                  <h6><i class="fas fa-bolt me-2"></i>Atividade Recente</h6>
                  <span>Últimos cadastros</span>
                </div>
                <div class="principal-timeline">
                  <% if (!atividadeRecente.length) { %>
                    <p class="principal-timeline-empty">Sem movimentações recentes no momento.</p>
                  <% } else { %>
                    <% atividadeRecente.forEach(function(item){ %>
                      <article class="principal-timeline-item">
                        <div class="principal-timeline-avatar"><i class="fas fa-user"></i></div>
                        <div class="principal-timeline-copy">
                          <strong><%= item.nomeCompleto || 'Cadastro sem nome' %></strong>
                          <span><%= item.__tipoPainel %> • <%= item.dataCadastro ? new Date(item.dataCadastro).toLocaleDateString('pt-BR') : 'Sem data' %></span>
                        </div>
                        <span class="principal-timeline-status <%= statusCadastroGrupo(item) === 'aprovado' ? 'is-ok' : (statusCadastroGrupo(item) === 'reprovado' ? 'is-bad' : 'is-pending') %>"><%= statusCadastroGrupo(item) %></span>
                      </article>
                    <% }); %>
                  <% } %>
                </div>
              </section>
            </div>
          </div>

          <!-- TAB: ENCONTRISTAS -->
          <div class="tab-pane fade" id="encontristas" data-required-permission="cadastros.visualizar" role="tabpanel">
            <div class="tab-workspace-head">
              <div>
                <p class="tab-kicker">Area Encontristas</p>
