          method: 'POST',
          headers: { Accept: 'application/json' }
        });

        const contentType = response.headers.get('content-type') || '';
        const result = contentType.includes('application/json')
          ? await response.json()
          : { success: false, error: await response.text() };

        if (result.success) {
          await appAlert('Transferencia realizada com sucesso.', 'success', 'Sucesso');
          recarregarMantendoAbaAtual();
          return;
        }

        await appAlert(result.error || 'Nao foi possivel transferir o cadastro.', 'danger', 'Erro');
      } catch (error) {
        await appAlert('Erro ao transferir cadastro: ' + (error.message || 'falha de conexao'), 'danger', 'Erro');
