    function getCheckedAdminPermissions(selector) {
      const nodes = document.querySelectorAll(selector);
      return Array.from(nodes)
        .filter((node) => node.checked)
        .map((node) => String(node.value || '').trim())
        .filter(Boolean);
    }

    function setCheckedAdminPermissions(selector, permissions) {
      const selected = new Set(Array.isArray(permissions) ? permissions : []);
      const nodes = document.querySelectorAll(selector);
      nodes.forEach((node) => {
        node.checked = selected.has(String(node.value || '').trim());
      });
    }

    function applyRoleDefaultPermissions(levelSelectorId, checkboxSelector) {
      const levelNode = document.getElementById(levelSelectorId);
