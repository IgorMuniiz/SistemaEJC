      document.getElementById('edit_observacoes').value = cadastro.observacoes || '';
      document.getElementById('edit_cep').value = cadastro.cep || '';
      document.getElementById('edit_estadoCivil').value = cadastro.estadoCivil || '';
      document.getElementById('edit_nomeMae').value = cadastro.nomeMae || '';
      document.getElementById('edit_telefoneMae').value = cadastro.telefoneMae || '';
      document.getElementById('edit_nomePai').value = cadastro.nomePai || '';
      document.getElementById('edit_telefonePai').value = cadastro.telefonePai || '';
