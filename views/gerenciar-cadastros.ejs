  <script src="/vendor/bootstrap/js/bootstrap.bundle.min.js"></script>
  <script src="/js/page-transitions.js"></script>
  <script id="encontristas-data" type="application/json"><%- JSON.stringify(encontristas) %></script>
  <script id="encontreiros-data" type="application/json"><%- JSON.stringify(encontreiros) %></script>
  <script id="ejcs-data" type="application/json"><%- JSON.stringify(ejcs || []) %></script>
  <script id="equipes-data" type="application/json"><%- JSON.stringify(equipes || []) %></script>
  <script id="encontreiros-equipe-data" type="application/json"><%- JSON.stringify(encontreirosParaEquipe || []) %></script>
  <script id="administradores-data" type="application/json"><%- JSON.stringify(administradores || []) %></script>
  <script id="admin-role-defaults-data" type="application/json"><%- JSON.stringify(adminRoleDefaults || {}) %></script>
  <script>
    const encontristas = JSON.parse(document.getElementById('encontristas-data').textContent || '[]');
    const encontreiros = JSON.parse(document.getElementById('encontreiros-data').textContent || '[]');
    const ejcs = JSON.parse(document.getElementById('ejcs-data').textContent || '[]');
    const equipes = JSON.parse(document.getElementById('equipes-data').textContent || '[]');
    const encontreirosParaEquipe = JSON.parse(document.getElementById('encontreiros-equipe-data').textContent || '[]');
    const administradoresData = JSON.parse(document.getElementById('administradores-data').textContent || '[]');
    const adminRoleDefaults = JSON.parse(document.getElementById('admin-role-defaults-data').textContent || '{}');
    const currentAdminPermissions = <%- JSON.stringify(adminPermissoesLista || []) %>;
    const adminUsernameAtual = <%- JSON.stringify(adminUsername || '') %>;
    const currentAdminLevel = <%- JSON.stringify(adminNivelAtual || 'super_admin') %>;

    function hasPermission(permissionKey) {
      if (String(currentAdminLevel || '').toLowerCase() === 'super_admin') return true;
      if (!permissionKey) return true;
      return currentAdminPermissions.includes(permissionKey);
    }

    function ensurePermission(permissionKey, message) {
      if (hasPermission(permissionKey)) return true;
      // Mostrar alerta sem bloquear (fire and forget)
      appAlert(message || 'Você não possui permissão para esta ação.', 'warning', 'Acesso negado').catch(err => console.error('[ensurePermission] erro ao mostrar alerta:', err));
      return false;
    }

    function getPrimeiraAbaDisponivelId() {
      const tabButtons = Array.from(document.querySelectorAll('#cadastroTabs .nav-link'));
      const firstVisible = tabButtons.find((item) => item.style.display !== 'none');
      if (!firstVisible || !firstVisible.id) return 'encontristas';
      return firstVisible.id.replace(/-tab$/, '');
    }

    function aplicarPermissoesNoPainel() {
      document.querySelectorAll('[data-required-permission]').forEach((node) => {
        const permissionKey = node.getAttribute('data-required-permission');
        if (hasPermission(permissionKey)) return;
        node.style.display = 'none';
      });
    }

    const modalEdicaoElement = document.getElementById('modalEdicao');
    const modalEdicaoAdminElement = document.getElementById('modalEdicaoAdmin');
    function createFixedEditorModalController(element) {
      if (!element) {
        return {
          show() {},
          hide() {},
        };
      }

      let hideTimer = null;

      const emit = (eventName) => {
        element.dispatchEvent(new Event(eventName));
      };

      const lockScroll = () => {
        const scrollY = window.scrollY;
        document.documentElement.style.overflow = 'hidden';
        document.body.style.overflow = 'hidden';
        document.body.style.position = 'fixed';
        document.body.style.top = `-${scrollY}px`;
        document.body.style.left = '0';
        document.body.style.right = '0';
        document.body.dataset.scrollY = scrollY;
      };

      const unlockScroll = () => {
        const scrollY = parseInt(document.body.dataset.scrollY || '0', 10);
        document.documentElement.style.overflow = '';
        document.body.style.overflow = '';
        document.body.style.position = '';
        document.body.style.top = '';
        document.body.style.left = '';
        document.body.style.right = '';
        delete document.body.dataset.scrollY;
        window.scrollTo(0, scrollY);
      };

      const show = () => {
        if (hideTimer) {
          clearTimeout(hideTimer);
          hideTimer = null;
        }
        emit('show.bs.modal');
        lockScroll();
        element.style.display = 'flex';
        requestAnimationFrame(() => {
          element.classList.add('show');
          emit('shown.bs.modal');
        });
      };

      const hide = () => {
        if (!element.classList.contains('show') && element.style.display === 'none') return;
        emit('hide.bs.modal');
        element.classList.remove('show');
        unlockScroll();
        hideTimer = window.setTimeout(() => {
          element.style.display = 'none';
          emit('hidden.bs.modal');
        }, 180);
      };

      element.style.display = 'none';
      element.querySelectorAll('[data-bs-dismiss="modal"]').forEach((button) => {
        button.addEventListener('click', () => hide());
      });
      element.addEventListener('click', (event) => {
        if (event.target === element) hide();
      });

      return { show, hide };
    }

    let modalEdicao = createFixedEditorModalController(modalEdicaoElement);
    let modalEdicaoAdmin = createFixedEditorModalController(modalEdicaoAdminElement);
    let scrollPaginaAntesModal = 0;

    function abrirModalEdicaoAdminSeguro() {
      if (!modalEdicaoAdminElement) return;
      modalEdicaoAdmin.show();
    }


    function popularParceirosTiosSelect(cadastroIdAtual, parceiroIdAtual) {
      const select = document.getElementById('edit_tioParceiroId');
      if (!select) return;

      const opcoes = encontreiros
        .filter((item) => item && item.tipo === 'tios' && String(item._id) !== String(cadastroIdAtual || ''))
        .sort((a, b) => String(a.nomeCompleto || '').localeCompare(String(b.nomeCompleto || ''), 'pt-BR'));

      select.innerHTML = `<option value="">Selecione</option>${opcoes.map((item) => {
        const nome = String(item.nomeCompleto || 'Sem nome')
          .replace(/&/g, '&amp;')
          .replace(/</g, '&lt;')
          .replace(/>/g, '&gt;')
          .replace(/"/g, '&quot;')
          .replace(/'/g, '&#39;');
        const detalhe = item.tioParceiroId ? ' • ja vinculado(a)' : '';
        return `<option value="${String(item._id)}">${nome}${detalhe}</option>`;
      }).join('')}`;

      select.value = parceiroIdAtual ? String(parceiroIdAtual) : '';
    }

    function atualizarCamposParceiroTios() {
      const tipo = document.getElementById('edit_tipo_pessoa');
      const categoria = document.getElementById('edit_tiosCategoria');
      const casal = document.getElementById('edit_tioComParceiro');
      const wrap = document.getElementById('wrap_edit_tioParceiroId');
      const parceiro = document.getElementById('edit_tioParceiroId');
      if (!tipo || !categoria || !casal || !wrap || !parceiro) return;

      const isTio = tipo.value === 'tios';
      const usaParceiro = isTio && casal.value === 'true';
      if (usaParceiro) {
        categoria.value = 'casal';
      } else if (isTio && categoria.value === 'casal') {
        categoria.value = 'solo';
      }

      wrap.style.display = usaParceiro ? '' : 'none';
      if (!usaParceiro) {
        parceiro.value = '';
      }
    }

    function ajustarEditorEncontreiroSemRolagem() {
      if (!modalEdicaoElement) return;

      const modalBody = modalEdicaoElement.querySelector('.edit-modal-body');
      const form = document.getElementById('formEdicao');
      if (!modalBody || !form) return;

      form.style.transform = '';
      form.style.transformOrigin = '';
      modalBody.style.overflowY = 'scroll';
      modalBody.style.overflowX = 'hidden';
    }

    function travarScrollFundo() {
      scrollPaginaAntesModal = window.scrollY || window.pageYOffset || 0;
      document.body.style.position = 'fixed';
      document.body.style.top = `-${scrollPaginaAntesModal}px`;
      document.body.style.left = '0';
      document.body.style.right = '0';
      document.body.style.width = '100%';
    }

    function liberarScrollFundo() {
      const topo = document.body.style.top || '0px';
      const scrollRestaurar = Math.abs(parseInt(topo, 10)) || scrollPaginaAntesModal || 0;
      document.body.style.position = '';
      document.body.style.top = '';
      document.body.style.left = '';
      document.body.style.right = '';
      document.body.style.width = '';
      window.scrollTo(0, scrollRestaurar);
    }

    modalEdicaoElement.addEventListener('show.bs.modal', () => {
      travarScrollFundo();
    });

    modalEdicaoElement.addEventListener('shown.bs.modal', () => {
      const modalBody = modalEdicaoElement.querySelector('.edit-modal-body');
      const modalContent = modalEdicaoElement.querySelector('.edit-cadastro-modal');
      if (modalBody) modalBody.scrollTop = 0;
      if (modalContent) modalContent.scrollTop = 0;
      ajustarEditorEncontreiroSemRolagem();
      requestAnimationFrame(ajustarEditorEncontreiroSemRolagem);
      setTimeout(ajustarEditorEncontreiroSemRolagem, 120);
      setTimeout(ajustarEditorEncontreiroSemRolagem, 320);
    });

    modalEdicaoElement.addEventListener('hidden.bs.modal', () => {
      modalEdicaoElement.classList.remove('is-encontreiro-view');
      ajustarEditorEncontreiroSemRolagem();
      liberarScrollFundo();
    });

    window.addEventListener('resize', () => {
      if (modalEdicaoElement.classList.contains('show')) {
        ajustarEditorEncontreiroSemRolagem();
      }
    });

    let useNativeDialogs = false;

    function ensureAppPopup() {
      console.log('[ensureAppPopup] verificando se modal existe...');
      let modalElement = document.getElementById('app-popup-modal');
      if (modalElement) {
        console.log('[ensureAppPopup] modal encontrado, retornando instância');
        return {
          element: modalElement,
          instance: bootstrap.Modal.getOrCreateInstance(modalElement),
        };
      }

      console.log('[ensureAppPopup] criando novo modal...');
      modalElement = document.createElement('div');
      modalElement.className = 'modal fade';
      modalElement.id = 'app-popup-modal';
      modalElement.tabIndex = -1;
      modalElement.setAttribute('aria-hidden', 'true');
      modalElement.innerHTML = `
        <div class="modal-dialog modal-dialog-centered app-popup-dialog">
          <div class="modal-content border-0 shadow-lg app-popup-content app-popup-tone-primary">
            <div class="modal-header app-popup-header">
              <h5 class="modal-title" id="app-popup-title">Aviso</h5>
              <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Fechar"></button>
            </div>
            <div class="modal-body app-popup-body">
              <p id="app-popup-message" class="mb-0" style="white-space: pre-line;"></p>
              <input id="app-popup-input" type="text" class="form-control mt-3" style="display:none;" />
            </div>
            <div class="modal-footer app-popup-footer">
              <button type="button" class="btn btn-outline-secondary" id="app-popup-cancel">Cancelar</button>
              <button type="button" class="btn btn-primary" id="app-popup-confirm">OK</button>
            </div>
          </div>
        </div>
      `;
      document.body.appendChild(modalElement);
      console.log('[ensureAppPopup] modal criado e adicionado ao DOM');

      if (typeof bootstrap === 'undefined') {
        console.error('[ensureAppPopup] ERRO: bootstrap não está carregado! Usando diálogos nativos.');
        useNativeDialogs = true;
        throw new Error('Bootstrap não está carregado');
      }

      try {
        const instance = bootstrap.Modal.getOrCreateInstance(modalElement);
        console.log('[ensureAppPopup] instância bootstrap criada:', instance);
        
        return {
          element: modalElement,
          instance,
        };
      } catch (e) {
        console.error('[ensureAppPopup] erro ao criar instância Bootstrap:', e);
        useNativeDialogs = true;
        throw e;
      }
    }

    function showAppPopup({ title, message, confirmText = 'OK', cancelText = null, tone = 'primary', inputValue = null, inputPlaceholder = '' }) {
      console.log('[showAppPopup] iniciado com:', { title, message, confirmText, cancelText, tone, inputValue });
      
      // Criar um timeout para evitar travamento infinito
      const timeoutPromise = new Promise((_, reject) => {
        setTimeout(() => {
          reject(new Error('showAppPopup timeout - modal não respondeu em 5 segundos'));
        }, 5000);
      });

      const popupPromise = (async () => {
        try {
          const { element, instance } = ensureAppPopup();
          const titleEl = element.querySelector('#app-popup-title');
          const messageEl = element.querySelector('#app-popup-message');
          const inputEl = element.querySelector('#app-popup-input');
          const confirmBtn = element.querySelector('#app-popup-confirm');
          const cancelBtn = element.querySelector('#app-popup-cancel');
          const contentEl = element.querySelector('.app-popup-content');

          console.log('[showAppPopup] elementos encontrados:', { titleEl, messageEl, inputEl, confirmBtn, cancelBtn, contentEl });

          titleEl.textContent = title || 'Aviso';
          messageEl.textContent = message || '';
          confirmBtn.textContent = confirmText;
          confirmBtn.className = `btn btn-${tone}`;
          if (contentEl) {
            contentEl.classList.remove('app-popup-tone-primary', 'app-popup-tone-warning', 'app-popup-tone-danger', 'app-popup-tone-success');
            contentEl.classList.add(`app-popup-tone-${tone}`);
          }

          if (cancelText) {
            cancelBtn.style.display = '';
            cancelBtn.textContent = cancelText;
          } else {
            cancelBtn.style.display = 'none';
          }

          const isPrompt = inputValue !== null;
          inputEl.style.display = isPrompt ? '' : 'none';
          inputEl.value = isPrompt ? String(inputValue) : '';
          inputEl.placeholder = inputPlaceholder || '';

          console.log('[showAppPopup] modal configurado, criando Promise...');

          return new Promise((resolve) => {
            let resolved = false;

            const cleanup = () => {
              confirmBtn.removeEventListener('click', onConfirm);
              cancelBtn.removeEventListener('click', onCancel);
              element.removeEventListener('hidden.bs.modal', onHidden);
              inputEl.removeEventListener('keydown', onInputKeyDown);
              console.log('[showAppPopup] cleanup executado');
            };

            const settle = (value) => {
              if (resolved) {
                console.log('[showAppPopup] settle já foi chamado, ignorando valor:', value);
                return;
              }
              resolved = true;
              console.log('[showAppPopup] settle com valor:', value);
              cleanup();
              
              // Tenta fechar o modal de forma segura
              try {
                instance.hide();
              } catch (e) {
                console.error('[showAppPopup] erro ao hide modal:', e);
              }
              
              resolve(value);
            };

            const onConfirm = () => {
              console.log('[showAppPopup] onConfirm disparado');
              settle(isPrompt ? inputEl.value : true);
            };

            const onCancel = () => {
              console.log('[showAppPopup] onCancel disparado');
              settle(isPrompt ? null : false);
            };

            const onHidden = () => {
              console.log('[showAppPopup] onHidden disparado');
              settle(isPrompt ? null : false);
            };

            const onInputKeyDown = (event) => {
              if (event.key === 'Enter') {
                console.log('[showAppPopup] Enter pressionado no input');
                event.preventDefault();
                onConfirm();
              }
            };

            confirmBtn.addEventListener('click', onConfirm);
            cancelBtn.addEventListener('click', onCancel);
            element.addEventListener('hidden.bs.modal', onHidden, { once: true });
            inputEl.addEventListener('keydown', onInputKeyDown);

            console.log('[showAppPopup] listeners adicionados, mostrando modal...');
            try {
              console.log('[showAppPopup] chamando instance.show()...');
              instance.show();
              console.log('[showAppPopup] modal.show() chamado com sucesso');
            } catch (e) {
              console.error('[showAppPopup] erro ao show modal:', e);
              settle(isPrompt ? null : false);
            }

            if (isPrompt) {
              setTimeout(() => {
                console.log('[showAppPopup] focando input...');
                inputEl.focus();
              }, 50);
            }
          });
        } catch (error) {
          console.error('[showAppPopup] ERRO NA FUNÇÃO:', error);
          throw error;
        }
      })();

      // Executar com timeout
      return Promise.race([popupPromise, timeoutPromise]).catch(err => {
        console.error('[showAppPopup] Promise rejeitada:', err);
        useNativeDialogs = true;
        throw err;
      });
    }

    async function appAlert(message, tone = 'primary', title = 'Aviso') {
      if (useNativeDialogs) {
        window.alert(`${title}\n\n${message}`);
        return;
      }
      try {
        await showBeautifulDialog({ title, message, confirmText: 'Entendi', isDanger: tone === 'danger' });
      } catch (e) {
        console.error('[appAlert] erro ao mostrar popup:', e);
        useNativeDialogs = true;
        window.alert(`${title}\n\n${message}`);
      }
    }

    async function appConfirm(message, title = 'Confirmacao') {
      if (useNativeDialogs) {
        return window.confirm(`${title}\n\n${message}`);
      }
      try {
        return await showBeautifulDialog({
          title,
          message,
          confirmText: 'Confirmar',
          cancelText: 'Cancelar',
        });
      } catch (e) {
        console.error('[appConfirm] erro ao mostrar popup:', e);
        useNativeDialogs = true;
        return window.confirm(`${title}\n\n${message}`);
      }
    }

    async function appPrompt(message, defaultValue = '', title = 'Informe um valor') {
      console.log('[appPrompt] chamado com:', { message, defaultValue, title });
      if (useNativeDialogs) {
        console.log('[appPrompt] usando native prompt');
        return window.prompt(`${title}\n\n${message}`, defaultValue);
      }
      try {
        return await showAppPopup({
          title,
          message,
          confirmText: 'Salvar',
          cancelText: 'Cancelar',
          tone: 'primary',
          inputValue: defaultValue,
        });
      } catch (e) {
        console.error('[appPrompt] erro ao mostrar popup:', e);
        useNativeDialogs = true;
        return window.prompt(`${title}\n\n${message}`, defaultValue);
      }
    }

    function abrirAba(tabId) {
      const tabButton = document.getElementById(tabId);
      if (tabButton && tabButton.style.display !== 'none') {
        atualizarNavegacaoAtiva(tabId);
        bootstrap.Tab.getOrCreateInstance(tabButton).show();
      }
