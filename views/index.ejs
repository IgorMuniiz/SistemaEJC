<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8" />
  <meta http-equiv="X-UA-Compatible" content="IE=edge" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content="Plataforma digital do EJC COP - Encontro de Jovens com Cristo" />
  <title>EJC COP - Plataforma de Gestão e Inscrições</title>
  <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@200;300;400;500;600;700&family=Inter:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet">
  <link rel="preload" href="/vendor/fontawesome/css/all.min.css" as="style" onload="this.onload=null;this.rel='stylesheet'">
  <noscript><link rel="stylesheet" href="/vendor/fontawesome/css/all.min.css"></noscript>
  <link rel="stylesheet" href="/css/ejc-home.css">
  <link rel="manifest" href="/manifest.json" />
</head>
<body>
  <!-- Background Grid Pattern -->
  <div class="bg-grid"></div>
  <div class="bg-gradient"></div>

  <!-- Navigation Bar -->
  <nav class="navbar">
    <div class="nav-container">
      <div class="nav-logo">
        <img src="/images/tema.png" alt="EJC COP" class="nav-logo-img">
        <span class="nav-brand">EJC COP</span>
      </div>
      <a href="/admin/login" class="nav-admin-link">
        <i class="fas fa-user-shield"></i>
        <span>Admin</span>
      </a>
    </div>
  </nav>

  <!-- Main Container -->
  <main class="main-container">
    
    <!-- Hero Section -->
    <section class="hero-section">
      <div class="hero-badge">
        <span class="badge-dot"></span>
        Encontro de Jovens com Cristo
      </div>
      
      <h1 class="hero-title">
        <span class="gradient-text">Simplesmente Amar</span>
      </h1>
      
      <p class="hero-description">
        Plataforma completa para gestão de inscrições e acompanhamento do EJC COP.
        <br />Uma experiência única de partilha, amor e encontro pessoal com Cristo.
      </p>

      <!-- CTA Cards -->
      <div class="cta-cards">
        
        <!-- Card Encontrista -->
        <a href="/inscricao" class="cta-card cta-primary">
          <div class="cta-header">
            <div class="cta-icon">
              <i class="fas fa-user-plus"></i>
            </div>
            <span class="cta-tag">Popular</span>
          </div>
          <h3 class="cta-title">Inscrição Encontrista</h3>
          <p class="cta-text">
            Registre-se para participar do próximo encontro e vivenciar uma experiência transformadora
          </p>
          <div class="cta-footer">
            <span class="cta-link-text">Fazer inscrição</span>
            <i class="fas fa-arrow-right"></i>
          </div>
        </a>

        <!-- Card Encontreiro -->
        <a href="/encontro" class="cta-card cta-secondary">
          <div class="cta-header">
            <div class="cta-icon">
              <i class="fas fa-users"></i>
            </div>
          </div>
          <h3 class="cta-title">Área do Encontreiro</h3>
          <p class="cta-text">
            Acesse ferramentas exclusivas, materiais de apoio e gerencie suas atividades
          </p>
          <div class="cta-footer">
            <span class="cta-link-text">Acessar área</span>
            <i class="fas fa-arrow-right"></i>
          </div>
        </a>

      </div>
    </section>

    <!-- Features Section -->
    <section class="features-section">
      <div class="feature-item">
        <div class="feature-icon">
          <i class="fas fa-shield-check"></i>
        </div>
        <span class="feature-text">Plataforma Segura</span>
      </div>
      <div class="feature-item">
        <div class="feature-icon">
          <i class="fas fa-clock"></i>
        </div>
        <span class="feature-text">Disponível 24/7</span>
      </div>
      <div class="feature-item">
        <div class="feature-icon">
          <i class="fas fa-mobile-alt"></i>
        </div>
        <span class="feature-text">Mobile Friendly</span>
      </div>
    </section>

  </main>

  <!-- Footer -->
  <footer class="main-footer">
    <p>&copy; 2026 EJC COP. Simplesmente Amar.</p>
  </footer>
</body>
</html>