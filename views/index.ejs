<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8" />
  <meta http-equiv="X-UA-Compatible" content="IE=edge" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content="Plataforma digital do EJC COP - Encontro de Jovens com Cristo" />
  <meta name="theme-color" content="#0a0a14" />
  <title>EJC COP - Plataforma de Gestão e Inscrições</title>
  <link rel="stylesheet" href="/css/ejc-home.css">
  <link rel="manifest" href="/manifest.json" />
</head>
<body>
  <!-- Background Grid Pattern -->
  <div class="bg-grid"></div>
  <div class="bg-gradient"></div>

  <!-- Navigation Bar -->
  <nav class="navbar">
    <div class="nav-container">
      <div class="nav-logo">
        <picture>
          <source srcset="/images/tema-logo-64.webp" type="image/webp">
          <img src="/images/tema-logo-64.png" alt="EJC COP" class="nav-logo-img" width="32" height="32" decoding="async" fetchpriority="high">
        </picture>
        <span class="nav-brand">EJC COP</span>
      </div>
      <a href="/admin/login" class="nav-admin-link">
        <span class="icon" aria-hidden="true">
          <svg viewBox="0 0 24 24" fill="currentColor" focusable="false"><path d="M12 2 4 5v6c0 5.2 3.4 9.9 8 11 4.6-1.1 8-5.8 8-11V5l-8-3Zm0 2.1 6 2.2V11c0 4.3-2.7 8.2-6 9.3-3.3-1.1-6-5-6-9.3V6.3l6-2.2Z"/></svg>
        </span>
        <span>Admin</span>
      </a>
    </div>
  </nav>

  <!-- Main Container -->
  <main class="main-container">
    
    <!-- Hero Section -->
    <section class="hero-section">
      <div class="hero-badge">
        <span class="badge-dot"></span>
        Encontro de Jovens com Cristo
      </div>
      
      <h1 class="hero-title">
        <span class="gradient-text">Simplesmente Amar</span>
      </h1>
      
      <p class="hero-description">
        Plataforma completa para gestão de inscrições e acompanhamento do EJC COP.
        <br />Uma experiência única de partilha, amor e encontro pessoal com Cristo.
      </p>

      <!-- CTA Cards -->
      <div class="cta-cards">
        
        <!-- Card Encontrista -->
        <a href="/inscricao" class="cta-card cta-primary">
          <div class="cta-header">
            <div class="cta-icon">
              <span class="icon" aria-hidden="true">
                <svg viewBox="0 0 24 24" fill="currentColor" focusable="false"><path d="M15 8a4 4 0 1 1-8 0 4 4 0 0 1 8 0Zm-4 6c3.3 0 6 2.2 6 5v1H5v-1c0-2.8 2.7-5 6-5Zm8-6v2h2v2h-2v2h-2v-2h-2v-2h2V8h2Z"/></svg>
              </span>
            </div>
            <span class="cta-tag">Popular</span>
          </div>
          <h2 class="cta-title">Inscrição Encontrista</h2>
          <p class="cta-text">
            Registre-se para participar do próximo encontro e vivenciar uma experiência transformadora
          </p>
          <div class="cta-footer">
            <span class="cta-link-text">Fazer inscrição</span>
            <span class="icon" aria-hidden="true">
              <svg viewBox="0 0 24 24" fill="currentColor" focusable="false"><path d="m13.5 5 1.4 1.4-4.6 4.6H20v2h-9.7l4.6 4.6L13.5 19 6.5 12l7-7Z"/></svg>
            </span>
          </div>
        </a>

        <!-- Card Encontreiro -->
        <a href="/encontro" class="cta-card cta-secondary">
          <div class="cta-header">
            <div class="cta-icon">
              <span class="icon" aria-hidden="true">
                <svg viewBox="0 0 24 24" fill="currentColor" focusable="false"><path d="M16 11a3 3 0 1 0-2.2-5A5 5 0 0 1 16 11ZM8 11a4 4 0 1 0 0-8 4 4 0 0 0 0 8Zm8.5 2c-1.6 0-3 .5-4 1.3 1.5 1 2.5 2.5 2.5 4.2V20H22v-1.5c0-3-2.5-5.5-5.5-5.5ZM8 13c-3.3 0-6 2.5-6 5.5V20h12v-1.5C14 15.5 11.3 13 8 13Z"/></svg>
              </span>
            </div>
          </div>
          <h2 class="cta-title">Área do Encontreiro</h2>
          <p class="cta-text">
            Acesse ferramentas exclusivas, materiais de apoio e gerencie suas atividades
          </p>
          <div class="cta-footer">
            <span class="cta-link-text">Acessar área</span>
            <span class="icon" aria-hidden="true">
              <svg viewBox="0 0 24 24" fill="currentColor" focusable="false"><path d="m13.5 5 1.4 1.4-4.6 4.6H20v2h-9.7l4.6 4.6L13.5 19 6.5 12l7-7Z"/></svg>
            </span>
          </div>
        </a>

      </div>
    </section>

    <!-- Features Section -->
    <section class="features-section">
      <div class="feature-item">
        <div class="feature-icon">
          <span class="icon" aria-hidden="true">
            <svg viewBox="0 0 24 24" fill="currentColor" focusable="false"><path d="M12 2 4 5v6c0 5.2 3.4 9.9 8 11 4.6-1.1 8-5.8 8-11V5l-8-3Zm-1 13.2-3-3 1.4-1.4 1.6 1.6 3.6-3.6 1.4 1.4-5 5Z"/></svg>
          </span>
        </div>
        <span class="feature-text">Plataforma Segura</span>
      </div>
      <div class="feature-item">
        <div class="feature-icon">
          <span class="icon" aria-hidden="true">
            <svg viewBox="0 0 24 24" fill="currentColor" focusable="false"><path d="M12 2a10 10 0 1 0 0 20 10 10 0 0 0 0-20Zm1 5v5.6l4 2.4-1 1.7L11 13.8V7h2Z"/></svg>
          </span>
        </div>
        <span class="feature-text">Disponível 24/7</span>
      </div>
      <div class="feature-item">
        <div class="feature-icon">
          <span class="icon" aria-hidden="true">
            <svg viewBox="0 0 24 24" fill="currentColor" focusable="false"><path d="M7 2h10a2 2 0 0 1 2 2v16a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2Zm0 3v14h10V5H7Zm4 13h2v2h-2v-2Z"/></svg>
          </span>
        </div>
        <span class="feature-text">Mobile Friendly</span>
      </div>
    </section>

  </main>

  <!-- Footer -->
  <footer class="main-footer">
    <p>&copy; 2026 EJC COP. Simplesmente Amar.</p>
  </footer>
</body>
</html>