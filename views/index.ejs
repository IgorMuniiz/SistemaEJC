<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8" />
  <meta http-equiv="X-UA-Compatible" content="IE=edge" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content="Plataforma digital do EJC COP - Encontro de Jovens com Cristo" />
  <meta name="theme-color" content="#0a0a14" />
  <title>EJC COP - Plataforma de Gestão e Inscrições</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link rel="preload" href="https://fonts.googleapis.com/css2?family=Manrope:wght@400;500;600;700;800&family=Sora:wght@500;600;700&display=swap" as="style" onload="this.onload=null;this.rel='stylesheet'">
  <noscript><link href="https://fonts.googleapis.com/css2?family=Manrope:wght@400;500;600;700;800&family=Sora:wght@500;600;700&display=swap" rel="stylesheet"></noscript>
  <link rel="preload" href="/css/ejc-home.css" as="style" onload="this.onload=null;this.rel='stylesheet'">
  <noscript><link rel="stylesheet" href="/css/ejc-home.css"></noscript>
  <link rel="preload" as="image" href="/img/images/tema.png?w=1280&h=720&fit=inside&format=webp&q=68" imagesrcset="/img/images/tema.png?w=960&h=540&fit=inside&format=webp&q=68 960w, /img/images/tema.png?w=1280&h=720&fit=inside&format=webp&q=68 1280w" imagesizes="100vw" fetchpriority="low">
  <link rel="manifest" href="/manifest.json" />
</head>
<body>
  <!-- Background Grid Pattern -->
  <div class="bg-grid"></div>
  <div class="bg-gradient"></div>
  <div class="bg-particles" aria-hidden="true">
    <span class="particle p1"></span>
    <span class="particle p2"></span>
    <span class="particle p3"></span>
    <span class="particle p4"></span>
    <span class="particle p5"></span>
    <span class="particle p6"></span>
    <span class="particle p7"></span>
    <span class="particle p8"></span>
  </div>
  <div class="bg-orb orb-1"></div>
  <div class="bg-orb orb-2"></div>
  <div class="bg-orb orb-3"></div>

  <!-- Navigation Bar -->
  <nav class="navbar">
    <div class="nav-container">
      <div class="nav-logo">
        <picture>
          <source srcset="/images/tema-logo-64.webp" type="image/webp">
          <img src="/images/tema-logo-64.png" alt="EJC COP" class="nav-logo-img" width="32" height="32" decoding="async" fetchpriority="high">
        </picture>
        <span class="nav-brand">EJC COP</span>
      </div>
      <div class="nav-actions">
        <a href="/inscricao" class="nav-cta-btn">
          <span>Inscrever-se</span>
        </a>
        <a href="/admin/login" class="nav-admin-link">
          <span class="icon" aria-hidden="true">
            <svg viewBox="0 0 24 24" fill="currentColor" focusable="false"><path d="M12 2 4 5v6c0 5.2 3.4 9.9 8 11 4.6-1.1 8-5.8 8-11V5l-8-3Zm0 2.1 6 2.2V11c0 4.3-2.7 8.2-6 9.3-3.3-1.1-6-5-6-9.3V6.3l6-2.2Z"/></svg>
          </span>
          <span>Admin</span>
        </a>
      </div>
    </div>
  </nav>

  <!-- Main Container -->
  <main class="main-container">
    <section class="hero-section scroll-reveal reveal-up" data-reveal>
      <div class="hero-grid">
        <div class="hero-copy">
          <div class="hero-badge">
            <span class="badge-dot"></span>
            Encontro de Jovens com Cristo
          </div>

          <h1 class="hero-title">
            <span class="gradient-text">Simplesmente Amar</span>
            <span class="hero-title-sub">Gerencie encontristas com mais eficiência e propósito</span>
          </h1>

          <p class="hero-description">
            Inscrições, organização e acompanhamento reunidos em uma plataforma elegante,
            rápida e humana — feita para quem vive e serve o encontro.
          </p>

          <div class="hero-actions">
            <a href="/inscricao" class="btn-primary">
              <span>Quero me inscrever</span>
              <span class="icon" aria-hidden="true">
                <svg viewBox="0 0 24 24" fill="currentColor" focusable="false"><path d="M13.17 5.17a1 1 0 0 1 1.41 0l6 6a1 1 0 0 1 0 1.41l-6 6a1 1 0 1 1-1.41-1.41L17.59 13H4a1 1 0 1 1 0-2h13.59l-4.42-4.41a1 1 0 0 1 0-1.42Z"/></svg>
              </span>
            </a>
            <a href="/encontro" class="btn-secondary">
              <span>Sou Encontreiro</span>
            </a>
          </div>

          <div class="hero-stats">
            <div class="hero-stat">
              <strong class="stat-num">500+</strong>
              <span class="stat-label">Jovens impactados</span>
            </div>
            <div class="hero-stat-divider"></div>
            <div class="hero-stat">
              <strong class="stat-num">38</strong>
              <span class="stat-label">Encontreiros ativos</span>
            </div>
            <div class="hero-stat-divider"></div>
            <div class="hero-stat">
              <strong class="stat-num">100%</strong>
              <span class="stat-label">Online e gratuito</span>
            </div>
          </div>
        </div>

        <aside class="hero-panel">
          <div class="panel-head">
            <span>Plataforma EJC COP</span>
            <span class="panel-live-dot">Online</span>
          </div>
          <div class="panel-metric-grid">
            <article class="metric-card">
              <span class="metric-label">Experiência</span>
              <strong class="metric-value">Um final de semana que transforma — amor, reflexão, amizade e encontro pessoal com Cristo.</strong>
            </article>
            <article class="metric-card">
              <span class="metric-label">Identidade</span>
              <strong class="metric-value">EJC COP</strong>
              <small class="metric-note">Feito para refletir o projeto.</small>
            </article>
            <article class="metric-card metric-wide">
              <span class="metric-label">Propósito</span>
              <strong class="metric-value">Evangelizar e aproximar os jovens de Deus, proporcionando um encontro pessoal com Jesus Cristo. ✝️</strong>
            </article>
          </div>
        </aside>
      </div>
    </section>

    <section class="studio-reel scroll-reveal reveal-up" data-reveal>
      <div class="studio-reel-head">
        <p class="studio-reel-kicker">Tema Visual do Encontro</p>
        <h2 class="studio-reel-title">Atmosfera do EJC em movimento</h2>
      </div>
      <div class="studio-reel-frame" data-video-parallax>
        <video
          class="studio-reel-video"
          autoplay
          loop
          muted
          playsinline
          preload="none"
          poster="/img/images/tema.png?w=1280&h=720&fit=inside&format=webp&q=68"
          aria-label="Video tema do EJC COP"
        >
          <source src="/images/video%20tema.mp4" type="video/mp4" />
        </video>
      </div>
    </section>

    <section class="cta-cards scroll-reveal reveal-stagger" data-reveal>
      <a href="/inscricao" class="cta-card cta-primary">
        <div class="cta-header">
          <div class="cta-icon">
            <span class="icon" aria-hidden="true">
              <svg viewBox="0 0 24 24" fill="currentColor" focusable="false"><path d="M15 8a4 4 0 1 1-8 0 4 4 0 0 1 8 0Zm-4 6c3.3 0 6 2.2 6 5v1H5v-1c0-2.8 2.7-5 6-5Zm8-6v2h2v2h-2v2h-2v-2h-2v-2h2V8h2Z"/></svg>
            </span>
          </div>
          <span class="cta-tag">Entrada principal</span>
        </div>
        <h2 class="cta-title">Quero ser Encontrista</h2>
        <p class="cta-text">Comece sua inscrição agora — fluxo simples, rápido e totalmente gratuito para o próximo encontro.</p>
        <div class="cta-footer">
          <span class="cta-link-text">Iniciar inscrição</span>
          <span class="icon" aria-hidden="true">
            <svg viewBox="0 0 24 24" fill="currentColor" focusable="false"><path d="M13.17 5.17a1 1 0 0 1 1.41 0l6 6a1 1 0 0 1 0 1.41l-6 6a1 1 0 1 1-1.41-1.41L17.59 13H4a1 1 0 1 1 0-2h13.59l-4.42-4.41a1 1 0 0 1 0-1.42Z"/></svg>
          </span>
        </div>
      </a>

      <a href="/encontro" class="cta-card cta-secondary">
        <div class="cta-header">
          <div class="cta-icon">
            <span class="icon" aria-hidden="true">
              <svg viewBox="0 0 24 24" fill="currentColor" focusable="false"><path d="M16 11a3 3 0 1 0-2.2-5A5 5 0 0 1 16 11ZM8 11a4 4 0 1 0 0-8 4 4 0 0 0 0 8Zm8.5 2c-1.6 0-3 .5-4 1.3 1.5 1 2.5 2.5 2.5 4.2V20H22v-1.5c0-3-2.5-5.5-5.5-5.5ZM8 13c-3.3 0-6 2.5-6 5.5V20h12v-1.5C14 15.5 11.3 13 8 13Z"/></svg>
            </span>
          </div>
          <span class="cta-tag">Equipe de serviço</span>
        </div>
        <h2 class="cta-title">Sou Encontreiro</h2>
        <p class="cta-text">Acesse sua área para atuar na preparação e conduzir experiências que transformam vidas.</p>
        <div class="cta-footer">
          <span class="cta-link-text">Entrar na área</span>
          <span class="icon" aria-hidden="true">
            <svg viewBox="0 0 24 24" fill="currentColor" focusable="false"><path d="M13.17 5.17a1 1 0 0 1 1.41 0l6 6a1 1 0 0 1 0 1.41l-6 6a1 1 0 1 1-1.41-1.41L17.59 13H4a1 1 0 1 1 0-2h13.59l-4.42-4.41a1 1 0 0 1 0-1.42Z"/></svg>
          </span>
        </div>
      </a>
    </section>

    <section class="features-section features-section--single scroll-reveal reveal-up" data-reveal>
      <div class="feature-item">
        <div class="feature-icon">
          <span class="icon" aria-hidden="true">
            <svg viewBox="0 0 24 24" fill="currentColor" focusable="false"><path d="M12 2 4 5v6c0 5.2 3.4 9.9 8 11 4.6-1.1 8-5.8 8-11V5l-8-3Zm-1 13.2-3-3 1.4-1.4 1.6 1.6 3.6-3.6 1.4 1.4-5 5Z"/></svg>
          </span>
        </div>
        <span class="feature-text">Segurança e privacidade garantidas</span>
      </div>
    </section>

  </main>

  <!-- Footer -->
  <footer class="main-footer">
    <p>&copy; 2026 EJC COP. Simplesmente Amar.</p>
  </footer>

  <script>
    document.querySelectorAll('.cta-card').forEach((card) => {
      card.addEventListener('pointermove', (event) => {
        const rect = card.getBoundingClientRect();
        const x = ((event.clientX - rect.left) / rect.width) * 100;
        const y = ((event.clientY - rect.top) / rect.height) * 100;
        card.style.setProperty('--mx', `${x}%`);
        card.style.setProperty('--my', `${y}%`);
      });
    });

    const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    const revealElements = document.querySelectorAll('[data-reveal]');

    if (!prefersReducedMotion && revealElements.length) {
      const revealObserver = new IntersectionObserver((entries, observer) => {
        entries.forEach((entry) => {
          if (!entry.isIntersecting) return;
          entry.target.classList.add('is-visible');
          observer.unobserve(entry.target);
        });
      }, {
        rootMargin: '0px 0px -12% 0px',
        threshold: 0.16,
      });

      revealElements.forEach((el) => revealObserver.observe(el));
    } else {
      revealElements.forEach((el) => el.classList.add('is-visible'));
    }

    const videoFrame = document.querySelector('[data-video-parallax]');
    if (videoFrame && !prefersReducedMotion) {
      let ticking = false;
      const updateVideoShift = () => {
        const rect = videoFrame.getBoundingClientRect();
        const viewportHeight = window.innerHeight || document.documentElement.clientHeight;
        const travel = (viewportHeight - rect.top) / (viewportHeight + rect.height);
        const progress = Math.max(0, Math.min(1, travel));
        const shiftY = (progress - 0.5) * 22;
        const scale = 1.03 + progress * 0.04;
        videoFrame.style.setProperty('--video-shift-y', `${shiftY.toFixed(2)}px`);
        videoFrame.style.setProperty('--video-scale', scale.toFixed(3));
        ticking = false;
      };

      const requestUpdate = () => {
        if (ticking) return;
        ticking = true;
        window.requestAnimationFrame(updateVideoShift);
      };

      requestUpdate();
      window.addEventListener('scroll', requestUpdate, { passive: true });
      window.addEventListener('resize', requestUpdate);
    }
  </script>
  <script defer src="/js/page-transitions.js"></script>
</body>
</html>