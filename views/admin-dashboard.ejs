<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8" />
  <meta http-equiv="X-UA-Compatible" content="IE=edge" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content="Painel de Aprovação EJC Admin" />
  <title>Aprovações — EJC Admin</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Manrope:wght@400;500;600;700;800&family=Sora:wght@500;600;700&display=swap" rel="stylesheet">
  <link rel="preload" href="/vendor/bootstrap/css/bootstrap.min.css" as="style" onload="this.onload=null;this.rel='stylesheet'">
  <noscript><link rel="stylesheet" href="/vendor/bootstrap/css/bootstrap.min.css"></noscript>
  <link rel="preload" href="/vendor/fontawesome/css/all.min.css" as="style" onload="this.onload=null;this.rel='stylesheet'">
  <noscript><link rel="stylesheet" href="/vendor/fontawesome/css/all.min.css"></noscript>
  <link rel="stylesheet" href="/css/admin-saas.css">
</head>
<body class="admin-panel admin-dashboard-page">
  <div class="db-bg" aria-hidden="true"></div>

  <!-- ── TOPBAR ── -->
  <header class="topbar">
    <a class="topbar-brand" href="/admin">
      <div class="topbar-logo"><i class="fas fa-shield-halved"></i></div>
      <div>
        <div class="topbar-name">EJC Admin</div>
        <div class="topbar-sub">Painel Administrativo</div>
      </div>
    </a>
    <nav class="topbar-nav">
      <a href="/" class="topbar-link"><i class="fas fa-house"></i>Início</a>
      <a href="/admin/gerenciar-cadastros" class="topbar-link"><i class="fas fa-table-columns"></i>Cadastros</a>
      <span class="topbar-user"><i class="fas fa-user-circle"></i><%= adminUsername %></span>
      <a href="/admin/logout" class="topbar-logout"><i class="fas fa-arrow-right-from-bracket"></i>Sair</a>
    </nav>
  </header>

  <!-- ── MAIN ── -->
  <main class="db-wrap">

    <!-- Toasts -->
    <div class="db-toast-area">
      <% if (typeof mensagemSucesso !== 'undefined' && mensagemSucesso) { %>
        <div class="db-toast success" role="alert">
          <i class="fas fa-circle-check"></i>
          <span><strong>Sucesso!</strong> <%= mensagemSucesso %></span>
          <button class="db-toast-close" onclick="this.closest('.db-toast').remove()" aria-label="Fechar">&times;</button>
        </div>
      <% } %>
      <% if (typeof mensagemErro !== 'undefined' && mensagemErro) { %>
        <div class="db-toast error" role="alert">
          <i class="fas fa-triangle-exclamation"></i>
          <span><strong>Erro!</strong> <%= mensagemErro %></span>
          <button class="db-toast-close" onclick="this.closest('.db-toast').remove()" aria-label="Fechar">&times;</button>
        </div>
      <% } %>
    </div>

    <!-- Page Header -->
    <div class="db-header">
      <div>
        <h1 class="db-header-title">Painel de Aprovação</h1>
        <p class="db-header-sub">Gerencie inscrições de encontristas e encontreiros em tempo real</p>
      </div>
      <div class="db-header-actions">
        <a href="/admin/gerenciar-cadastros" class="btn-action btn-action-primary">
          <i class="fas fa-users-cog"></i>Gerenciar Cadastros
        </a>
        <span class="live-badge"><span class="live-dot"></span>Fluxo ativo</span>
      </div>
    </div>

    <!-- Stats -->
    <div class="stats-row">
      <div class="stat-tile amber-tile">
        <div class="stat-tile-icon amber"><i class="fas fa-clock"></i></div>
        <div>
          <div class="stat-tile-num"><%= totalPendentesEncontristas + totalPendentesEncontreiros %></div>
          <div class="stat-tile-lbl">Pendentes</div>
        </div>
      </div>
      <div class="stat-tile green-tile">
        <div class="stat-tile-icon green"><i class="fas fa-circle-check"></i></div>
        <div>
          <div class="stat-tile-num"><%= totalAprovadosEncontristas + totalAprovadosEncontreiros %></div>
          <div class="stat-tile-lbl">Aprovados</div>
        </div>
      </div>
      <div class="stat-tile red-tile">
        <div class="stat-tile-icon red"><i class="fas fa-circle-xmark"></i></div>
        <div>
          <div class="stat-tile-num"><%= totalReprovadosEncontristas + totalReprovadosEncontreiros %></div>
          <div class="stat-tile-lbl">Reprovados</div>
        </div>
      </div>
      <div class="stat-tile blue-tile">
        <div class="stat-tile-icon blue"><i class="fas fa-users"></i></div>
        <div>
          <div class="stat-tile-num"><%= (totalPendentesEncontristas + totalAprovadosEncontristas + totalReprovadosEncontristas) + (totalPendentesEncontreiros + totalAprovadosEncontreiros + totalReprovadosEncontreiros) %></div>
          <div class="stat-tile-lbl">Total Geral</div>
        </div>
      </div>
    </div>

    <!-- ───────── ENCONTRISTAS ───────── -->
    <section class="section-panel">
      <div class="section-panel-head">
        <h2 class="section-panel-title"><i class="fas fa-user-graduate"></i>Encontristas</h2>
        <div class="section-meta">
          <span class="meta-chip amber"><i class="fas fa-clock"></i><%= totalPendentesEncontristas %> pendente(s)</span>
          <span class="meta-chip green"><i class="fas fa-check"></i><%= totalAprovadosEncontristas %> aprovado(s)</span>
          <span class="meta-chip red"><i class="fas fa-xmark"></i><%= totalReprovadosEncontristas %> reprovado(s)</span>
        </div>
        <div class="export-row">
          <a href="/export?format=pdf" class="export-btn" target="_blank" rel="noreferrer"><i class="fas fa-file-pdf"></i>PDF</a>
          <a href="/export-encontrista-excel" class="export-btn" target="_blank" rel="noreferrer"><i class="fas fa-table"></i>Excel</a>
          <a href="/export-images-encontristas" class="export-btn" target="_blank" rel="noreferrer"><i class="fas fa-images"></i>Imagens</a>
        </div>
      </div>

      <div class="kanban-board">
        <!-- Pendentes -->
        <div class="kanban-col">
          <div class="kanban-col-head">
            <span class="kanban-col-label amber"><span class="dot"></span>Pendentes</span>
            <span class="kanban-count"><%= pendentesEncontristas.length %></span>
          </div>
          <% if (pendentesEncontristas.length === 0) { %>
            <div class="empty-col">
              <div class="empty-col-icon"><i class="fas fa-inbox"></i></div>
              <p class="empty-col-text">Nenhuma inscrição pendente</p>
            </div>
          <% } else { %>
            <% pendentesEncontristas.forEach(r => { %>
              <div class="pcard amber-card">
                <div class="pcard-top">
                  <div class="pcard-avatar">
                    <% if (r.foto) { %>
                      <img src="/img/uploads/<%= encodeURIComponent(r.foto) %>?w=100&h=100&fit=cover&format=webp" loading="lazy" decoding="async" alt="<%= r.nomeCompleto %>" />
                    <% } else { %><i class="fas fa-user"></i><% } %>
                  </div>
                  <div>
                    <div class="pcard-name"><%= r.nomeCompleto %></div>
                    <div class="pcard-meta">
                      <span><i class="fas fa-church"></i><%= r.ejc %></span>
                      <span><i class="fas fa-calendar-days"></i><%= new Date(r.dataCadastro).toLocaleDateString('pt-BR') %></span>
                    </div>
                  </div>
                </div>
                <div class="pcard-details">
                  <div><div class="pcard-field-lbl">Email</div><div class="pcard-field-val"><%= r.email %></div></div>
                  <div><div class="pcard-field-lbl">Telefone</div><div class="pcard-field-val"><%= r.telefone %></div></div>
                  <div><div class="pcard-field-lbl">Logradouro</div><div class="pcard-field-val"><%= r.logradouro %></div></div>
                  <div><div class="pcard-field-lbl">Bairro</div><div class="pcard-field-val"><%= r.bairro %></div></div>
                  <div><div class="pcard-field-lbl">Nascimento</div><div class="pcard-field-val"><%= new Date(r.dataNascimento).toLocaleDateString('pt-BR') %></div></div>
                </div>
                <div class="pcard-actions">
                  <button class="pcard-btn approve" onclick="aprovarCadastro('<%= r._id %>', 'encontrista')"><i class="fas fa-check"></i>Aprovar</button>
                </div>
              </div>
            <% }); %>
