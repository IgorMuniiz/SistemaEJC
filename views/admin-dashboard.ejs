<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8" />
  <meta http-equiv="X-UA-Compatible" content="IE=edge" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content="Painel de Aprovação EJC Admin" />
  <title>Aprovações — EJC Admin</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Manrope:wght@400;500;600;700;800&family=Sora:wght@500;600;700&display=swap" rel="stylesheet">
  <link rel="preload" href="/vendor/bootstrap/css/bootstrap.min.css" as="style" onload="this.onload=null;this.rel='stylesheet'">
  <noscript><link rel="stylesheet" href="/vendor/bootstrap/css/bootstrap.min.css"></noscript>
  <link rel="preload" href="/vendor/fontawesome/css/all.min.css" as="style" onload="this.onload=null;this.rel='stylesheet'">
  <noscript><link rel="stylesheet" href="/vendor/fontawesome/css/all.min.css"></noscript>
  <link rel="stylesheet" href="/css/admin-saas.css">
</head>
<body class="admin-panel admin-dashboard-page is-loading">
  <div class="db-bg" aria-hidden="true"></div>

  <!-- ── TOPBAR ── -->
  <header class="topbar">
    <a class="topbar-brand" href="/admin">
      <div class="topbar-logo"><i class="fas fa-shield-halved"></i></div>
      <div>
        <div class="topbar-name">EJC Admin</div>
        <div class="topbar-sub">Painel Administrativo</div>
      </div>
    </a>
    <nav class="topbar-nav">
      <a href="/" class="topbar-link"><i class="fas fa-house"></i>Início</a>
      <a href="/admin/gerenciar-cadastros" class="topbar-link"><i class="fas fa-table-columns"></i>Cadastros</a>
      <span class="topbar-user">
        <span class="topbar-user-avatar"><%= ((adminUsername || 'A').trim().charAt(0) || 'A').toUpperCase() %></span>
        <span><%= adminUsername %></span>
      </span>
      <a href="/admin/logout" class="topbar-logout"><i class="fas fa-arrow-right-from-bracket"></i>Sair</a>
    </nav>
  </header>

  <div class="db-skeleton-layer" aria-hidden="true">
    <div class="db-skeleton-wrap">
      <div class="db-skeleton-line lg"></div>
      <div class="db-skeleton-line sm"></div>
      <div class="db-skeleton-grid">
        <div class="db-skeleton-card"></div>
        <div class="db-skeleton-card"></div>
        <div class="db-skeleton-card"></div>
        <div class="db-skeleton-card"></div>
      </div>
      <div class="db-skeleton-panel"></div>
    </div>
  </div>

  <!-- ── MAIN ── -->
  <main class="db-wrap">
    <% 
      const totalPendentes = totalPendentesEncontristas + totalPendentesEncontreiros;
      const totalAprovados = totalAprovadosEncontristas + totalAprovadosEncontreiros;
      const totalReprovados = totalReprovadosEncontristas + totalReprovadosEncontreiros;
      const totalGeral = totalPendentes + totalAprovados + totalReprovados;
      const totalProcessados = totalAprovados + totalReprovados;

      const pressaoPendencia = totalGeral > 0 ? Math.round((totalPendentes / totalGeral) * 100) : 0;
      const taxaAprovacao = totalProcessados > 0 ? Math.round((totalAprovados / totalProcessados) * 100) : 0;
      const indiceRisco = totalProcessados > 0 ? Math.round((totalReprovados / totalProcessados) * 100) : 0;

      const pendenciaCritica = pressaoPendencia >= 35;
      const aprovacaoSaudavel = taxaAprovacao >= 70;
      const riscoAlto = indiceRisco >= 25;

      const acoesRecomendadas = [];
      if (pendenciaCritica) {
        acoesRecomendadas.push({
          tone: 'amber',
          icon: 'fa-clock',
          titulo: 'Reduzir fila de pendências',
          texto: `${totalPendentes} cadastros estão aguardando (${pressaoPendencia}% do funil). Priorize aprovação em lote agora.`,
        });
      }
      if (totalProcessados > 0 && !aprovacaoSaudavel) {
        acoesRecomendadas.push({
          tone: 'blue',
          icon: 'fa-chart-line',
          titulo: 'Aumentar conversão de aprovações',
          texto: `Taxa atual em ${taxaAprovacao}%. Revisar critérios de triagem pode recuperar conversão sem perder qualidade.`,
        });
      }
      if (riscoAlto) {
        acoesRecomendadas.push({
          tone: 'red',
          icon: 'fa-triangle-exclamation',
          titulo: 'Investigar padrão de reprovação',
          texto: `${indiceRisco}% de reprovação entre processados. Vale auditar dados incompletos ou inconsistências recorrentes.`,
        });
      }
      if (acoesRecomendadas.length === 0) {
        acoesRecomendadas.push(
          {
            tone: 'green',
            icon: 'fa-circle-check',
            titulo: 'Fluxo saudável',
            texto: 'Os indicadores estão equilibrados. Mantenha rotina de revisão em lote para preservar a velocidade.',
          },
          {
            tone: 'blue',
            icon: 'fa-list-check',
            titulo: 'Ação rápida sugerida',
            texto: 'Faça uma rodada curta nos cadastros pendentes de maior tempo para evitar gargalos futuros.',
          },
          {
            tone: 'amber',
            icon: 'fa-bullseye',
            titulo: 'Meta do dia',
            texto: 'Busque manter pendência abaixo de 30% do funil e taxa de aprovação acima de 70%.',
          }
        );
      }

      const todosCadastros = [
        ...pendentesEncontristas,
        ...aprovadosEncontristas,
        ...reprovadosEncontristas,
        ...pendentesEncontreiros,
        ...aprovadosEncontreiros,
        ...reprovadosEncontreiros,
      ];

      const normalizarEmail = (valor) => String(valor || '').trim().toLowerCase();
      const normalizarTelefone = (valor) => String(valor || '').replace(/\D/g, '');
      const paraDataISO = (valor) => {
        const data = valor ? new Date(valor) : null;
        return data && !Number.isNaN(data.getTime()) ? data.toISOString().slice(0, 10) : '';
      };

      const mapaEmail = {};
      const mapaTelefone = {};
      todosCadastros.forEach((registro) => {
        const emailKey = normalizarEmail(registro.email);
        const telefoneKey = normalizarTelefone(registro.telefone);
        if (emailKey) mapaEmail[emailKey] = (mapaEmail[emailKey] || 0) + 1;
        if (telefoneKey) mapaTelefone[telefoneKey] = (mapaTelefone[telefoneKey] || 0) + 1;
      });

      const equipesUnicas = [...new Set(todosCadastros.map((registro) => String(registro.ejc || '').trim()).filter(Boolean))]
        .sort((a, b) => a.localeCompare(b, 'pt-BR'));

      const construirInsights = (registro, status) => {
        const emailKey = normalizarEmail(registro.email);
        const telefoneKey = normalizarTelefone(registro.telefone);
        const incompleto = !registro.email || !registro.telefone || !registro.logradouro || !registro.bairro;
        const duplicado = (emailKey && mapaEmail[emailKey] > 1) || (telefoneKey && mapaTelefone[telefoneKey] > 1);
        const recomendado = status === 'pendente' && !incompleto && !duplicado;
        return { incompleto, duplicado, recomendado };
      };
    %>

    <!-- Toasts -->
    <div class="db-toast-area">
      <% if (typeof mensagemSucesso !== 'undefined' && mensagemSucesso) { %>
        <div class="db-toast success" role="alert">
          <i class="fas fa-circle-check"></i>
          <span><strong>Sucesso!</strong> <%= mensagemSucesso %></span>
          <button class="db-toast-close" onclick="this.closest('.db-toast').remove()" aria-label="Fechar">&times;</button>
        </div>
      <% } %>
      <% if (typeof mensagemErro !== 'undefined' && mensagemErro) { %>
        <div class="db-toast error" role="alert">
          <i class="fas fa-triangle-exclamation"></i>
          <span><strong>Erro!</strong> <%= mensagemErro %></span>
          <button class="db-toast-close" onclick="this.closest('.db-toast').remove()" aria-label="Fechar">&times;</button>
        </div>
      <% } %>
    </div>

    <!-- Page Header -->
    <div class="db-header">
      <div>
        <h1 class="db-header-title">Painel de Aprovação</h1>
        <p class="db-header-sub">Gerencie inscrições de encontristas e encontreiros em tempo real</p>
      </div>
      <div class="db-header-actions">
        <div class="event-scope-switch" role="group" aria-label="Escopo de evento">
          <button
            type="button"
            class="event-scope-btn <%= (escopoEventoAdmin || 'ativo') === 'ativo' ? 'active' : '' %>"
            data-event-scope="ativo"
            aria-pressed="<%= (escopoEventoAdmin || 'ativo') === 'ativo' ? 'true' : 'false' %>">
            <i class="fas fa-bullseye"></i>Evento ativo
          </button>
          <button
            type="button"
            class="event-scope-btn <%= (escopoEventoAdmin || 'ativo') === 'todos' ? 'active' : '' %>"
            data-event-scope="todos"
            aria-pressed="<%= (escopoEventoAdmin || 'ativo') === 'todos' ? 'true' : 'false' %>">
            <i class="fas fa-layer-group"></i>Todos
          </button>
        </div>
        <a href="/admin/gerenciar-cadastros" class="btn-action btn-action-primary">
          <i class="fas fa-users-cog"></i>Gerenciar Cadastros
        </a>
        <span class="live-badge"><span class="live-dot"></span>Fluxo ativo</span>
        <div class="motion-mode-switch" role="group" aria-label="Modo de animação">
          <button type="button" class="motion-mode-btn" data-motion-mode="executivo" aria-pressed="false">
            <i class="fas fa-gauge-high"></i>Executivo
          </button>
          <button type="button" class="motion-mode-btn" data-motion-mode="premium" aria-pressed="true">
            <i class="fas fa-sparkles"></i>Premium
          </button>
        </div>
      </div>
    </div>

    <div class="event-filter-banner">
      <i class="fas fa-filter-circle-dollar"></i>
      <span>
        <strong>Escopo:</strong>
        <%= (escopoEventoAdmin || 'ativo') === 'todos'
          ? 'Mostrando todos os eventos'
          : ('Evento ativo: ' + (eventoFiltroNome || eventoAtivoNome || 'Nao definido')) %>
      </span>
    </div>

    <section class="quick-workbench" aria-label="Filtros avançados">
      <div class="quick-workbench-title">
        <i class="fas fa-sliders"></i>
        <span>Filtros avançados</span>
      </div>
      <div class="quick-filters-grid">
        <label class="quick-filter-field">
          <span>Status</span>
          <select id="filter-status">
            <option value="all">Todos</option>
            <option value="pendente">Em análise</option>
            <option value="aprovado">Aprovados</option>
            <option value="reprovado">Reprovados</option>
          </select>
        </label>
        <label class="quick-filter-field">
          <span>Equipe</span>
          <select id="filter-team">
            <option value="all">Todas</option>
            <% equipesUnicas.forEach((equipe) => { %>
              <option value="<%= equipe.toLowerCase() %>"><%= equipe %></option>
            <% }); %>
          </select>
        </label>
        <label class="quick-filter-field">
          <span>De</span>
          <input type="date" id="filter-date-from" />
        </label>
        <label class="quick-filter-field">
          <span>Até</span>
          <input type="date" id="filter-date-to" />
        </label>
      </div>
      <div class="quick-filter-actions">
        <button type="button" class="batch-btn" id="save-filters-btn"><i class="fas fa-bookmark"></i>Salvar filtros</button>
        <button type="button" class="batch-btn" id="clear-filters-btn"><i class="fas fa-rotate-left"></i>Limpar filtros</button>
      </div>
    </section>

    <section class="strategy-strip" aria-label="Ações recomendadas hoje">
      <div class="strategy-head">
        <h2 class="strategy-title"><i class="fas fa-compass"></i>Ações recomendadas hoje</h2>
        <span class="strategy-sub">Priorização automática com base no estado atual do funil</span>
      </div>
      <div class="strategy-grid">
        <% acoesRecomendadas.slice(0, 3).forEach((acao) => { %>
          <article class="strategy-card <%= acao.tone %>">
            <div class="strategy-icon"><i class="fas <%= acao.icon %>"></i></div>
            <div>
              <h3 class="strategy-card-title"><%= acao.titulo %></h3>
              <p class="strategy-card-text"><%= acao.texto %></p>
            </div>
          </article>
        <% }); %>
      </div>
    </section>

    <!-- Stats -->
    <div class="stats-row">
      <div class="stat-tile amber-tile priority-tile">
        <div class="stat-tile-icon amber"><i class="fas fa-clock"></i></div>
        <div>
          <div class="stat-tile-num"><%= totalPendentes %></div>
          <div class="stat-tile-lbl">Pendentes (Prioridade)</div>
          <div class="stat-tile-trend <%= pendenciaCritica ? 'trend-up trend-alert' : 'trend-down trend-good' %>">
            <i class="fas <%= pendenciaCritica ? 'fa-arrow-trend-up' : 'fa-arrow-trend-down' %>"></i>
            <span><%= pressaoPendencia %>% do funil aguardando análise</span>
          </div>
        </div>
      </div>
      <div class="stat-tile green-tile">
        <div class="stat-tile-icon green"><i class="fas fa-chart-line"></i></div>
        <div>
          <div class="stat-tile-num"><%= taxaAprovacao %>%</div>
          <div class="stat-tile-lbl">Taxa de Aprovação</div>
          <div class="stat-tile-trend <%= aprovacaoSaudavel ? 'trend-up trend-good' : 'trend-down trend-alert' %>">
            <i class="fas <%= aprovacaoSaudavel ? 'fa-arrow-trend-up' : 'fa-arrow-trend-down' %>"></i>
            <span><%= totalAprovados %> aprovados de <%= totalProcessados %> processados</span>
          </div>
        </div>
      </div>
      <div class="stat-tile red-tile">
        <div class="stat-tile-icon red"><i class="fas fa-circle-xmark"></i></div>
        <div>
          <div class="stat-tile-num"><%= totalReprovados %></div>
          <div class="stat-tile-lbl">Reprovados</div>
          <div class="stat-tile-trend <%= riscoAlto ? 'trend-up trend-alert' : 'trend-down trend-good' %>">
            <i class="fas <%= riscoAlto ? 'fa-arrow-trend-up' : 'fa-arrow-trend-down' %>"></i>
            <span><%= indiceRisco %>% entre processados</span>
          </div>
        </div>
      </div>
      <div class="stat-tile blue-tile">
        <div class="stat-tile-icon blue"><i class="fas fa-users"></i></div>
        <div>
          <div class="stat-tile-num"><%= totalGeral %></div>
          <div class="stat-tile-lbl">Total Geral</div>
          <div class="stat-tile-trend trend-neutral">
            <i class="fas fa-layer-group"></i>
            <span><%= totalPendentes %> pendentes | <%= totalProcessados %> processados</span>
          </div>
        </div>
      </div>
    </div>

    <!-- ───────── ENCONTRISTAS ───────── -->
    <section class="section-panel approval-panel" data-approval-panel="encontristas">
      <div class="section-panel-head">
        <div class="approval-head-main">
          <div>
            <h2 class="section-panel-title"><i class="fas fa-user-graduate"></i>Encontristas</h2>
            <p class="approval-head-sub">Central de triagem e decisão operacional para inscrições de encontristas.</p>
          </div>
          <div class="section-meta">
            <span class="meta-chip amber"><i class="fas fa-clock"></i><%= totalPendentesEncontristas %> pendente(s)</span>
            <span class="meta-chip green"><i class="fas fa-check"></i><%= totalAprovadosEncontristas %> aprovado(s)</span>
            <span class="meta-chip red"><i class="fas fa-xmark"></i><%= totalReprovadosEncontristas %> reprovado(s)</span>
          </div>
        </div>
        <div class="export-row approval-head-tools">
          <a href="/export?format=pdf" class="export-btn" target="_blank" rel="noreferrer"><i class="fas fa-file-pdf"></i>PDF</a>
          <a href="/export-encontrista-excel" class="export-btn" target="_blank" rel="noreferrer"><i class="fas fa-table"></i>Excel</a>
          <a href="/export-images-encontristas" class="export-btn" target="_blank" rel="noreferrer"><i class="fas fa-images"></i>Imagens</a>
        </div>
        <div class="batch-toolbar approval-command-bar" data-batch-scope="encontrista">
          <span class="batch-counter">0 selecionado(s)</span>
          <span class="batch-separator"></span>
          <button type="button" class="batch-btn batch-filter-pending" onclick="selecionarPorStatusLote('encontrista','pendente')"><i class="fas fa-clock"></i>Pendentes</button>
          <button type="button" class="batch-btn batch-filter-approved" onclick="selecionarPorStatusLote('encontrista','aprovado')"><i class="fas fa-circle-check"></i>Aprovados</button>
          <button type="button" class="batch-btn batch-filter-rejected" onclick="selecionarPorStatusLote('encontrista','reprovado')"><i class="fas fa-circle-xmark"></i>Reprovados</button>
          <span class="batch-separator"></span>
          <button type="button" class="batch-btn batch-select-all" onclick="selecionarTodosLote('encontrista')"><i class="fas fa-check-double"></i>Todos</button>
          <button type="button" class="batch-btn batch-clear" onclick="limparSelecaoLote('encontrista')"><i class="fas fa-eraser"></i>Limpar</button>
          <span class="batch-separator"></span>
          <button type="button" class="batch-btn batch-approve" data-batch-action="aprovar" onclick="executarAcaoLote('encontrista', 'aprovar')" disabled><i class="fas fa-circle-check"></i>Aprovar selecionados</button>
          <button type="button" class="batch-btn batch-reject" data-batch-action="desaprovar" onclick="executarAcaoLote('encontrista', 'desaprovar')" disabled><i class="fas fa-circle-xmark"></i>Reprovar selecionados</button>
        </div>
        <div class="status-tabs approval-view-switch" data-board-tabs>
          <button type="button" class="status-tab active" data-view="all"><i class="fas fa-border-all"></i>Todos</button>
          <button type="button" class="status-tab" data-view="pendente"><i class="fas fa-clock"></i>Pendentes</button>
          <button type="button" class="status-tab" data-view="aprovado"><i class="fas fa-circle-check"></i>Aprovados</button>
          <button type="button" class="status-tab" data-view="reprovado"><i class="fas fa-circle-xmark"></i>Reprovados</button>
        </div>
      </div>

      <div class="kanban-board">
        <!-- Pendentes -->
        <div class="kanban-col col-pendente">
          <div class="kanban-col-head">
            <span class="kanban-col-label amber"><span class="dot"></span>Pendentes</span>
            <span class="kanban-count"><%= pendentesEncontristas.length %></span>
          </div>
          <% if (pendentesEncontristas.length === 0) { %>
            <div class="empty-col">
              <div class="empty-col-icon"><i class="fas fa-inbox"></i></div>
              <p class="empty-col-text">Nenhuma inscrição pendente</p>
            </div>
          <% } else { %>
            <% pendentesEncontristas.forEach(r => { %>
              <% const insights = construirInsights(r, 'pendente'); %>
              <div class="pcard amber-card selectable-card smart-card"
                   data-batch-card="encontrista:<%= r._id %>"
                   data-id="<%= r._id %>"
                   data-tipo="encontrista"
                   data-status="pendente"
                   data-team="<%= String(r.ejc || '').toLowerCase() %>"
                   data-date="<%= paraDataISO(r.dataCadastro) %>"
                   data-updated-date="<%= paraDataISO(r.dataAtualizacao || r.updatedAt || r.dataCadastro) %>"
                   data-incomplete="<%= insights.incompleto ? '1' : '0' %>"
                   data-duplicate="<%= insights.duplicado ? '1' : '0' %>"
                   data-recommended="<%= insights.recomendado ? '1' : '0' %>">
                <div class="pcard-top">
                  <label class="pcard-select" aria-label="Selecionar <%= r.nomeCompleto %>">
                    <input type="checkbox" class="batch-checkbox" data-batch-scope="encontrista" data-batch-id="<%= r._id %>" data-batch-tipo="encontrista" />
                    <span></span>
                  </label>
                  <div class="pcard-avatar">
                    <% if (r.foto) { %>
                      <img src="/img/uploads/<%= encodeURIComponent(r.foto) %>?w=100&h=100&fit=cover&format=webp" loading="lazy" decoding="async" alt="<%= r.nomeCompleto %>" />
                    <% } else { %><i class="fas fa-user"></i><% } %>
                  </div>
                  <div>
                    <div class="pcard-name"><%= r.nomeCompleto %></div>
                    <div class="pcard-meta">
                      <span><i class="fas fa-church"></i><%= r.ejc %></span>
                      <span><i class="fas fa-calendar-days"></i><%= new Date(r.dataCadastro).toLocaleDateString('pt-BR') %></span>
                    </div>
                  </div>
                </div>
                <div class="pcard-details">
                  <div><div class="pcard-field-lbl">Email</div><div class="pcard-field-val"><%= r.email %></div></div>
                  <div><div class="pcard-field-lbl">Telefone</div><div class="pcard-field-val"><%= r.telefone %></div></div>
                  <div><div class="pcard-field-lbl">Logradouro</div><div class="pcard-field-val"><%= r.logradouro %></div></div>
                  <div><div class="pcard-field-lbl">Bairro</div><div class="pcard-field-val"><%= r.bairro %></div></div>
                  <div><div class="pcard-field-lbl">Nascimento</div><div class="pcard-field-val"><%= new Date(r.dataNascimento).toLocaleDateString('pt-BR') %></div></div>
                </div>
                <div class="pcard-actions">
                  <button class="pcard-btn approve" onclick="aprovarCadastro('<%= r._id %>', 'encontrista')"><i class="fas fa-check"></i>Aprovar</button>
                  <button class="pcard-btn reject" onclick="desaprovarCadastro('<%= r._id %>', 'encontrista')"><i class="fas fa-xmark"></i>Reprovar</button>
                  <button class="pcard-btn details" type="button" onclick="toggleCardDetails(this)"><i class="fas fa-eye"></i>Ver detalhes</button>
                </div>
              </div>
            <% }); %>
          <% } %>
        </div>

        <!-- Aprovados -->
        <div class="kanban-col col-aprovado">
          <div class="kanban-col-head">
            <span class="kanban-col-label green"><span class="dot"></span>Aprovados</span>
            <span class="kanban-count"><%= aprovadosEncontristas.length %></span>
          </div>
          <% if (aprovadosEncontristas.length === 0) { %>
            <div class="empty-col">
              <div class="empty-col-icon"><i class="fas fa-inbox"></i></div>
              <p class="empty-col-text">Nenhuma inscrição aprovada</p>
            </div>
          <% } else { %>
            <% aprovadosEncontristas.forEach(r => { %>
              <% const insights = construirInsights(r, 'aprovado'); %>
              <div class="pcard green-card selectable-card smart-card"
                   data-batch-card="encontrista:<%= r._id %>"
                   data-id="<%= r._id %>"
                   data-tipo="encontrista"
                   data-status="aprovado"
                   data-team="<%= String(r.ejc || '').toLowerCase() %>"
                   data-date="<%= paraDataISO(r.dataCadastro) %>"
                   data-updated-date="<%= paraDataISO(r.dataAtualizacao || r.updatedAt || r.dataCadastro) %>"
                   data-incomplete="<%= insights.incompleto ? '1' : '0' %>"
                   data-duplicate="<%= insights.duplicado ? '1' : '0' %>"
                   data-recommended="<%= insights.recomendado ? '1' : '0' %>">
                <div class="pcard-top">
                  <label class="pcard-select" aria-label="Selecionar <%= r.nomeCompleto %>">
