            <i class="fas fa-file-pdf me-1"></i>PDF
          </a>
          <a href="/export-encontro-excel" class="btn btn-sm btn-outline-secondary export-btn" target="_blank" rel="noreferrer" title="Exportar Relat&oacute;rio em Excel">
            <i class="fas fa-table me-1"></i>Relat&oacute;rio
          </a>
