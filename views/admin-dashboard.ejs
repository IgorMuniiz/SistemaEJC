                <div class="pcard-top">
                  <div class="pcard-avatar">
                    <% if (r.foto) { %>
                      <img src="/img/uploads/<%= encodeURIComponent(r.foto) %>?w=100&h=100&fit=cover&format=webp" loading="lazy" decoding="async" alt="<%= r.nomeCompleto %>" />
                    <% } else { %><i class="fas fa-user"></i><% } %>
                  </div>
                  <div>
