<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8" />
  <meta http-equiv="X-UA-Compatible" content="IE=edge" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content="Dashboard do Administrador" />
  <title>Admin - Dashboard</title>
    <link rel="preload" href="/vendor/bootstrap/css/bootstrap.min.css" as="style" onload="this.onload=null;this.rel='stylesheet'">
  <noscript><link rel="stylesheet" href="/vendor/bootstrap/css/bootstrap.min.css"></noscript>
  <link rel="preload" href="/vendor/fontawesome/css/all.min.css" as="style" onload="this.onload=null;this.rel='stylesheet'">
  <noscript><link rel="stylesheet" href="/vendor/fontawesome/css/all.min.css"></noscript>
  <link rel="stylesheet" href="/css/style.css" />
  <link rel="stylesheet" href="/css/admin-saas.css">
  <style>
    body {
      background-color: #0a0a0f;
      font-family: 'Inter', sans-serif;
    }

    .navbar-admin {
      background: linear-gradient(120deg, #16324f 0%, #1f4f7a 50%, #2b6a99 100%);
      box-shadow: 0 8px 24px rgba(9, 24, 39, 0.25);
      border-bottom: 1px solid rgba(255, 255, 255, 0.12);
      padding: 12px 0;
    }

    .brand-wrap {
      display: flex;
      align-items: center;
      gap: 12px;
      color: #fff;
    }

    .brand-icon {
      width: 42px;
      height: 42px;
      border-radius: 10px;
      display: grid;
      place-items: center;
      background: rgba(255, 255, 255, 0.16);
      border: 1px solid rgba(255, 255, 255, 0.22);
      font-size: 1.1rem;
    }

    .brand-title {
      font-weight: 700;
      font-size: 1.05rem;
      line-height: 1.1;
      margin: 0;
      letter-spacing: 0.2px;
    }

    .brand-subtitle {
      margin: 2px 0 0;
      font-size: 0.78rem;
      color: rgba(255, 255, 255, 0.82);
      font-weight: 500;
      letter-spacing: 0.15px;
    }

    .admin-user {
      color: rgba(255, 255, 255, 0.9);
      font-weight: 600;
    }

    .admin-badge {
      background: rgba(255, 255, 255, 0.16);
      border: 1px solid rgba(255, 255, 255, 0.28);
      border-radius: 999px;
      padding: 6px 12px;
      font-size: 0.78rem;
      color: #fff;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.5px;
    }

    .btn-logout {
      background-color: rgba(255, 255, 255, 0.2);
      color: white;
      border: 1px solid rgba(255, 255, 255, 0.3);
      padding: 8px 20px;
      border-radius: 6px;
      transition: all 0.3s ease;
      text-decoration: none;
      display: inline-block;
      font-weight: 600;
    }

    .btn-logout:hover {
      background-color: rgba(255, 255, 255, 0.3);
      color: white;
      transform: translateY(-1px);
    }

    .dashboard-header {
      background: rgba(26, 26, 32, 0.6);
      backdrop-filter: blur(20px);
      border: 1px solid rgba(255, 255, 255, 0.08);
      border-radius: 20px;
      padding: 32px 40px;
      margin-bottom: 32px;
      box-shadow: 0 8px 32px rgba(0, 0, 0, 0.2);
      display: flex;
      justify-content: space-between;
      align-items: center;
      gap: 24px;
      flex-wrap: wrap;
    }

    .dashboard-title {
      color: #fff;
      font-weight: 800;
      font-size: 2.2rem;
      margin-bottom: 8px;
      background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
    }

    .dashboard-subtitle {
      color: rgba(255, 255, 255, 0.6);
      font-size: 0.95rem;
      margin: 0;
    }

    .dashboard-status {
      background: rgba(16, 185, 129, 0.15);
      color: #34d399;
      border: 1px solid rgba(16, 185, 129, 0.3);
      padding: 10px 18px;
      border-radius: 12px;
      font-size: 0.82rem;
      font-weight: 700;
      white-space: nowrap;
    }

    .stats-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
      gap: 20px;
      margin-bottom: 32px;
    }

    .stat-card {
      background: rgba(26, 26, 32, 0.6);
      backdrop-filter: blur(20px);
      border: 1px solid rgba(255, 255, 255, 0.08);
      padding: 32px;
      border-radius: 16px;
      box-shadow: 0 4px 24px rgba(0, 0, 0, 0.2);
      transition: all 0.3s ease;
    }

    .stat-card:hover {
      transform: translateY(-6px);
      box-shadow: 0 12px 40px rgba(0, 0, 0, 0.3);
      border-color: rgba(255, 255, 255, 0.12);
    }

    .stat-number {
      font-size: 2.8rem;
      font-weight: 800;
      margin-bottom: 8px;
      color: #fff;
    }

    .stat-label {
      color: rgba(255, 255, 255, 0.6);
      font-size: 0.95rem;
      font-weight: 600;
    }

    .stat-pending {
      border-left: 4px solid #f59e0b;
    }

    .stat-pending .stat-number {
      color: #fbbf24;
    }

    .stat-approved {
      border-left: 4px solid #10b981;
    }

    .stat-approved .stat-number {
      color: #34d399;
    }

    .stat-rejected {
      border-left: 4px solid #ef4444;
    }

    .stat-rejected .stat-number {
      color: #f87171;
    }

    .section-title {
      color: #fff;
      font-weight: 800;
      font-size: 1.6rem;
      margin-bottom: 24px;
      padding-bottom: 18px;
      border-bottom: 2px solid rgba(102, 126, 234, 0.3);
      display: flex;
      align-items: center;
      gap: 12px;
    }

    .section-title i {
      color: #667eea;
      font-size: 1.4rem;
    }

    .registration-card {
      background: rgba(26, 26, 32, 0.6);
      backdrop-filter: blur(20px);
      border: 1px solid rgba(255, 255, 255, 0.08);
      border-radius: 16px;
      overflow: hidden;
      box-shadow: 0 4px 24px rgba(0, 0, 0, 0.2);
      transition: all 0.3s ease;
      margin-bottom: 18px;
      border-left: 4px solid #f59e0b;
    }

    .registration-card.approved {
      border-left-color: #10b981;
    }

    .registration-card.rejected {
      border-left-color: #ef4444;
    }

    .registration-card:hover {
      transform: translateY(-3px);
      box-shadow: 0 12px 40px rgba(0, 0, 0, 0.3);
      border-color: rgba(255, 255, 255, 0.12);
    }

    .card-header-admin {
      display: flex;
      align-items: center;
      gap: 15px;
      padding: 24px;
      background: rgba(255, 255, 255, 0.03);
      border-bottom: 1px solid rgba(255, 255, 255, 0.08);
    }

    .card-photo {
      width: 70px;
      height: 70px;
      border-radius: 12px;
      object-fit: cover;
      background-color: rgba(255, 255, 255, 0.08);
      border: 1px solid rgba(255, 255, 255, 0.1);
    }

    .card-info {
      flex: 1;
    }

    .card-name {
      font-size: 1.1rem;
      font-weight: 700;
      color: #fff;
      margin-bottom: 5px;
    }

    .card-detail {
      font-size: 0.85rem;
      color: rgba(255, 255, 255, 0.6);
      margin-bottom: 3px;
    }

    .card-body-admin {
      padding: 24px;
    }

    .detail-row {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 24px;
      margin-bottom: 12px;
    }

    .detail-item {
      font-size: 0.9rem;
    }

    .detail-label {
      color: rgba(255, 255, 255, 0.5);
      font-weight: 600;
      margin-bottom: 6px;
      font-size: 0.8rem;
      text-transform: uppercase;
      letter-spacing: 0.5px;
    }

    .detail-value {
      color: rgba(255, 255, 255, 0.9);
      font-weight: 500;
      word-break: break-word;
    }

    .card-actions {
      padding: 24px;
      background: rgba(255, 255, 255, 0.02);
      border-top: 1px solid rgba(255, 255, 255, 0.08);
      display: flex;
      gap: 12px;
    }

    .btn-approve, .btn-disapprove {
      flex: 1;
      padding: 12px;
      border: none;
      border-radius: 10px;
      font-weight: 600;
      cursor: pointer;
      transition: all 0.3s ease;
      font-size: 0.9rem;
      border: 1.5px solid transparent;
    }

    .btn-approve {
      background: linear-gradient(135deg, #10b981 0%, #059669 100%);
      color: white;
      box-shadow: 0 4px 12px rgba(16, 185, 129, 0.3);
    }

    .btn-approve:hover {
      transform: translateY(-2px);
      box-shadow: 0 6px 16px rgba(16, 185, 129, 0.4);
    }

    .btn-disapprove {
      background: rgba(239, 68, 68, 0.1);
      color: #f87171;
      border-color: rgba(239, 68, 68, 0.3);
    }

    .btn-disapprove:hover {
      background: rgba(239, 68, 68, 0.2);
      border-color: #f87171;
      transform: translateY(-2px);
    }

    .empty-state {
      text-align: center;
      padding: 80px 20px;
      color: rgba(255, 255, 255, 0.5);
    }

    .empty-state-icon {
      font-size: 4rem;
      margin-bottom: 20px;
      color: rgba(255, 255, 255, 0.2);
    }

    .empty-state-title {
      font-size: 1.4rem;
      font-weight: 700;
      color: rgba(255, 255, 255, 0.8);
      margin-bottom: 10px;
    }

    .approval-group {
      margin-bottom: 32px;
      background: rgba(26, 26, 32, 0.6);
      backdrop-filter: blur(20px);
      border: 1px solid rgba(255, 255, 255, 0.08);
      border-radius: 16px;
      box-shadow: 0 4px 24px rgba(0, 0, 0, 0.2);
      overflow: hidden;
      transition: all 0.3s ease;
    }

    .approval-group:hover {
      border-color: rgba(255, 255, 255, 0.12);
      box-shadow: 0 8px 32px rgba(0, 0, 0, 0.25);
    }

    .approval-group-header {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 16px;
      flex-wrap: wrap;
      background: rgba(255, 255, 255, 0.03);
      border-bottom: 1px solid rgba(255, 255, 255, 0.08);
      padding: 18px 24px;
    }

    .approval-group-title {
      margin: 0;
      font-size: 1.2rem;
      font-weight: 700;
      color: #fff;
      display: flex;
      align-items: center;
      gap: 10px;
    }

    .approval-group-title i {
      color: #667eea;
    }

    .approval-group-body {
      padding: 24px;
    }

    .approval-columns {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 24px;
    }

    .approval-column-title {
      margin: 0 0 18px;
      font-size: 1rem;
      font-weight: 700;
      color: rgba(255, 255, 255, 0.9);
      display: flex;
      align-items: center;
      gap: 8px;
      padding-bottom: 12px;
      border-bottom: 1px solid rgba(255, 255, 255, 0.08);
    }

    .counter-pill {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      background: rgba(102, 126, 234, 0.15);
      color: #a5b4fc;
      border: 1px solid rgba(102, 126, 234, 0.3);
      border-radius: 999px;
      padding: 8px 14px;
      font-size: 0.8rem;
      font-weight: 700;
      margin-bottom: 12px;
    }

    .export-group-actions {
      display: flex;
      gap: 10px;
      align-items: center;
    }

    .export-btn {
      background: rgba(255, 255, 255, 0.05);
      color: rgba(255, 255, 255, 0.7);
      border: 1.5px solid rgba(255, 255, 255, 0.1);
      border-radius: 10px;
      padding: 8px 14px;
      font-size: 0.78rem;
      font-weight: 600;
      transition: all 0.2s ease;
      text-decoration: none;
      display: inline-flex;
      align-items: center;
      gap: 6px;
      white-space: nowrap;
    }

    .export-btn:hover {
      background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
      color: #fff;
      border-color: transparent;
      transform: translateY(-2px);
      text-decoration: none;
      box-shadow: 0 4px 12px rgba(102, 126, 234, 0.3);
    }

    @media (max-width: 768px) {
      .stats-grid {
        grid-template-columns: 1fr;
      }

      .approval-columns {
        grid-template-columns: 1fr;
      }

      .detail-row {
        grid-template-columns: 1fr;
      }

      .card-actions {
        flex-direction: column;
      }

      .approval-group-header {
        flex-direction: column;
        align-items: flex-start;
      }

      .export-group-actions {
        flex-wrap: wrap;
        width: 100%;
      }

      .export-btn {
        font-size: 0.75rem;
        padding: 7px 12px;
      }

      .dashboard-header {
        padding: 24px 20px;
        flex-direction: column;
      }

      .dashboard-title {
        font-size: 1.8rem;
      }

      .stat-number {
        font-size: 2.2rem;
      }
    }
  </style>
</head>
<body class="admin-panel">
  <div class="admin-background"></div>
  <!-- Navbar -->
  <nav class="navbar navbar-expand-lg" style="background: rgba(26, 26, 32, 0.95); backdrop-filter: blur(20px); border-bottom: 1px solid rgba(255, 255, 255, 0.08); position: sticky; top: 0; z-index: 1000;">
    <div class="container-fluid">
      <div class="brand-wrap">
        <div class="card-icon" style="width: 42px; height: 42px; font-size: 1.1rem;">
          <i class="fas fa-shield-alt"></i>
        </div>
        <div>
          <p class="brand-title" style="color: var(--neutral-50); margin: 0; font-weight: 700; font-size: 1.05rem;">EJC Painel Administrativo</p>
          <p class="brand-subtitle" style="color: var(--neutral-400); margin: 0; font-size: 0.8rem;">Gestão de inscrições e aprovações</p>
        </div>
      </div>
      <div class="d-flex align-items-center gap-3">
        <a href="/" class="btn-saas btn-saas-secondary btn-sm"><i class="fas fa-house me-1"></i>Início</a>
        <a href="/admin/gerenciar-cadastros" class="btn-saas btn-saas-secondary btn-sm"><i class="fas fa-table-columns me-1"></i>Painel</a>
        <span class="user-info-badge">
          <i class="fas fa-user-circle me-2"></i><%= adminUsername %>
        </span>
        <a href="/admin/logout" class="logout-btn">
          <i class="fas fa-sign-out-alt me-2"></i>Sair
        </a>
      </div>
    </div>
  </nav>

  <!-- Mensagens de Feedback -->
  <% if (typeof mensagemSucesso !== 'undefined' && mensagemSucesso) { %>
    <div class="container mt-3">
      <div class="alert alert-success alert-dismissible fade show" role="alert">
        <i class="fas fa-check-circle me-2"></i><strong>Sucesso!</strong> <%= mensagemSucesso %>
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
      </div>
    </div>
  <% } %>
  <% if (typeof mensagemErro !== 'undefined' && mensagemErro) { %>
    <div class="container mt-3">
      <div class="alert alert-danger alert-dismissible fade show" role="alert">
        <i class="fas fa-exclamation-circle me-2"></i><strong>Erro!</strong> <%= mensagemErro %>
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
      </div>
    </div>
  <% } %>

  <!-- Main Content -->
  <div class="container mt-5 mb-5">
    <!-- Header -->
    <div class="dashboard-header">
      <div>
        <h1 class="dashboard-title"><i class="fas fa-tasks me-2"></i>Painel de Aprova&ccedil;&atilde;o</h1>
        <p class="dashboard-subtitle">Gerenciamento separado de inscri&ccedil;&otilde;es de encontristas e encontreiros</p>
      </div>
      <div class="d-flex gap-2 align-items-center">
        <a href="/admin/gerenciar-cadastros" class="btn btn-primary">
          <i class="fas fa-users-cog me-2"></i>Gerenciar Cadastros
        </a>
        <div class="dashboard-status">
          <i class="fas fa-circle-check me-2"></i>Fluxo de aprova&ccedil;&atilde;o ativo
        </div>
      </div>
    </div>

    <!-- Stats -->
    <div class="stats-grid">
      <div class="stat-card stat-pending">
        <div class="stat-number"><%= totalPendentesEncontristas + totalPendentesEncontreiros %></div>
        <div class="stat-label">Pendentes Totais</div>
      </div>
      <div class="stat-card stat-approved">
        <div class="stat-number"><%= totalAprovadosEncontristas + totalAprovadosEncontreiros %></div>
        <div class="stat-label">Aprovados Totais</div>
      </div>
      <div class="stat-card stat-rejected">
        <div class="stat-number"><%= totalReprovadosEncontristas + totalReprovadosEncontreiros %></div>
        <div class="stat-label">Reprovados Totais</div>
      </div>
    </div>

    <section class="approval-group">
      <div class="approval-group-header">
        <h2 class="approval-group-title"><i class="fas fa-user me-2"></i>Inscri&ccedil;&otilde;es de Encontristas</h2>
        <div class="counter-pill">
          Pendentes: <%= totalPendentesEncontristas %> | Aprovados: <%= totalAprovadosEncontristas %> | Reprovados: <%= totalReprovadosEncontristas %>
        </div>
        <div class="export-group-actions">
          <a href="/export?format=pdf" class="btn btn-sm btn-outline-secondary export-btn" target="_blank" rel="noreferrer" title="Exportar como PDF">
            <i class="fas fa-file-pdf me-1"></i>PDF
          </a>
          <a href="/export-encontrista-excel" class="btn btn-sm btn-outline-secondary export-btn" target="_blank" rel="noreferrer" title="Exportar Relat&oacute;rio em Excel">
            <i class="fas fa-table me-1"></i>Relat&oacute;rio
          </a>
          <a href="/export-images-encontristas" class="btn btn-sm btn-outline-secondary export-btn" target="_blank" rel="noreferrer" title="Exportar Imagens">
            <i class="fas fa-file-archive me-1"></i>Imagens
          </a>
        </div>
      </div>
      <div class="approval-group-body">
        <div class="approval-columns">
          <div>
            <h3 class="approval-column-title">Pendentes</h3>
            <% if (pendentesEncontristas.length === 0) { %>
              <div class="empty-state">
                <div class="empty-state-icon"><i class="fas fa-inbox"></i></div>
                <div class="empty-state-title">Nenhuma inscricao pendente</div>
              </div>
            <% } else { %>
              <% pendentesEncontristas.forEach(registro => { %>
                <div class="registration-card">
                  <div class="card-header-admin">
                    <% if (registro.foto) { %>
                      <img src="/img/uploads/<%= encodeURIComponent(registro.foto) %>?w=120&h=120&fit=cover&format=webp" loading="lazy" decoding="async" alt="<%= registro.nomeCompleto %>" class="card-photo" />
                    <% } else { %>
                      <div class="card-photo" style="display: flex; align-items: center; justify-content: center;">
                        <i class="fas fa-user" style="font-size: 2rem; color: #999;"></i>
                      </div>
                    <% } %>
                    <div class="card-info">
                      <div class="card-name"><%= registro.nomeCompleto %></div>
                      <div class="card-detail"><i class="fas fa-church me-2"></i><%= registro.ejc %></div>
                      <div class="card-detail"><i class="fas fa-calendar me-2"></i><%= new Date(registro.dataCadastro).toLocaleDateString('pt-BR') %></div>
                    </div>
                  </div>
                  <div class="card-body-admin">
                    <div class="detail-row">
                      <div class="detail-item"><div class="detail-label">Email</div><div class="detail-value"><%= registro.email %></div></div>
                      <div class="detail-item"><div class="detail-label">Telefone</div><div class="detail-value"><%= registro.telefone %></div></div>
                    </div>
                    <div class="detail-row">
                      <div class="detail-item"><div class="detail-label">Logradouro</div><div class="detail-value"><%= registro.logradouro %></div></div>
                      <div class="detail-item"><div class="detail-label">Bairro</div><div class="detail-value"><%= registro.bairro %></div></div>
                      <div class="detail-item"><div class="detail-label">Data de Nascimento</div><div class="detail-value"><%= new Date(registro.dataNascimento).toLocaleDateString('pt-BR') %></div></div>
                    </div>
                  </div>
                  <div class="card-actions">
                    <button class="btn-approve" type="button" onclick="aprovarCadastro('<%= registro._id %>', 'encontrista')"><i class="fas fa-check me-2"></i>Aprovar</button>
                  </div>
                </div>
              <% }); %>
            <% } %>
          </div>

          <div>
            <h3 class="approval-column-title">Aprovados</h3>
            <% if (aprovadosEncontristas.length === 0) { %>
              <div class="empty-state">
                <div class="empty-state-icon"><i class="fas fa-inbox"></i></div>
                <div class="empty-state-title">Nenhuma inscricao aprovada</div>
              </div>
            <% } else { %>
              <% aprovadosEncontristas.forEach(registro => { %>
                <div class="registration-card approved">
                  <div class="card-header-admin">
                    <% if (registro.foto) { %>
                      <img src="/img/uploads/<%= encodeURIComponent(registro.foto) %>?w=120&h=120&fit=cover&format=webp" loading="lazy" decoding="async" alt="<%= registro.nomeCompleto %>" class="card-photo" />
                    <% } else { %>
                      <div class="card-photo" style="display: flex; align-items: center; justify-content: center;">
                        <i class="fas fa-user" style="font-size: 2rem; color: #999;"></i>
                      </div>
                    <% } %>
                    <div class="card-info">
                      <div class="card-name"><%= registro.nomeCompleto %></div>
                      <div class="card-detail"><i class="fas fa-church me-2"></i><%= registro.ejc %></div>
                      <div class="card-detail"><i class="fas fa-calendar me-2"></i><%= new Date(registro.dataCadastro).toLocaleDateString('pt-BR') %></div>
                    </div>
                  </div>
                  <div class="card-actions">
                    <button class="btn-disapprove" type="button" onclick="desaprovarCadastro('<%= registro._id %>', 'encontrista')"><i class="fas fa-times me-2"></i>Desaprovar</button>
                  </div>
                </div>
              <% }); %>
            <% } %>
          </div>

          <div>
            <h3 class="approval-column-title">Reprovados</h3>
            <% if (reprovadosEncontristas.length === 0) { %>
              <div class="empty-state">
                <div class="empty-state-icon"><i class="fas fa-inbox"></i></div>
                <div class="empty-state-title">Nenhuma inscricao reprovada</div>
              </div>
            <% } else { %>
              <% reprovadosEncontristas.forEach(registro => { %>
