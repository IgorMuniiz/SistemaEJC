  <script src="/vendor/bootstrap/js/bootstrap.bundle.min.js"></script>
  <script>
    /* ── Modal helper ────────────────────────────────────────── */
    function ensureAppPopup() {
      let el = document.getElementById('app-popup-modal');
      if (el) return { element: el, instance: bootstrap.Modal.getOrCreateInstance(el) };
      el = document.createElement('div');
      el.className = 'modal fade';
      el.id = 'app-popup-modal';
      el.tabIndex = -1;
      el.setAttribute('aria-hidden', 'true');
      el.innerHTML = `
        <div class="modal-dialog modal-dialog-centered app-popup-dialog">
          <div class="modal-content app-popup-content app-popup-tone-primary">
            <div class="modal-header app-popup-header">
              <h5 class="modal-title" id="app-popup-title">Aviso</h5>
              <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Fechar"></button>
            </div>
            <div class="modal-body app-popup-body">
              <p id="app-popup-message" class="mb-0" style="white-space:pre-line;"></p>
            </div>
            <div class="modal-footer app-popup-footer">
              <button type="button" class="btn btn-outline-secondary" id="app-popup-cancel">Cancelar</button>
              <button type="button" class="btn btn-primary" id="app-popup-confirm">OK</button>
            </div>
          </div>
        </div>`;
      document.body.appendChild(el);
      return { element: el, instance: bootstrap.Modal.getOrCreateInstance(el) };
    }

    function showAppPopup({ title, message, confirmText = 'OK', cancelText = null, tone = 'primary' }) {
      const { element, instance } = ensureAppPopup();
      element.querySelector('#app-popup-title').textContent = title || 'Aviso';
      element.querySelector('#app-popup-message').textContent = message || '';
      const confirmBtn = element.querySelector('#app-popup-confirm');
      const cancelBtn  = element.querySelector('#app-popup-cancel');
      const contentEl  = element.querySelector('.app-popup-content');
      confirmBtn.textContent = confirmText;
      confirmBtn.className = `btn btn-${tone}`;
      if (contentEl) {
        contentEl.classList.remove('app-popup-tone-primary', 'app-popup-tone-warning', 'app-popup-tone-danger', 'app-popup-tone-success');
        contentEl.classList.add(`app-popup-tone-${tone}`);
      }
      cancelBtn.style.display = cancelText ? '' : 'none';
      if (cancelText) cancelBtn.textContent = cancelText;

      return new Promise(resolve => {
        let resolved = false;
        const cleanup = () => {
          confirmBtn.removeEventListener('click', onConfirm);
          cancelBtn.removeEventListener('click', onCancel);
          element.removeEventListener('hidden.bs.modal', onHidden);
        };
        const settle = v => { if (resolved) return; resolved = true; cleanup(); resolve(v); };
        const onConfirm = () => { settle(true);  instance.hide(); };
        const onCancel  = () => { settle(false); instance.hide(); };
        const onHidden  = () => settle(false);
        confirmBtn.addEventListener('click', onConfirm);
        cancelBtn.addEventListener('click', onCancel);
        element.addEventListener('hidden.bs.modal', onHidden, { once: true });
        instance.show();
      });
    }

    const appAlert   = (msg, tone = 'primary', title = 'Aviso') =>
      showAppPopup({ title, message: msg, confirmText: 'Entendi', tone });
    const appConfirm = (msg, title = 'Confirmação') =>
      showAppPopup({ title, message: msg, confirmText: 'Confirmar', cancelText: 'Cancelar', tone: 'warning' });

    const MOTION_MODE_STORAGE_KEY = 'ejc-dashboard-motion-mode';
    const FILTERS_STORAGE_KEY = 'ejc-dashboard-filters';

    function applyMotionMode(mode) {
      const normalized = mode === 'executivo' ? 'executivo' : 'premium';
      document.body.classList.remove('motion-mode-executivo', 'motion-mode-premium');
      document.body.classList.add(`motion-mode-${normalized}`);

      document.querySelectorAll('.motion-mode-btn[data-motion-mode]').forEach((button) => {
        const isActive = button.dataset.motionMode === normalized;
        button.classList.toggle('active', isActive);
        button.setAttribute('aria-pressed', String(isActive));
      });
    }

    function setupMotionModeControls() {
      const savedMode = localStorage.getItem(MOTION_MODE_STORAGE_KEY);
      applyMotionMode(savedMode === 'executivo' ? 'executivo' : 'premium');

      document.querySelectorAll('.motion-mode-btn[data-motion-mode]').forEach((button) => {
        button.addEventListener('click', () => {
          const selectedMode = button.dataset.motionMode === 'executivo' ? 'executivo' : 'premium';
          applyMotionMode(selectedMode);
          localStorage.setItem(MOTION_MODE_STORAGE_KEY, selectedMode);
        });
      });
    }

    function setupEventScopeControls() {
      const buttons = Array.from(document.querySelectorAll('.event-scope-btn[data-event-scope]'));
      if (buttons.length === 0) return;

      buttons.forEach((button) => {
        button.addEventListener('click', async () => {
          const nextScope = button.dataset.eventScope === 'todos' ? 'todos' : 'ativo';
          buttons.forEach((b) => {
            const active = b === button;
            b.classList.toggle('active', active);
            b.setAttribute('aria-pressed', String(active));
            b.disabled = true;
          });

          try {
            const res = await fetch('/admin/evento-scope', {
              method: 'POST',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify({ scope: nextScope }),
            });
            const data = await res.json();
            if (!res.ok || !data.success) {
              throw new Error(data.error || 'Falha ao trocar escopo de evento.');
            }

            window.location.reload();
          } catch (error) {
            buttons.forEach((b) => {
              b.disabled = false;
            });
            await appAlert('Erro: ' + error.message, 'danger', 'Escopo de evento');
          }
        });
      });
    }

    function formatarDataCurta(dateIso) {
      if (!dateIso) return 'Data não informada';
      const data = new Date(`${dateIso}T00:00:00`);
      if (Number.isNaN(data.getTime())) return 'Data não informada';
      return data.toLocaleDateString('pt-BR');
    }

    function refreshVisibleCounts() {
      document.querySelectorAll('.kanban-col').forEach((col) => {
        const visibleCards = col.querySelectorAll('.pcard:not(.is-filter-hidden)');
        const countEl = col.querySelector('.kanban-count');
        if (countEl) countEl.textContent = String(visibleCards.length);

        const existingEmpty = col.querySelector('.empty-col.dynamic-empty');
        if (visibleCards.length === 0) {
          if (!existingEmpty) {
            const empty = document.createElement('div');
            empty.className = 'empty-col dynamic-empty';
            empty.innerHTML = '<div class="empty-col-icon"><i class="fas fa-filter-circle-xmark"></i></div><p class="empty-col-text">Nenhum cadastro com estes filtros</p>';
            col.appendChild(empty);
          }
        } else if (existingEmpty) {
          existingEmpty.remove();
        }
      });
    }

    function applyAdvancedFilters() {
      const status = document.getElementById('filter-status')?.value || 'all';
      const team = document.getElementById('filter-team')?.value || 'all';
      const dateFrom = document.getElementById('filter-date-from')?.value || '';
      const dateTo = document.getElementById('filter-date-to')?.value || '';

      document.querySelectorAll('.smart-card').forEach((card) => {
        const cardStatus = card.dataset.status || '';
        const cardTeam = card.dataset.team || '';
        const cardDate = card.dataset.date || '';

        const statusOk = status === 'all' || cardStatus === status;
        const teamOk = team === 'all' || cardTeam === team;
        const fromOk = !dateFrom || !cardDate || cardDate >= dateFrom;
        const toOk = !dateTo || !cardDate || cardDate <= dateTo;

        card.classList.toggle('is-filter-hidden', !(statusOk && teamOk && fromOk && toOk));
      });

      refreshVisibleCounts();
    }

    function saveCurrentFilters() {
      const payload = {
        status: document.getElementById('filter-status')?.value || 'all',
        team: document.getElementById('filter-team')?.value || 'all',
        dateFrom: document.getElementById('filter-date-from')?.value || '',
        dateTo: document.getElementById('filter-date-to')?.value || '',
      };
      try {
        localStorage.setItem(FILTERS_STORAGE_KEY, JSON.stringify(payload));
        return true;
      } catch (error) {
        console.error('Falha ao salvar filtros no localStorage:', error);
        return false;
      }
    }

    function loadSavedFilters() {
      const raw = localStorage.getItem(FILTERS_STORAGE_KEY);
      if (!raw) return;

      try {
        const saved = JSON.parse(raw);
        const statusEl = document.getElementById('filter-status');
        const teamEl = document.getElementById('filter-team');
        const fromEl = document.getElementById('filter-date-from');
        const toEl = document.getElementById('filter-date-to');
        if (statusEl) statusEl.value = saved.status || 'all';
        if (teamEl) teamEl.value = saved.team || 'all';
        if (fromEl) fromEl.value = saved.dateFrom || '';
        if (toEl) toEl.value = saved.dateTo || '';
      } catch {
        localStorage.removeItem(FILTERS_STORAGE_KEY);
      }
    }

    function setupAdvancedFilters() {
      ['filter-status', 'filter-team', 'filter-date-from', 'filter-date-to'].forEach((id) => {
        const el = document.getElementById(id);
        if (el) el.addEventListener('change', applyAdvancedFilters);
      });

      document.getElementById('save-filters-btn')?.addEventListener('click', async (event) => {
        event.preventDefault();

        // Aplica primeiro para refletir imediatamente o estado atual na tela.
        applyAdvancedFilters();

        const saved = saveCurrentFilters();
        if (!saved) {
          await appAlert('Não foi possível salvar os filtros neste navegador.', 'warning', 'Atenção');
          return;
        }

        const button = event.currentTarget;
        if (!(button instanceof HTMLButtonElement)) return;

        const originalHtml = button.innerHTML;
        button.disabled = true;
        button.innerHTML = '<i class="fas fa-check"></i>Filtros salvos';

        setTimeout(() => {
          button.innerHTML = originalHtml;
          button.disabled = false;
        }, 900);
      });

      document.getElementById('clear-filters-btn')?.addEventListener('click', () => {
        const statusEl = document.getElementById('filter-status');
        const teamEl = document.getElementById('filter-team');
        const fromEl = document.getElementById('filter-date-from');
        const toEl = document.getElementById('filter-date-to');
        if (statusEl) statusEl.value = 'all';
        if (teamEl) teamEl.value = 'all';
        if (fromEl) fromEl.value = '';
        if (toEl) toEl.value = '';
        localStorage.removeItem(FILTERS_STORAGE_KEY);
        applyAdvancedFilters();
      });
    }

    async function executarAcaoRapida(id, tipoLista, action, triggerButton) {
      const endpoint = action === 'aprovar' ? '/admin/aprovar' : '/admin/desaprovar';
      const button = triggerButton;
      if (button) button.disabled = true;

      try {
        const res = await fetch(endpoint, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ id, tipoLista }),
        });
        const data = await res.json();
        if (!res.ok || !data.success) throw new Error(data.error || 'Falha na ação rápida');

        const card = button?.closest('.pcard');
        if (card) {
          card.classList.add('is-removing');
          setTimeout(() => {
            card.remove();
            refreshVisibleCounts();
          }, 320);
        }
      } catch (error) {
        if (button) button.disabled = false;
        await appAlert('Erro: ' + error.message, 'danger', 'Ação rápida falhou');
      }
    }

    function hydrateSmartCards() {
      document.querySelectorAll('.smart-card').forEach((card) => {
        const status = card.dataset.status || '';
        const tipo = card.dataset.tipo || '';
        const id = card.dataset.id || '';
        const meta = card.querySelector('.pcard-meta');
        const details = card.querySelector('.pcard-details');
        const top = card.querySelector('.pcard-top');

        if (meta && !meta.querySelector('.pcard-ai')) {
          const ai = document.createElement('div');
          ai.className = 'pcard-ai';
          if (card.dataset.incomplete === '1') {
            ai.innerHTML += '<span class="ai-chip warning"><i class="fas fa-triangle-exclamation"></i>Dados incompletos</span>';
          }
          if (card.dataset.duplicate === '1') {
            ai.innerHTML += '<span class="ai-chip danger"><i class="fas fa-clone"></i>Possível duplicado</span>';
          }
          if (card.dataset.recommended === '1') {
            ai.innerHTML += '<span class="ai-chip good"><i class="fas fa-wand-magic-sparkles"></i>Recomendado aprovar</span>';
          }
          if (!ai.innerHTML) {
            ai.innerHTML = '<span class="ai-chip neutral"><i class="fas fa-circle-info"></i>Cadastro estável</span>';
          }
          meta.appendChild(ai);
        }

        if (details && !details.querySelector('.pcard-timeline')) {
          const timeline = document.createElement('div');
          timeline.className = 'pcard-timeline';
          const createdDate = formatarDataCurta(card.dataset.date);
          const updatedDate = formatarDataCurta(card.dataset.updatedDate || card.dataset.date);
          const statusLabel = status === 'aprovado' ? 'Aprovado' : status === 'reprovado' ? 'Reprovado' : 'Em análise';
          timeline.innerHTML = `
            <div class="timeline-title"><i class="fas fa-timeline"></i>Timeline</div>
            <ul>
              <li><span>Inscrição</span><strong>${createdDate}</strong></li>
              <li><span>Última alteração</span><strong>${updatedDate}</strong></li>
              <li><span>Status atual</span><strong>${statusLabel} • Equipe Admin</strong></li>
            </ul>`;
          details.appendChild(timeline);
        }

        if (top && !top.querySelector('.pcard-quick')) {
          const quick = document.createElement('div');
          quick.className = 'pcard-quick';

          if (status !== 'aprovado') {
            const approveBtn = document.createElement('button');
            approveBtn.type = 'button';
            approveBtn.className = 'quick-icon-btn quick-approve';
            approveBtn.title = 'Aprovar com 1 clique';
            approveBtn.innerHTML = '<i class="fas fa-bolt"></i>';
            approveBtn.addEventListener('click', (event) => {
              event.stopPropagation();
              executarAcaoRapida(id, tipo, 'aprovar', approveBtn);
            });
            quick.appendChild(approveBtn);
          }

          if (status !== 'reprovado') {
            const rejectBtn = document.createElement('button');
            rejectBtn.type = 'button';
            rejectBtn.className = 'quick-icon-btn quick-reject';
            rejectBtn.title = 'Reprovar com 1 clique';
            rejectBtn.innerHTML = '<i class="fas fa-xmark"></i>';
            rejectBtn.addEventListener('click', (event) => {
              event.stopPropagation();
              executarAcaoRapida(id, tipo, 'desaprovar', rejectBtn);
            });
            quick.appendChild(rejectBtn);
          }

          const detailsBtn = document.createElement('button');
          detailsBtn.type = 'button';
          detailsBtn.className = 'quick-icon-btn quick-view';
          detailsBtn.title = 'Ver detalhes';
          detailsBtn.innerHTML = '<i class="fas fa-eye"></i>';
          detailsBtn.addEventListener('click', (event) => {
            event.stopPropagation();
            card.classList.toggle('is-expanded');
          });
          quick.appendChild(detailsBtn);

          top.appendChild(quick);
        }
      });

      refreshVisibleCounts();
    }

    function obterCheckboxesLote(scope) {
      return Array.from(document.querySelectorAll(`.batch-checkbox[data-batch-scope="${scope}"]`));
    }

    function atualizarInterfaceLote(scope) {
      const checkboxes = obterCheckboxesLote(scope);
      const selecionados = checkboxes.filter((checkbox) => checkbox.checked);
      const toolbar = document.querySelector(`.batch-toolbar[data-batch-scope="${scope}"]`);

      checkboxes.forEach((checkbox) => {
        const card = checkbox.closest('.selectable-card');
        if (card) {
          card.classList.toggle('is-selected', checkbox.checked);
        }
      });

      if (!toolbar) return;

      const counter = toolbar.querySelector('.batch-counter');
      const actionButtons = toolbar.querySelectorAll('[data-batch-action]');
      if (counter) {
        counter.textContent = `${selecionados.length} selecionado(s)`;
      }

      actionButtons.forEach((button) => {
        button.disabled = selecionados.length === 0;
      });
    }

    const STATUS_CARD_CLASS = {
      pendente: 'amber-card',
      aprovado: 'green-card',
      reprovado: 'red-card',
    };

    function selecionarTodosLote(scope) {
      obterCheckboxesLote(scope).forEach((checkbox) => {
        checkbox.checked = true;
      });
      atualizarInterfaceLote(scope);
    }

    function limparSelecaoLote(scope) {
      obterCheckboxesLote(scope).forEach((checkbox) => {
        checkbox.checked = false;
      });
      atualizarInterfaceLote(scope);
    }

    function selecionarPorStatusLote(scope, status) {
      const cardClass = STATUS_CARD_CLASS[status];
      obterCheckboxesLote(scope).forEach((checkbox) => {
        const card = checkbox.closest('.selectable-card');
        checkbox.checked = card ? card.classList.contains(cardClass) : false;
      });
      atualizarInterfaceLote(scope);
    }

    async function executarAcaoLote(scope, action) {
      const selecionados = obterCheckboxesLote(scope)
        .filter((checkbox) => checkbox.checked)
        .map((checkbox) => checkbox.dataset.batchId);

      if (selecionados.length === 0) {
        await appAlert('Selecione pelo menos um cadastro para continuar.', 'warning', 'Nenhuma seleção');
        return;
      }

      const verbo = action === 'aprovar' ? 'aprovar' : 'reprovar';
      const confirmacao = await appConfirm(`Tem certeza que deseja ${verbo} ${selecionados.length} cadastro(s) de uma vez?`, `Confirmar ${verbo} em lote`);
      if (!confirmacao) return;

      try {
        const res = await fetch('/admin/aprovacao-lote', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ ids: selecionados, tipoLista: scope, action })
        });
        const data = await res.json();

        if (!res.ok || !data.success) {
          throw new Error(data.error || 'Falha ao processar atualização em lote');
        }

        const complemento = data.missingCount > 0
          ? ` ${data.missingCount} cadastro(s) não foram encontrados.`
          : '';

        await appAlert(`${data.updatedCount} cadastro(s) atualizados com sucesso.${complemento}`, 'success', 'Sucesso');
        location.reload();
      } catch (e) {
        await appAlert('Erro: ' + e.message, 'danger', 'Erro');
      }
    }

    document.addEventListener('change', (event) => {
      if (!event.target.classList.contains('batch-checkbox')) return;
      atualizarInterfaceLote(event.target.dataset.batchScope);
    });

    document.addEventListener('DOMContentLoaded', () => {
      setupMotionModeControls();
      setupEventScopeControls();
      setupAdvancedFilters();

      window.requestAnimationFrame(() => {
        window.requestAnimationFrame(() => {
          const loadDelay = document.body.classList.contains('motion-mode-executivo') ? 220 : 300;
          setTimeout(() => {
            document.body.classList.remove('is-loading');
            document.body.classList.add('is-loaded');
          }, loadDelay);
        });
      });

      ['encontrista', 'encontreiro'].forEach(atualizarInterfaceLote);
      hydrateSmartCards();
      loadSavedFilters();
      applyAdvancedFilters();

      document.querySelectorAll('[data-board-tabs]').forEach((tabGroup) => {
        const panel = tabGroup.closest('.section-panel');
        if (!panel) return;

        tabGroup.addEventListener('click', (event) => {
          const button = event.target.closest('.status-tab');
          if (!button) return;

          const view = button.dataset.view || 'all';
          tabGroup.querySelectorAll('.status-tab').forEach((tab) => tab.classList.remove('active'));
          button.classList.add('active');

          panel.classList.remove('view-all', 'view-pendente', 'view-aprovado', 'view-reprovado');
          panel.classList.add(`view-${view}`);
        });
      });

      document.querySelectorAll('.pcard').forEach((card) => {
        const header = card.querySelector('.pcard-top');
        if (!header) return;
        header.addEventListener('click', (event) => {
          if (event.target.closest('button, a, input, label')) return;
          card.classList.toggle('is-expanded');
        });
      });
    });

    function toggleCardDetails(trigger) {
      const card = trigger.closest('.pcard');
      if (!card) return;
      card.classList.toggle('is-expanded');
    }

    /* ── Actions ─────────────────────────────────────────────── */
    async function aprovarCadastro(id, tipoLista) {
      if (!await appConfirm('Tem certeza que deseja aprovar este cadastro?', 'Confirmar aprovação')) return;
      try {
        const res  = await fetch('/admin/aprovar', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ id, tipoLista }) });
        const data = await res.json();
        if (data.success) { await appAlert('Cadastro aprovado com sucesso.', 'success', 'Sucesso'); location.reload(); }
        else await appAlert('Erro: ' + (data.error || 'Falha ao aprovar'), 'danger', 'Erro');
      } catch (e) { await appAlert('Erro: ' + e.message, 'danger', 'Erro'); }
    }

    async function desaprovarCadastro(id, tipoLista) {
      if (!await appConfirm('Tem certeza que deseja desaprovar este cadastro?', 'Confirmar desaprovação')) return;
      try {
        const res  = await fetch('/admin/desaprovar', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ id, tipoLista }) });
        const data = await res.json();
        if (data.success) { await appAlert('Cadastro desaprovado com sucesso.', 'success', 'Sucesso'); location.reload(); }
        else await appAlert('Erro: ' + (data.error || 'Falha ao desaprovar'), 'danger', 'Erro');
      } catch (e) { await appAlert('Erro: ' + e.message, 'danger', 'Erro'); }
    }
  </script>
  <script src="/js/page-transitions.js"></script>
</body>
</html>

