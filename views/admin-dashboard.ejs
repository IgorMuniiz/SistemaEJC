  <script src="/vendor/bootstrap/js/bootstrap.bundle.min.js"></script>
  <script>
    /* ── Modal helper ────────────────────────────────────────── */
    function ensureAppPopup() {
      let el = document.getElementById('app-popup-modal');
      if (el) return { element: el, instance: bootstrap.Modal.getOrCreateInstance(el) };
      el = document.createElement('div');
      el.className = 'modal fade';
      el.id = 'app-popup-modal';
      el.tabIndex = -1;
      el.setAttribute('aria-hidden', 'true');
      el.innerHTML = `
        <div class="modal-dialog modal-dialog-centered">
          <div class="modal-content">
            <div class="modal-header">
              <h5 class="modal-title" id="app-popup-title">Aviso</h5>
              <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Fechar"></button>
            </div>
            <div class="modal-body">
              <p id="app-popup-message" class="mb-0" style="white-space:pre-line;"></p>
            </div>
            <div class="modal-footer">
              <button type="button" class="btn btn-outline-secondary" id="app-popup-cancel">Cancelar</button>
              <button type="button" class="btn btn-primary" id="app-popup-confirm">OK</button>
            </div>
          </div>
        </div>`;
      document.body.appendChild(el);
      return { element: el, instance: bootstrap.Modal.getOrCreateInstance(el) };
    }

    function showAppPopup({ title, message, confirmText = 'OK', cancelText = null, tone = 'primary' }) {
      const { element, instance } = ensureAppPopup();
      element.querySelector('#app-popup-title').textContent = title || 'Aviso';
      element.querySelector('#app-popup-message').textContent = message || '';
      const confirmBtn = element.querySelector('#app-popup-confirm');
      const cancelBtn  = element.querySelector('#app-popup-cancel');
      confirmBtn.textContent = confirmText;
      confirmBtn.className = `btn btn-${tone}`;
      cancelBtn.style.display = cancelText ? '' : 'none';
      if (cancelText) cancelBtn.textContent = cancelText;

      return new Promise(resolve => {
        let resolved = false;
        const cleanup = () => {
          confirmBtn.removeEventListener('click', onConfirm);
          cancelBtn.removeEventListener('click', onCancel);
          element.removeEventListener('hidden.bs.modal', onHidden);
        };
        const settle = v => { if (resolved) return; resolved = true; cleanup(); resolve(v); };
        const onConfirm = () => { settle(true);  instance.hide(); };
        const onCancel  = () => { settle(false); instance.hide(); };
        const onHidden  = () => settle(false);
        confirmBtn.addEventListener('click', onConfirm);
        cancelBtn.addEventListener('click', onCancel);
        element.addEventListener('hidden.bs.modal', onHidden, { once: true });
        instance.show();
      });
    }

    const appAlert   = (msg, tone = 'primary', title = 'Aviso') =>
      showAppPopup({ title, message: msg, confirmText: 'Entendi', tone });
    const appConfirm = (msg, title = 'Confirmação') =>
      showAppPopup({ title, message: msg, confirmText: 'Confirmar', cancelText: 'Cancelar', tone: 'warning' });

    /* ── Actions ─────────────────────────────────────────────── */
    async function aprovarCadastro(id, tipoLista) {
      if (!await appConfirm('Tem certeza que deseja aprovar este cadastro?', 'Confirmar aprovação')) return;
      try {
        const res  = await fetch('/admin/aprovar', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ id, tipoLista }) });
        const data = await res.json();
        if (data.success) { await appAlert('Cadastro aprovado com sucesso.', 'success', 'Sucesso'); location.reload(); }
        else await appAlert('Erro: ' + (data.error || 'Falha ao aprovar'), 'danger', 'Erro');
      } catch (e) { await appAlert('Erro: ' + e.message, 'danger', 'Erro'); }
    }

    async function desaprovarCadastro(id, tipoLista) {
      if (!await appConfirm('Tem certeza que deseja desaprovar este cadastro?', 'Confirmar desaprovação')) return;
      try {
        const res  = await fetch('/admin/desaprovar', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ id, tipoLista }) });
        const data = await res.json();
        if (data.success) { await appAlert('Cadastro desaprovado com sucesso.', 'success', 'Sucesso'); location.reload(); }
        else await appAlert('Erro: ' + (data.error || 'Falha ao desaprovar'), 'danger', 'Erro');
      } catch (e) { await appAlert('Erro: ' + e.message, 'danger', 'Erro'); }
    }
  </script>
</body>
</html>

